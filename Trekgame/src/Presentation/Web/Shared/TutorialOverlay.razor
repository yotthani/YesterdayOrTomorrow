@using Blazored.LocalStorage
@using System.Text.Json
@using System.Text.Json.Serialization
@inject ILocalStorageService LocalStorage
@inject NavigationManager Navigation
@inject HttpClient Http
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (_showTutorial && _currentStep != null)
{
    <div class="tutorial-overlay">
        <div class="tutorial-backdrop" @onclick="SkipTutorial"></div>

        @if (_currentStep.HighlightSelector != null && _highlightBounds != null)
        {
            <div class="tutorial-highlight" style="@GetHighlightStyle()"></div>
        }

        <div class="tutorial-dialog @GetDialogCssClass()" style="@GetDialogPositionStyle()">
            <div class="dialog-header">
                <span class="step-indicator">Step @(_currentStepIndex + 1) of @_steps.Count</span>
                <span class="dialog-title">@_currentStep.Title</span>
            </div>
            <div class="dialog-content">
                <div class="dialog-icon">@_currentStep.Icon</div>
                <p>@_currentStep.Content</p>
                @if (_currentStep.Tips?.Any() == true)
                {
                    <ul class="dialog-tips">
                        @foreach (var tip in _currentStep.Tips)
                        {
                            <li>@tip</li>
                        }
                    </ul>
                }
            </div>
            <div class="dialog-footer">
                @if (_currentStepIndex > 0)
                {
                    <button class="tutorial-btn secondary" @onclick="PreviousStep">← Back</button>
                }
                <button class="tutorial-btn skip" @onclick="SkipTutorial">Skip Tutorial</button>
                @if (_currentStepIndex < _steps.Count - 1)
                {
                    <button class="tutorial-btn primary" @onclick="NextStep">Next →</button>
                }
                else
                {
                    <button class="tutorial-btn primary" @onclick="CompleteTutorial">🚀 Start Playing!</button>
                }
            </div>
            <div class="progress-bar">
                <div class="progress-fill" style="width: @((_currentStepIndex + 1) * 100 / _steps.Count)%"></div>
            </div>
        </div>
    </div>
}

<style>
    .tutorial-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        pointer-events: auto;
    }
    .tutorial-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.7);
    }
    .tutorial-highlight {
        position: absolute;
        border: 3px solid #ff9900;
        border-radius: 8px;
        box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.7), 0 0 20px #ff9900;
        pointer-events: none;
        animation: pulse-highlight 2s infinite;
        transition: all 0.3s ease;
    }
    @@keyframes pulse-highlight {
        0%, 100% { box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.7), 0 0 20px #ff9900; }
        50% { box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.7), 0 0 40px #ff9900; }
    }
    .tutorial-dialog {
        position: absolute;
        width: 420px;
        background: linear-gradient(180deg, rgba(20, 30, 50, 0.98) 0%, rgba(10, 15, 25, 0.98) 100%);
        border: 2px solid #ff9900;
        border-radius: 12px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
        overflow: hidden;
    }
    .tutorial-dialog.center { top: 50%; left: 50%; transform: translate(-50%, -50%); }
    .tutorial-dialog.top-right { top: 100px; right: 40px; }
    .tutorial-dialog.top-left { top: 100px; left: 40px; }
    .tutorial-dialog.bottom-right { bottom: 100px; right: 40px; }
    .tutorial-dialog.bottom-left { bottom: 100px; left: 40px; }
    .tutorial-dialog.positioned { position: absolute; }

    .dialog-header {
        padding: 16px 20px;
        background: rgba(255, 153, 0, 0.1);
        border-bottom: 1px solid rgba(255, 153, 0, 0.3);
    }
    .step-indicator {
        display: block;
        font-size: 10px;
        color: #7890a8;
        letter-spacing: 1px;
        margin-bottom: 4px;
    }
    .dialog-title {
        font-size: 18px;
        font-weight: 600;
        color: #ff9900;
    }
    .dialog-content {
        padding: 20px;
    }
    .dialog-icon {
        font-size: 48px;
        text-align: center;
        margin-bottom: 16px;
    }
    .dialog-content p {
        font-size: 14px;
        line-height: 1.6;
        color: #c8d4e8;
        margin: 0;
    }
    .dialog-tips {
        margin-top: 16px;
        padding-left: 20px;
    }
    .dialog-tips li {
        font-size: 12px;
        color: #7890a8;
        margin: 6px 0;
    }
    .dialog-footer {
        display: flex;
        gap: 10px;
        padding: 16px 20px;
        background: rgba(0, 0, 0, 0.2);
    }
    .tutorial-btn {
        padding: 10px 20px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.15s;
    }
    .tutorial-btn.primary {
        background: linear-gradient(180deg, #ff9900, #cc7700);
        border: none;
        color: #000;
        margin-left: auto;
    }
    .tutorial-btn.primary:hover { background: linear-gradient(180deg, #ffaa22, #dd8800); }
    .tutorial-btn.secondary {
        background: transparent;
        border: 1px solid rgba(255, 153, 0, 0.5);
        color: #ff9900;
    }
    .tutorial-btn.secondary:hover { background: rgba(255, 153, 0, 0.1); }
    .tutorial-btn.skip {
        background: transparent;
        border: 1px solid rgba(120, 144, 168, 0.5);
        color: #7890a8;
    }
    .tutorial-btn.skip:hover { background: rgba(120, 144, 168, 0.1); }
    .progress-bar {
        height: 4px;
        background: rgba(255, 153, 0, 0.2);
    }
    .progress-fill {
        height: 100%;
        background: #ff9900;
        transition: width 0.3s;
    }
</style>

@code {
    private bool _showTutorial;
    private int _currentStepIndex;
    private TutorialStep? _currentStep => _steps.ElementAtOrDefault(_currentStepIndex);
    private List<TutorialStep> _steps = new();

    private ElementBounds? _highlightBounds;
    private DialogPosition? _dialogPosition;
    private DotNetObjectReference<TutorialOverlay>? _selfRef;
    private bool _firstRenderDone;

    protected override async Task OnInitializedAsync()
    {
        var hasSeenTutorial = await LocalStorage.GetItemAsync<bool>("hasSeenTutorial");
        _showTutorial = !hasSeenTutorial;

        try
        {
            var loaded = await Http.GetFromJsonAsync<List<TutorialStep>>("data/tutorials/first-game.json");
            if (loaded != null && loaded.Count > 0)
            {
                _steps = loaded;
            }
        }
        catch
        {
            // Graceful degradation: if JSON fails, steps remain empty
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _firstRenderDone = true;
            _selfRef = DotNetObjectReference.Create(this);

            try
            {
                await JS.InvokeVoidAsync("TutorialHighlight.onResize", _selfRef);
            }
            catch
            {
                // JS module may not be loaded yet
            }

            if (_showTutorial && _currentStep != null)
            {
                await UpdateHighlight();
            }
        }
    }

    private async Task UpdateHighlight()
    {
        _highlightBounds = null;
        _dialogPosition = null;

        if (_currentStep?.HighlightSelector == null || !_firstRenderDone)
        {
            StateHasChanged();
            return;
        }

        try
        {
            var boundsJson = await JS.InvokeAsync<JsonElement?>(
                "TutorialHighlight.getElementBounds", _currentStep.HighlightSelector);

            if (boundsJson.HasValue && boundsJson.Value.ValueKind == JsonValueKind.Object)
            {
                var b = boundsJson.Value;
                _highlightBounds = new ElementBounds(
                    b.GetProperty("x").GetDouble(),
                    b.GetProperty("y").GetDouble(),
                    b.GetProperty("width").GetDouble(),
                    b.GetProperty("height").GetDouble()
                );

                await JS.InvokeVoidAsync("TutorialHighlight.scrollToElement", _currentStep.HighlightSelector);

                // Get dialog position relative to the highlighted element
                var dialogJson = await JS.InvokeAsync<JsonElement?>(
                    "TutorialHighlight.getDialogPosition",
                    boundsJson.Value, 420, 300, _currentStep.Position ?? "bottom");

                if (dialogJson.HasValue && dialogJson.Value.ValueKind == JsonValueKind.Object)
                {
                    var d = dialogJson.Value;
                    _dialogPosition = new DialogPosition(
                        d.GetProperty("x").GetDouble(),
                        d.GetProperty("y").GetDouble()
                    );
                }
            }
            else
            {
                // Element not found yet — observe for it to appear
                if (_selfRef != null)
                {
                    await JS.InvokeVoidAsync(
                        "TutorialHighlight.observeElement", _currentStep.HighlightSelector, _selfRef);
                }
            }
        }
        catch
        {
            // JS interop failure — highlight will simply not show
        }

        StateHasChanged();
    }

    private string GetHighlightStyle()
    {
        if (_highlightBounds == null) return "";
        var b = _highlightBounds;
        return $"top: {b.Y - 4:F0}px; left: {b.X - 4:F0}px; width: {b.Width + 8:F0}px; height: {b.Height + 8:F0}px;";
    }

    private string GetDialogCssClass()
    {
        // When JS-positioned (element has highlight bounds), use "positioned" class
        if (_dialogPosition != null)
            return "positioned";

        // Otherwise fall back to CSS position classes
        return _currentStep?.Position ?? "center";
    }

    private string GetDialogPositionStyle()
    {
        if (_dialogPosition == null)
            return "";

        return $"top: {_dialogPosition.Y:F0}px; left: {_dialogPosition.X:F0}px;";
    }

    private async Task NextStep()
    {
        if (_currentStepIndex >= _steps.Count - 1) return;

        var nextStep = _steps.ElementAtOrDefault(_currentStepIndex + 1);
        var currentRoute = _currentStep?.NextRoute;

        _currentStepIndex++;
        _highlightBounds = null;
        _dialogPosition = null;

        if (!string.IsNullOrEmpty(currentRoute))
        {
            Navigation.NavigateTo(currentRoute);
            await Task.Delay(400);
        }

        await UpdateHighlight();
    }

    private async Task PreviousStep()
    {
        if (_currentStepIndex <= 0) return;

        _currentStepIndex--;
        _highlightBounds = null;
        _dialogPosition = null;

        await UpdateHighlight();
    }

    private async Task SkipTutorial()
    {
        await LocalStorage.SetItemAsync("hasSeenTutorial", true);
        _showTutorial = false;

        try
        {
            await JS.InvokeVoidAsync("TutorialHighlight.stopObserving");
        }
        catch { }
    }

    private async Task CompleteTutorial()
    {
        await LocalStorage.SetItemAsync("hasSeenTutorial", true);
        _showTutorial = false;

        try
        {
            await JS.InvokeVoidAsync("TutorialHighlight.stopObserving");
        }
        catch { }
    }

    public async void ShowTutorial()
    {
        _currentStepIndex = 0;
        _showTutorial = true;
        _highlightBounds = null;
        _dialogPosition = null;
        StateHasChanged();

        if (_firstRenderDone)
        {
            await UpdateHighlight();
        }
    }

    [JSInvokable]
    public async Task OnWindowResized()
    {
        if (_showTutorial && _currentStep != null)
        {
            await UpdateHighlight();
        }
    }

    [JSInvokable]
    public async Task OnElementReady()
    {
        if (_showTutorial && _currentStep != null)
        {
            await UpdateHighlight();
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("TutorialHighlight.offResize");
        }
        catch { }

        try
        {
            await JS.InvokeVoidAsync("TutorialHighlight.stopObserving");
        }
        catch { }

        _selfRef?.Dispose();
    }

    // ---------------------------------------------------------------
    // Models
    // ---------------------------------------------------------------

    private record ElementBounds(double X, double Y, double Width, double Height);

    private record DialogPosition(double X, double Y);

    private class TutorialStep
    {
        [JsonPropertyName("id")]
        public string Id { get; set; } = "";

        [JsonPropertyName("title")]
        public string Title { get; set; } = "";

        [JsonPropertyName("icon")]
        public string Icon { get; set; } = "";

        [JsonPropertyName("content")]
        public string Content { get; set; } = "";

        [JsonPropertyName("tips")]
        public string[]? Tips { get; set; }

        [JsonPropertyName("position")]
        public string Position { get; set; } = "center";

        [JsonPropertyName("highlightSelector")]
        public string? HighlightSelector { get; set; }

        [JsonPropertyName("nextRoute")]
        public string? NextRoute { get; set; }
    }
}
