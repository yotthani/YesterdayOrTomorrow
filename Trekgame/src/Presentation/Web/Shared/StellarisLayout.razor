    /// <summary>
    /// Game state shared via CascadingValue to all child pages
    /// </summary>
    public class GameLayoutState
    {
        public Guid? GameId { get; set; }
        public Guid? FactionId { get; set; }
        public bool IsAdmin { get; set; }
        public string FactionName { get; set; } = "United Federation";
        public string RaceId { get; set; } = "federation";
        public string GovernmentType { get; set; } = "Starfleet Command";
        public int CurrentTurn { get; set; }
        public string Stardate { get; set; } = "24.56";

        // Resources
        public int Energy { get; set; } = 1250;
        public int EnergyIncome { get; set; } = 45;
        public int Minerals { get; set; } = 890;
        public int Food { get; set; } = 120;
        public int Alloys { get; set; } = 340;
        public int Research { get; set; } = 85;

        // ── Topbar Override (pages can customize the topbar via these) ──
        public string? TopbarIcon { get; set; }
        public string? TopbarTitle { get; set; }
        public string? TopbarSubtitle { get; set; }
        public string? TopbarCssClass { get; set; }
        public bool ShowResources { get; set; } = true;
        public bool ShowEndTurn { get; set; } = true;

        public event Action? OnLayoutChanged;

        public void SetTopbarOverride(string icon, string title,
            string? subtitle = null, string? cssClass = null,
            bool showResources = true, bool showEndTurn = true)
        {
            TopbarIcon = icon;
            TopbarTitle = title;
            TopbarSubtitle = subtitle;
            TopbarCssClass = cssClass;
            ShowResources = showResources;
            ShowEndTurn = showEndTurn;
            OnLayoutChanged?.Invoke();
        }

        public void ResetTopbar()
        {
            TopbarIcon = null;
            TopbarTitle = null;
            TopbarSubtitle = null;
            TopbarCssClass = null;
            ShowResources = true;
            ShowEndTurn = true;
            OnLayoutChanged?.Invoke();
        }
    }
