@inherits LayoutComponentBase
@using MudBlazor
@using StarTrekGame.Web.Services
@using Blazored.LocalStorage
@using Microsoft.AspNetCore.SignalR.Client
@using System.Text.Json
@using StarTrekGame.Web.Components.UI
@inject ThemeService ThemeService
@inject IGameApiClient Api
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject HotSeatService HotSeatService
@inject INotificationService NotificationSvc
@implements IAsyncDisposable

<MudThemeProvider IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingValue Name="GameState" Value="@_gameState">
<CascadingValue Name="MultiplayerState" Value="@_mpState">
<div class="stellaris-app" data-theme="@ThemeService.CurrentTheme">
    <div class="stellaris-layout">
        @* ═══════════════════════════════════════════════════════════════════
           TOP BAR - Empire Badge, Resources, Game Controls
           ═══════════════════════════════════════════════════════════════════ *@
        <header class="st-topbar @_gameState.TopbarCssClass">
            <div class="st-empire-badge">
                <div class="st-empire-flag">@(_gameState.TopbarIcon ?? "🌐")</div>
                <div class="st-empire-info">
                    <span class="st-empire-name">@(_gameState.TopbarTitle ?? _gameState.FactionName)</span>
                    <span class="st-empire-type">@(_gameState.TopbarSubtitle ?? _gameState.GovernmentType)</span>
                </div>
            </div>

            @if (_gameState.ShowResources)
            {
                <div class="st-resources">
                    <div class="st-resource"><span class="st-resource-icon">⚡</span><div class="st-resource-values"><span class="st-resource-current">@_gameState.Energy.ToString("N0")</span>@if(_gameState.EnergyIncome!=0){<span class="st-resource-income @(_gameState.EnergyIncome>0?"positive":"negative")">@FormatIncome(_gameState.EnergyIncome)</span>}</div></div>
                    <div class="st-resource"><span class="st-resource-icon">💎</span><div class="st-resource-values"><span class="st-resource-current">@_gameState.Minerals.ToString("N0")</span></div></div>
                    <div class="st-resource"><span class="st-resource-icon">🌾</span><div class="st-resource-values"><span class="st-resource-current">@_gameState.Food.ToString("N0")</span></div></div>
                    <div class="st-resource"><span class="st-resource-icon">🔩</span><div class="st-resource-values"><span class="st-resource-current">@_gameState.Alloys.ToString("N0")</span></div></div>
                    <div class="st-resource"><span class="st-resource-icon">🔬</span><div class="st-resource-values"><span class="st-resource-current">@_gameState.Research.ToString("N0")</span></div></div>
                </div>
            }

            <div class="st-game-controls">
                <div class="st-notification-bell" @onclick="ToggleNotificationPanel" @onclick:stopPropagation="true">
                    <span class="st-bell-icon">&#x1F514;</span>
                    @if (NotificationSvc.UnreadCount > 0)
                    {
                        <span class="st-bell-badge">@(NotificationSvc.UnreadCount > 99 ? "99+" : NotificationSvc.UnreadCount.ToString())</span>
                    }
                    @if (_showNotifications)
                    {
                        <div class="st-notification-dropdown" @onclick:stopPropagation="true">
                            <div class="st-notification-header">
                                <span>Notifications</span>
                                @if (NotificationSvc.UnreadCount > 0)
                                {
                                    <button class="st-notification-mark-read" @onclick="() => NotificationSvc.MarkAllAsRead()">Mark all read</button>
                                }
                            </div>
                            <div class="st-notification-list">
                                @if (!NotificationSvc.Notifications.Any())
                                {
                                    <div class="st-notification-empty">No notifications</div>
                                }
                                else
                                {
                                    @foreach (var n in NotificationSvc.Notifications.Take(15))
                                    {
                                        <div class="st-notification-item @(!n.IsRead ? "unread" : "")" @onclick="() => OnNotificationClick(n)">
                                            <span class="st-notification-icon" style="color: @n.TypeColor">@n.TypeIcon</span>
                                            <div class="st-notification-content">
                                                <div class="st-notification-title">@n.Title</div>
                                                <div class="st-notification-message">@n.Message</div>
                                            </div>
                                            <span class="st-notification-time">@FormatTimeAgo(n.Timestamp)</span>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
                <div class="st-date-display">
                    <span class="st-date-label">STARDATE</span>
                    <span class="st-date-value">@_gameState.Stardate</span>
                </div>
                @if (_gameState.ShowEndTurn)
                {
                    <button class="st-end-turn-btn" @onclick="EndTurn" disabled="@_processingTurn">END TURN</button>
                }
                <a href="/game/settings" class="st-btn sm settings-btn" title="Settings">⚙</a>
                @if (_gameState.IsAdmin && _gameState.ShowEndTurn)
                {
                    <button class="admin-force-btn" @onclick="ForceProcessTurn" disabled="@_processingTurn" title="Admin: Force process turn immediately">⚡ FORCE</button>
                }
            </div>
        </header>

        @if (_mpState.IsMultiplayer)
        {
            <MultiplayerTopbar OnReadyClicked="ToggleReady"
                               OnChatToggled="ToggleChat"
                               OnSpeedChanged="SetGameSpeed"
                               OnPauseClicked="TogglePause" />
        }

        @if (_mpState.IsMultiplayer)
        {
            <ChatPanel IsOpen="_chatOpen" IsOpenChanged="OnChatOpenChanged" OnSendMessage="OnChatSendMessage" />
        }

        @* ═══════════════════════════════════════════════════════════════════
           MAIN AREA - Sidebar + Content
           ═══════════════════════════════════════════════════════════════════ *@
        <div class="st-main">
            <aside class="st-sidebar-left">
                <nav class="st-nav">
                    <a href="/game/galaxy" class="st-nav-btn @IsActive("/game/galaxy","/game/map")"><span class="st-nav-icon">🌌</span><span class="st-nav-label">Galaxy</span></a>
                    <a href="/game/planets" class="st-nav-btn @IsActive("/game/planets","/game/colonies")"><span class="st-nav-icon">🏠</span><span class="st-nav-label">Planets</span></a>
                    <a href="/game/fleets" class="st-nav-btn @IsActive("/game/fleets","/game/military")"><span class="st-nav-icon">🚀</span><span class="st-nav-label">Fleets</span></a>
                    <a href="/game/research" class="st-nav-btn @IsActive("/game/research","/game/tech")"><span class="st-nav-icon">🔬</span><span class="st-nav-label">Research</span></a>
                    <a href="/game/contacts" class="st-nav-btn @IsActive("/game/contacts","/game/diplomacy")"><span class="st-nav-icon">👥</span><span class="st-nav-label">Diplomacy</span></a>
                    <a href="/game/economy" class="st-nav-btn @IsActive("/game/economy")"><span class="st-nav-icon">💰</span><span class="st-nav-label">Economy</span></a>
                    <a href="/game/intelligence" class="st-nav-btn @IsActive("/game/intelligence")"><span class="st-nav-icon">👁</span><span class="st-nav-label">Intel</span></a>
                    <a href="/game/stations" class="st-nav-btn @IsActive("/game/stations","/game/station-designer")"><span class="st-nav-icon">⚓</span><span class="st-nav-label">Stations</span></a>
                    <a href="/game/leaders" class="st-nav-btn @IsActive("/game/leaders")"><span class="st-nav-icon">👤</span><span class="st-nav-label">Leaders</span></a>
                    <a href="/game/species" class="st-nav-btn @IsActive("/game/species")"><span class="st-nav-icon">🧬</span><span class="st-nav-label">Species</span></a>
                    <a href="/game/ship-designer" class="st-nav-btn @IsActive("/game/ship-designer","/game/designer")"><span class="st-nav-icon">🔧</span><span class="st-nav-label">Designer</span></a>
                    <a href="/game/policies" class="st-nav-btn @IsActive("/game/policies")"><span class="st-nav-icon">📜</span><span class="st-nav-label">Policies</span></a>
                    <a href="/game/crisis" class="st-nav-btn @IsActive("/game/crisis")"><span class="st-nav-icon">🚨</span><span class="st-nav-label">Crisis</span></a>
                    <a href="/game/victory-status" class="st-nav-btn @IsActive("/game/victory-status","/game/victory")"><span class="st-nav-icon">🏆</span><span class="st-nav-label">Victory</span></a>
                </nav>
            </aside>

            <div class="st-page-wrapper">
                @Body
            </div>
        </div>

        @* ═══════════════════════════════════════════════════════════════════
           BOTTOM BAR
           ═══════════════════════════════════════════════════════════════════ *@
        <footer class="st-bottombar">
            <div class="st-notifications"></div>
            <div class="st-bottom-actions">
                <button class="st-btn sm" @onclick='() => Navigation.NavigateTo("/")'>☰ MENU</button>
                <a href="/game/help" class="st-btn sm">? HELP</a>
                <button class="st-btn sm" @onclick="StartTutorial">📚 TUTORIAL</button>
            </div>
        </footer>
    </div>
</div>
@if (_mpState.Mode == GameMode.HotSeat && HotSeatService.ShowSplash)
{
    <HotSeatSplash NextPlayer="HotSeatService.CurrentPlayer"
                   IsVisible="true"
                   OnConfirm="OnHotSeatConfirm" />
}
<TutorialOverlay @ref="_tutorialOverlay" />
@if (_showTurnSummary && _turnReport != null)
{
    <div class="turn-summary-overlay" @onclick="DismissTurnSummary">
        <div class="turn-summary-modal" @onclick:stopPropagation="true">
            <div class="turn-summary-header">
                <span class="turn-summary-title">TURN @_summaryTurn REPORT</span>
                <button class="turn-summary-close" @onclick="DismissTurnSummary">&times;</button>
            </div>
            <div class="turn-summary-body">
                @* ECONOMY *@
                @if (_turnReport.CreditsIncome != 0 || _turnReport.CreditsExpenses != 0 || _turnReport.EnergyBalance != 0 || _turnReport.FoodBalance != 0)
                {
                    <div class="turn-summary-section">
                        <div class="turn-summary-section-title"><span class="turn-summary-icon">💰</span> Economy</div>
                        <div class="turn-summary-grid">
                            <span class="ts-label">Income:</span><span class="ts-value ts-positive">+@_turnReport.CreditsIncome ₵</span>
                            <span class="ts-label">Expenses:</span><span class="ts-value ts-negative">-@_turnReport.CreditsExpenses ₵</span>
                            <span class="ts-label">Net:</span><span class="ts-value @(_turnReport.CreditsIncome - _turnReport.CreditsExpenses >= 0 ? "ts-positive" : "ts-negative")">@((_turnReport.CreditsIncome - _turnReport.CreditsExpenses >= 0 ? "+" : ""))@(_turnReport.CreditsIncome - _turnReport.CreditsExpenses) ₵</span>
                            @if (_turnReport.EnergyBalance != 0)
                            {
                                <span class="ts-label">Energy:</span><span class="ts-value @(_turnReport.EnergyBalance >= 0 ? "ts-positive" : "ts-negative")">@(_turnReport.EnergyBalance >= 0 ? "+" : "")@_turnReport.EnergyBalance ⚡</span>
                            }
                            @if (_turnReport.FoodBalance != 0)
                            {
                                <span class="ts-label">Food:</span><span class="ts-value @(_turnReport.FoodBalance >= 0 ? "ts-positive" : "ts-negative")">@(_turnReport.FoodBalance >= 0 ? "+" : "")@_turnReport.FoodBalance 🍞</span>
                            }
                        </div>
                    </div>
                }

                @* RESEARCH *@
                @if (_turnReport.TechCompleted != null || _turnReport.ResearchProgress > 0)
                {
                    <div class="turn-summary-section">
                        <div class="turn-summary-section-title"><span class="turn-summary-icon">🔬</span> Research</div>
                        @if (_turnReport.TechCompleted != null)
                        {
                            <div class="turn-summary-highlight">Completed: @_turnReport.TechCompleted</div>
                        }
                        @if (_turnReport.ResearchProgress > 0 && _turnReport.TechCompleted == null)
                        {
                            <div class="ts-progress">Current research: @_turnReport.ResearchProgress%</div>
                        }
                    </div>
                }

                @* CONSTRUCTION *@
                @if (_turnReport.BuildingsCompleted.Any() || _turnReport.ShipsCompleted.Any() || _turnReport.StationsCompleted.Any() || _turnReport.ModulesCompleted.Any())
                {
                    <div class="turn-summary-section">
                        <div class="turn-summary-section-title"><span class="turn-summary-icon">🏗️</span> Construction</div>
                        @foreach (var b in _turnReport.BuildingsCompleted)
                        {
                            <div class="turn-summary-item">@b</div>
                        }
                        @foreach (var s in _turnReport.ShipsCompleted)
                        {
                            <div class="turn-summary-item">@s</div>
                        }
                        @foreach (var st in _turnReport.StationsCompleted)
                        {
                            <div class="turn-summary-item turn-summary-highlight">@st</div>
                        }
                        @foreach (var m in _turnReport.ModulesCompleted)
                        {
                            <div class="turn-summary-item">@m</div>
                        }
                    </div>
                }

                @* MILITARY *@
                @if (_turnReport.Combats.Any() || _turnReport.FleetArrivals.Any())
                {
                    <div class="turn-summary-section">
                        <div class="turn-summary-section-title"><span class="turn-summary-icon">⚔️</span> Military</div>
                        @foreach (var c in _turnReport.Combats)
                        {
                            <div class="turn-summary-item @(c.AttackerVictory ? "ts-positive" : "ts-negative")">
                                @c.SystemName: @c.AttackerName vs @c.DefenderName — @(c.AttackerVictory ? "Victory!" : "Defeat") (Losses: @(c.AttackerVictory ? c.DefenderLosses : c.AttackerLosses))
                            </div>
                        }
                        @foreach (var f in _turnReport.FleetArrivals)
                        {
                            <div class="turn-summary-item">@f</div>
                        }
                    </div>
                }

                @* Ground Combat *@
                @if ((_turnReport?.InvasionResults?.Count ?? 0) > 0 || (_turnReport?.ArmiesRecruited?.Count ?? 0) > 0)
                {
                    <div class="turn-summary-section">
                        <div class="turn-summary-section-title"><span class="turn-summary-icon">⚔️</span> Ground Combat</div>
                        <div class="turn-summary-section-content">
                            @if (_turnReport?.InvasionResults != null)
                            {
                                @foreach (var result in _turnReport.InvasionResults)
                                {
                                    <div class="turn-summary-highlight">@result</div>
                                }
                            }
                            @if (_turnReport?.ArmiesRecruited != null)
                            {
                                @foreach (var recruited in _turnReport.ArmiesRecruited)
                                {
                                    <div>@recruited</div>
                                }
                            }
                        </div>
                    </div>
                }

                @* POPULATION *@
                @if (_turnReport.PopulationChange != 0)
                {
                    <div class="turn-summary-section">
                        <div class="turn-summary-section-title"><span class="turn-summary-icon">👥</span> Population</div>
                        <div class="ts-value @(_turnReport.PopulationChange > 0 ? "ts-positive" : "ts-negative")">
                            @(_turnReport.PopulationChange > 0 ? "+" : "")@_turnReport.PopulationChange pops
                        </div>
                    </div>
                }

                @* ESPIONAGE *@
                @if (_turnReport.EspionageResults.Any())
                {
                    <div class="turn-summary-section">
                        <div class="turn-summary-section-title"><span class="turn-summary-icon">🕵️</span> Espionage</div>
                        @foreach (var e in _turnReport.EspionageResults)
                        {
                            <div class="turn-summary-item">@e</div>
                        }
                    </div>
                }

                @* DIPLOMACY *@
                @if (_turnReport.DiplomacyChanges.Any())
                {
                    <div class="turn-summary-section">
                        <div class="turn-summary-section-title"><span class="turn-summary-icon">🌐</span> Diplomacy</div>
                        @foreach (var d in _turnReport.DiplomacyChanges)
                        {
                            <div class="turn-summary-item">@d</div>
                        }
                    </div>
                }

                @* EVENTS *@
                @if (_turnReport.NewEventsCount > 0)
                {
                    <div class="turn-summary-section turn-summary-clickable" @onclick="NavigateToEvents">
                        <div class="turn-summary-section-title"><span class="turn-summary-icon">📜</span> Events</div>
                        <div class="turn-summary-item">@_turnReport.NewEventsCount new event@(_turnReport.NewEventsCount > 1 ? "s" : "") pending</div>
                    </div>
                }

                @* CRISIS *@
                @if (_turnReport.CrisisUpdate != null)
                {
                    <div class="turn-summary-section turn-summary-crisis">
                        <div class="turn-summary-section-title"><span class="turn-summary-icon">⚠️</span> Crisis</div>
                        <div class="turn-summary-item">@_turnReport.CrisisUpdate</div>
                    </div>
                }
            </div>
            <div class="turn-summary-footer">
                <button class="st-btn st-btn-primary turn-summary-acknowledge" @onclick="DismissTurnSummary">ACKNOWLEDGE</button>
            </div>
        </div>
    </div>
}
</CascadingValue>
</CascadingValue>

<style>
    .stellaris-app {
        min-height: 100vh;
        background: var(--st-bg-darkest, #040608);
    }

    .admin-force-btn {
        padding: 6px 12px;
        background: linear-gradient(180deg, #cc6600 0%, #993300 100%);
        border: 1px solid #ff8800;
        border-radius: 4px;
        color: #fff;
        font-size: 11px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.15s;
        letter-spacing: 1px;
    }
    .admin-force-btn:hover {
        background: linear-gradient(180deg, #ff8800 0%, #cc6600 100%);
        box-shadow: 0 0 12px rgba(255, 136, 0, 0.4);
    }
    .admin-force-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    /* ── Notification Bell ─────────────────────────────────── */
    .st-notification-bell {
        position: relative;
        cursor: pointer;
        padding: 4px 8px;
        display: flex;
        align-items: center;
    }
    .st-bell-icon {
        font-size: 18px;
        filter: grayscale(0.3);
        transition: filter 0.15s;
    }
    .st-notification-bell:hover .st-bell-icon {
        filter: grayscale(0);
    }
    .st-bell-badge {
        position: absolute;
        top: -2px;
        right: 0;
        background: #ff4455;
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        min-width: 16px;
        height: 16px;
        line-height: 16px;
        text-align: center;
        border-radius: 8px;
        padding: 0 4px;
        pointer-events: none;
    }
    .st-notification-dropdown {
        position: absolute;
        top: 100%;
        right: 0;
        width: 360px;
        max-height: 480px;
        background: var(--st-bg-darker, #0a0e14);
        border: 1px solid var(--st-border, #1a2a3a);
        border-radius: 6px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.6);
        z-index: 1000;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .st-notification-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 14px;
        border-bottom: 1px solid var(--st-border, #1a2a3a);
        font-size: 13px;
        font-weight: 600;
        color: var(--st-text, #c8d6e5);
        letter-spacing: 0.5px;
    }
    .st-notification-mark-read {
        background: none;
        border: none;
        color: var(--st-accent, #4a9eff);
        font-size: 11px;
        cursor: pointer;
        padding: 2px 6px;
    }
    .st-notification-mark-read:hover {
        text-decoration: underline;
    }
    .st-notification-list {
        overflow-y: auto;
        flex: 1;
    }
    .st-notification-empty {
        padding: 24px;
        text-align: center;
        color: #556;
        font-size: 12px;
    }
    .st-notification-item {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 10px 14px;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        cursor: pointer;
        transition: background 0.1s;
    }
    .st-notification-item:hover {
        background: rgba(255,255,255,0.04);
    }
    .st-notification-item.unread {
        background: rgba(74, 158, 255, 0.06);
        border-left: 2px solid var(--st-accent, #4a9eff);
    }
    .st-notification-icon {
        font-size: 16px;
        flex-shrink: 0;
        margin-top: 2px;
    }
    .st-notification-content {
        flex: 1;
        min-width: 0;
    }
    .st-notification-title {
        font-size: 12px;
        font-weight: 600;
        color: var(--st-text, #c8d6e5);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .st-notification-message {
        font-size: 11px;
        color: #889;
        margin-top: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .st-notification-time {
        font-size: 10px;
        color: #556;
        flex-shrink: 0;
        margin-top: 2px;
    }
</style>

@code {
    private GameLayoutState _gameState = new();
    private MultiplayerState _mpState = new();
    private HubConnection? _hub;
    private bool _processingTurn;
    private TutorialOverlay? _tutorialOverlay;
    private bool _showNotifications;
    private bool _showTurnSummary;
    private TurnReportDto? _turnReport;
    private int _summaryTurn;

    protected override async Task OnInitializedAsync()
    {
        await ThemeService.InitializeAsync();
        await LoadGameState();
        Navigation.LocationChanged += OnLocationChanged;
        _gameState.OnLayoutChanged += OnLayoutChanged;
        HotSeatService.OnPlayerChanged += OnHotSeatPlayerChanged;
        NotificationSvc.OnNotificationsChanged += OnNotificationsChanged;
    }

    private void OnLayoutChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnHotSeatPlayerChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadGameState()
    {
        try
        {
            _gameState.FactionId = await LocalStorage.GetItemAsync<Guid?>("currentFactionId");
            _gameState.IsAdmin = await LocalStorage.GetItemAsync<bool>("isAdmin");

            var games = await Api.GetGamesAsync();
            var game = games.FirstOrDefault();
            if (game != null)
            {
                _gameState.GameId = game.Id;
                _gameState.CurrentTurn = game.Turn;
                _gameState.Stardate = $"{game.Turn / 10}.{game.Turn % 10:D2}";

                if (_gameState.FactionId.HasValue)
                {
                    var faction = await Api.GetMyFactionAsync(game.Id, _gameState.FactionId.Value);
                    if (faction != null)
                    {
                        _gameState.FactionName = faction.Name ?? "United Federation";
                        _gameState.RaceId = faction.RaceId?.ToLower() ?? "federation";
                        _gameState.GovernmentType = "Starfleet Command";

                        // Load resources from faction treasury
                        if (faction.Treasury != null)
                        {
                            _gameState.Energy = faction.Treasury.Credits;
                            _gameState.Minerals = faction.Treasury.Duranium;
                            _gameState.Food = faction.Treasury.Deuterium;
                            _gameState.Alloys = faction.Treasury.Dilithium;
                        }

                        // Do NOT auto-switch theme to faction - user's choice in Settings is respected
                        // await ThemeService.SetThemeForRaceAsync(_gameState.RaceId);
                    }
                }
            }

            // Load multiplayer state from localStorage
            var isMultiplayer = await LocalStorage.GetItemAsync<bool>("isMultiplayer");
            var gameModeStr = await LocalStorage.GetItemAsync<string>("gameMode");
            _mpState.IsMultiplayer = isMultiplayer;
            _mpState.Mode = Enum.TryParse<GameMode>(gameModeStr, out var gm) ? gm : GameMode.SinglePlayer;
            _mpState.CurrentPlayerId = _gameState.FactionId ?? Guid.Empty;
            _mpState.IsHost = await LocalStorage.GetItemAsync<bool>("isHost");

            if (_mpState.IsMultiplayer && _mpState.Mode != GameMode.HotSeat)
            {
                await InitializeHubConnection();
            }
        }
        catch
        {
            // Fallback to demo mode - keep defaults
        }
    }

    private async Task EndTurn()
    {
        if (_processingTurn) return;
        _processingTurn = true;
        StateHasChanged();
        try
        {
            if (_mpState.IsMultiplayer && _mpState.Mode == GameMode.TurnBased && _hub?.State == HubConnectionState.Connected)
            {
                // Multiplayer turn-based: signal ready via SignalR
                await _hub.InvokeAsync("SetReady", _gameState.GameId, true);
                Snackbar.Add("Ready! Waiting for other players...", Severity.Info);
            }
            else if (_mpState.Mode == GameMode.HotSeat)
            {
                // Hot-Seat: process turn via normal API, then trigger player switch
                if (_gameState.FactionId.HasValue && _gameState.GameId.HasValue)
                {
                    await Api.EndTurnAsync(_gameState.GameId.Value, _gameState.FactionId.Value);
                }
                HotSeatService.EndTurn();
                Snackbar.Add("Turn ended. Pass to next player!", Severity.Info);
            }
            else if (_gameState.FactionId.HasValue && _gameState.GameId.HasValue)
            {
                await Api.EndTurnAsync(_gameState.GameId.Value, _gameState.FactionId.Value);
                Snackbar.Add("Orders submitted!", Severity.Success);
            }
            else
            {
                Snackbar.Add("Orders submitted (demo mode)", Severity.Info);
            }
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _processingTurn = false; StateHasChanged(); }
    }

    private async Task ForceProcessTurn()
    {
        if (_processingTurn || !_gameState.GameId.HasValue) return;
        _processingTurn = true;
        StateHasChanged();
        try
        {
            var result = await Api.ProcessTurnAsync(_gameState.GameId.Value);
            _gameState.CurrentTurn = result.NewTurn;
            _gameState.Stardate = $"{result.NewTurn / 10}.{result.NewTurn % 10:D2}";
            Snackbar.Add($"Turn processed! Now turn {result.NewTurn}.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Force turn error: {ex.Message}", Severity.Error); }
        finally { _processingTurn = false; StateHasChanged(); }
    }

