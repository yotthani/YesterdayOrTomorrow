    /// <summary>
    /// Called after turn processing to persist key items as notifications.
    /// Task 10's OnTurnProcessed can call this with the parsed TurnReportDto.
    /// </summary>
    private void FeedTurnNotifications(TurnReportDto report, int turn)
    {
        if (report.TechCompleted != null)
            NotificationSvc.AddNotification("Research Complete", $"Turn {turn}: {report.TechCompleted}", NotificationType.Research, "/game/research");

        foreach (var combat in report.Combats)
        {
            var outcome = combat.AttackerVictory ? "Victory" : "Defeat";
            NotificationSvc.AddNotification($"Combat: {outcome}", $"Turn {turn}: {combat.SystemName} — {combat.AttackerName} vs {combat.DefenderName}", NotificationType.Combat, "/game/combat");
        }

        if (report.BuildingsCompleted.Any() || report.ShipsCompleted.Any())
            NotificationSvc.AddNotification("Construction Complete", $"Turn {turn}: {report.BuildingsCompleted.Count + report.ShipsCompleted.Count} item(s) finished", NotificationType.Colony);

        if (report.StationsCompleted.Any())
            NotificationSvc.AddNotification("Station Complete", $"Turn {turn}: {string.Join(", ", report.StationsCompleted)}", NotificationType.Info, "/game/stations");

        if (report.NewEventsCount > 0)
            NotificationSvc.AddNotification("New Events", $"Turn {turn}: {report.NewEventsCount} event(s) pending", NotificationType.Warning, "/game/events");

        if (report.CrisisUpdate != null)
            NotificationSvc.AddNotification("Crisis Update", $"Turn {turn}: {report.CrisisUpdate}", NotificationType.Error, "/game/crisis");

        // Ground combat
        if (report.InvasionResults != null)
        {
            foreach (var invasion in report.InvasionResults)
            {
                NotificationSvc.AddNotification("Ground Combat", invasion, NotificationType.Combat);
            }
        }
    }

