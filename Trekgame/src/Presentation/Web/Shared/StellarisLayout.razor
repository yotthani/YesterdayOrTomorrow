    private void OnTickUpdate(JsonElement data)
    {
        if (data.TryGetProperty("Tick", out var tickEl))
        {
            _mpState.CurrentTick = tickEl.GetInt64();
        }
        _mpState.NotifyStateChanged();
        InvokeAsync(StateHasChanged);
    }

    private void OnModeChanged(JsonElement data)
    {
        if (data.TryGetProperty("Mode", out var modeEl))
        {
            var modeStr = modeEl.GetString() ?? "";
            _mpState.Mode = Enum.TryParse<GameMode>(modeStr, true, out var mode) ? mode : _mpState.Mode;
        }
        _mpState.NotifyStateChanged();
        InvokeAsync(StateHasChanged);
    }

