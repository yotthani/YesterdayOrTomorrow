    public async ValueTask DisposeAsync()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        _gameState.OnLayoutChanged -= OnLayoutChanged;
        HotSeatService.OnPlayerChanged -= OnHotSeatPlayerChanged;
        NotificationSvc.OnNotificationsChanged -= OnNotificationsChanged;

        if (_hub != null)
        {
            try { await _hub.DisposeAsync(); }
            catch { }
        }
    }

    private async Task InitializeHubConnection()
    {
        try
        {
            var baseUri = Navigation.BaseUri.TrimEnd('/');
            _hub = new HubConnectionBuilder()
                .WithUrl($"{baseUri}/hubs/game?gameId={_gameState.GameId}&factionId={_gameState.FactionId}")
                .WithAutomaticReconnect()
                .Build();

            // Register event handlers
            _hub.On<JsonElement>("PlayerJoined", OnPlayerJoined);
            _hub.On<JsonElement>("PlayerLeft", OnPlayerLeft);
            _hub.On<JsonElement>("PlayerReadyChanged", OnPlayerReadyChanged);
            _hub.On<JsonElement>("TurnProcessed", OnTurnProcessed);
            _hub.On("TurnProcessingStarted", () => InvokeAsync(StateHasChanged));
            _hub.On<JsonElement>("ChatMessage", OnChatMessage);
            _hub.On<JsonElement>("SpeedChanged", OnSpeedChanged);
            _hub.On<JsonElement>("GamePaused", OnGamePaused);
            _hub.On("GameResumed", OnGameResumed);
            _hub.On<JsonElement>("TickUpdate", OnTickUpdate);
            _hub.On<JsonElement>("ModeChanged", OnModeChanged);
            _hub.On<JsonElement>("RealtimeOrderExecuted", OnRealtimeOrderExecuted);

            _hub.Reconnecting += _ => { Snackbar.Add("Reconnecting...", Severity.Warning); return Task.CompletedTask; };
            _hub.Reconnected += _ => { Snackbar.Add("Reconnected!", Severity.Success); return Task.CompletedTask; };

            await _hub.StartAsync();

            var playerName = _gameState.FactionName ?? "Player";
            await _hub.InvokeAsync("JoinGame", _gameState.GameId, _mpState.CurrentPlayerId, playerName);
        }
        catch (Exception ex)
        {
            // Hub connection optional — game works without it in single-player
            Console.WriteLine($"Hub connection failed: {ex.Message}");
        }
    }

    private void OnPlayerJoined(JsonElement data)
    {
        var playerId = data.GetProperty("PlayerId").GetGuid();
        var playerName = data.GetProperty("PlayerName").GetString() ?? "";
        if (!_mpState.Players.Any(p => p.PlayerId == playerId))
        {
            _mpState.Players.Add(new PlayerInfo { PlayerId = playerId, Name = playerName, IsConnected = true });
        }
        _mpState.NotifyStateChanged();
        InvokeAsync(StateHasChanged);
    }

    private void OnPlayerLeft(JsonElement data)
    {
        var playerId = data.GetProperty("PlayerId").GetGuid();
        _mpState.Players.RemoveAll(p => p.PlayerId == playerId);
        _mpState.ReadyPlayers.Remove(playerId);
        _mpState.NotifyStateChanged();
        InvokeAsync(StateHasChanged);
    }

    private void OnPlayerReadyChanged(JsonElement data)
    {
        var playerId = data.GetProperty("PlayerId").GetGuid();
        var isReady = data.GetProperty("IsReady").GetBoolean();
        if (isReady) _mpState.ReadyPlayers.Add(playerId);
        else _mpState.ReadyPlayers.Remove(playerId);

        var player = _mpState.Players.FirstOrDefault(p => p.PlayerId == playerId);
        if (player != null) player.IsReady = isReady;
        _mpState.NotifyStateChanged();
        InvokeAsync(StateHasChanged);
    }

    private void OnTurnProcessed(JsonElement data)
    {
        if (data.TryGetProperty("NewTurn", out var newTurnEl))
        {
            _gameState.CurrentTurn = newTurnEl.GetInt32();
            _gameState.Stardate = $"{_gameState.CurrentTurn / 10}.{_gameState.CurrentTurn % 10:D2}";
            _summaryTurn = _gameState.CurrentTurn;
        }
        _mpState.ReadyPlayers.Clear();
        foreach (var p in _mpState.Players) p.IsReady = false;
        _mpState.NotifyStateChanged();

        // Parse turn report if present (faction-specific payload)
        if (data.TryGetProperty("Report", out var reportEl))
        {
            try
            {
                _turnReport = System.Text.Json.JsonSerializer.Deserialize<TurnReportDto>(reportEl.GetRawText(),
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                _showTurnSummary = true;
                if (_turnReport != null)
                {
                    FeedTurnNotifications(_turnReport, _summaryTurn);

                    // Update topbar resources from post-turn treasury
                    if (_turnReport.Treasury != null)
                    {
                        _gameState.Energy = _turnReport.Treasury.TreasuryCredits;
                        _gameState.Minerals = _turnReport.Treasury.TreasuryDuranium;
                        _gameState.Food = _turnReport.Treasury.TreasuryDeuterium;
                        _gameState.Alloys = _turnReport.Treasury.TreasuryDilithium;
                    }
                    _gameState.Research = _turnReport.ResearchProgress;
                    _gameState.EnergyIncome = _turnReport.CreditsIncome - _turnReport.CreditsExpenses;
                }
            }
            catch { /* fallback: no modal */ }
        }

        if (!_showTurnSummary)
            Snackbar.Add("Turn processed!", Severity.Success);

        InvokeAsync(StateHasChanged);
    }

    private void DismissTurnSummary()
    {
        _showTurnSummary = false;
        _turnReport = null;
        InvokeAsync(StateHasChanged);
    }

    private void NavigateToEvents()
    {
        DismissTurnSummary();
        Navigation.NavigateTo("/game/events");
    }

    private void OnChatMessage(JsonElement data)
    {
        var msg = new ChatMessageDto
        {
            SenderId = data.GetProperty("SenderId").GetGuid(),
            SenderName = data.GetProperty("SenderName").GetString() ?? "",
            Message = data.GetProperty("Message").GetString() ?? "",
            Channel = data.TryGetProperty("Channel", out var ch) ? ch.ToString() : "Global",
            Timestamp = DateTime.UtcNow
        };
        _mpState.ChatMessages.Add(msg);
        _mpState.UnreadChatCount++;
        _mpState.NotifyStateChanged();
        InvokeAsync(StateHasChanged);
    }

    private void OnSpeedChanged(JsonElement data)
    {
        if (data.TryGetProperty("Speed", out var speedEl))
        {
            _mpState.GameSpeed = speedEl.GetInt32();
        }
        _mpState.NotifyStateChanged();
        InvokeAsync(StateHasChanged);
    }

    private void OnGamePaused(JsonElement data)
    {
        _mpState.IsPaused = true;
        var by = data.TryGetProperty("RequestedBy", out var byEl) ? byEl.GetString() : "someone";
        Snackbar.Add($"Game paused by {by}", Severity.Info);
        _mpState.NotifyStateChanged();
        InvokeAsync(StateHasChanged);
    }

    private void OnGameResumed()
    {
        _mpState.IsPaused = false;
        _mpState.NotifyStateChanged();
