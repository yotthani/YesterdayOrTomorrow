@inherits LayoutComponentBase
@using StarTrekGame.Web.Components.UI
@using Microsoft.JSInterop
@using Blazored.LocalStorage
@using StarTrekGame.Web.Services
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ThemeService ThemeService
@inject ILocalStorageService LocalStorage

<div class="starfield-background"></div>

<div class="layout-container">
    <header class="game-header">
        <FederationButton OnClick="ToggleDrawer" Variant="outline" Style="width: 48px; height: 48px; font-size: 24px;" Class="d-lg-none">☰</FederationButton>
        
        <div class="header-logo" @onclick="@(() => Navigation.NavigateTo("/"))">
            GALACTIC STRATEGY
        </div>

        @if (_isInGame)
        {
            <nav class="header-nav">
                <a href="/game/map" class="header-nav-item @(IsActive("/game/map") ? "active" : "")">Map</a>
                <a href="/game/fleets" class="header-nav-item @(IsActive("/game/fleets") ? "active" : "")">Fleets</a>
                <a href="/game/colonies" class="header-nav-item @(IsActive("/game/colonies") ? "active" : "")">Colonies</a>
                <a href="/game/research" class="header-nav-item @(IsActive("/game/research") ? "active" : "")">Research</a>
                <a href="/game/diplomacy" class="header-nav-item @(IsActive("/game/diplomacy") ? "active" : "")">Diplomacy</a>
            </nav>
        }

        <div class="header-right-controls">
            <FederationButton OnClick="@(() => Navigation.NavigateTo("/game/settings"))" Variant="outline" Style="width: 48px; height: 48px; font-size: 24px;">⚙</FederationButton>
        </div>
    </header>

    <div class="nav-drawer-backdrop @(_drawerOpen && !_isLgOrWider ? "active" : "")" @onclick="ToggleDrawer"></div>
    <div class="nav-drawer @(_drawerOpen || _isLgOrWider ? "open" : "")">
        <FederationPanel Title="Navigation" HeaderColor="primary" AccentColor="accent" Rounded="tr,br" Padding="0" Style="flex-grow: 1;">
            <div class="nav-menu">
                <a href="/" class="nav-item @(IsActive("/", true) ? "active" : "")">
                    <span class="nav-icon">⌂</span> Main Menu
                </a>
                
                @if (_isInGame)
                {
                    <div class="nav-section-header">IN GAME</div>
                    <a href="/game/overview" class="nav-item @(IsActive("/game/overview") ? "active" : "")"><span class="nav-icon">📊</span> Overview</a>
                    <a href="/game/map" class="nav-item @(IsActive("/game/map") ? "active" : "")"><span class="nav-icon">🗺️</span> Galaxy Map</a>
                    <a href="/game/fleets" class="nav-item @(IsActive("/game/fleets") ? "active" : "")"><span class="nav-icon">🚀</span> Fleets</a>
                    <a href="/game/colonies" class="nav-item @(IsActive("/game/colonies") ? "active" : "")"><span class="nav-icon">🌍</span> Colonies</a>
                    <a href="/game/research" class="nav-item @(IsActive("/game/research") ? "active" : "")"><span class="nav-icon">🔬</span> Research</a>
                    <a href="/game/diplomacy" class="nav-item @(IsActive("/game/diplomacy") ? "active" : "")"><span class="nav-icon">🤝</span> Diplomacy</a>

                    <div class="nav-section-header">TOOLS</div>
                    <a href="/game/ship-designer" class="nav-item @(IsActive("/game/ship-designer") ? "active" : "")"><span class="nav-icon">🛠️</span> Ship Designer</a>
                    <a href="/game/save-load" class="nav-item @(IsActive("/game/save-load") ? "active" : "")"><span class="nav-icon">💾</span> Save/Load</a>
                    
                    <div class="nav-divider"></div>
                    
                    <a @onclick="LeaveGame" class="nav-item danger"><span class="nav-icon">🚪</span> Leave Game</a>
                }
                else
                {
                    <div class="nav-section-header">START PLAYING</div>
                    <a href="/game/new" class="nav-item @(IsActive("/game/new") ? "active" : "")"><span class="nav-icon">✨</span> New Game</a>
                    <a href="/" class="nav-item @(IsActive("/") ? "active" : "")"><span class="nav-icon">🧑‍🤝‍🧑</span> Join Game</a>
                }
                
                <div class="nav-section-header">OPTIONS</div>
                <a href="/game/tutorial" class="nav-item @(IsActive("/game/tutorial") ? "active" : "")"><span class="nav-icon">❓</span> Tutorial</a>
                <a href="/game/settings" class="nav-item @(IsActive("/game/settings") ? "active" : "")"><span class="nav-icon">⚙</span> Settings</a>
            </div>
        </FederationPanel>
    </div>

    <main class="main-content">
        <div class="main-content-inner">
             @Body
        </div>
    </main>
</div>

@if (_showDisclaimer)
{
    <StarTrekGame.Web.Components.Shared.DisclaimerBanner OnDismiss="DismissDisclaimer" />
}

<style>
    .d-lg-none {
        display: none;
    }
    .starfield-background {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: black url('https://www.transparenttextures.com/patterns/stardust.png');
        z-index: -1;
    }

    .layout-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
    }

    .game-header {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 0 16px;
    }
    
    .header-right-controls {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .main-content {
        flex-grow: 1;
        overflow: auto;
        padding-top: var(--header-height);
        transition: padding-left var(--transition-normal);
    }
    
    .main-content-inner {
        padding: 1rem;
    }

    .nav-drawer {
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        width: 280px;
        z-index: 1100;
        transform: translateX(-100%);
        transition: transform var(--transition-normal);
        display: flex;
        flex-direction: column;
    }
    
    .nav-drawer.open {
        transform: translateX(0);
    }
    
    .nav-drawer-backdrop {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 1050;
        opacity: 0;
        pointer-events: none;
        transition: opacity var(--transition-normal);
    }
    
    .nav-drawer-backdrop.active {
        opacity: 1;
        pointer-events: auto;
    }
    
    .nav-menu {
        padding: 16px 0;
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow-y: auto;
    }
    
    .nav-item {
        display: flex;
        align-items: center;
        padding: 10px 24px;
        color: var(--federation-text-dim);
        text-decoration: none;
        transition: background var(--transition-fast), color var(--transition-fast);
        gap: 16px;
    }
    
    .nav-item:hover {
        background: var(--federation-primary-dark);
        color: var(--federation-text);
    }
    
    .nav-item.active {
        background: var(--federation-primary);
        color: var(--federation-text);
        font-weight: bold;
    }
    
    .nav-item.danger {
        color: var(--federation-danger);
    }
    .nav-item.danger:hover {
        background: var(--federation-danger);
        color: white;
    }
    
    .nav-icon {
        font-size: 1.2em;
        width: 24px;
        text-align: center;
    }

    .nav-section-header {
        font-family: var(--font-display);
        color: var(--federation-accent);
        padding: 24px 24px 8px 24px;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.8rem;
    }
    
    .nav-divider {
        height: 1px;
        background: var(--federation-border);
        margin: 8px 24px;
    }

    /* Responsive */
    @@media (max-width: 959.95px) {
        .header-nav {
            display: none;
        }
    }
    @@media (min-width: 960px) {
        .d-lg-none {
            display: none !important;
        }
        .main-content {
            padding-left: 280px;
        }
    }
</style>

<script suppress-error="BL9992">
    // The existing JS scripts remain here
</script>

@code {
    private bool _drawerOpen = false;
    private bool _showDisclaimer = true;
    private bool _isInGame = false;
    private bool _isLgOrWider = false;

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += async (s, e) => await OnLocationChanged();
        await ThemeService.InitializeAsync();
        await CheckGameState();
        _showDisclaimer = !await LocalStorage.GetItemAsync<bool>("disclaimer-dismissed");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isLgOrWider = await JS.InvokeAsync<bool>("checkBreakpoint", 960);
            StateHasChanged();
        }
    }

    private async Task CheckGameState()
    {
        _isInGame = await LocalStorage.GetItemAsync<Guid?>("currentFactionId") != null && await LocalStorage.GetItemAsync<Guid?>("currentGameId") != null;
    }
    
    private async Task OnLocationChanged()
    {
        await CheckGameState();
        if (_drawerOpen && !_isLgOrWider)
        {
            _drawerOpen = false;
        }
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    
    private async Task SetTheme(string themeId)
    {
        await ThemeService.SetThemeAsync(themeId);
    }
    
    private async Task LeaveGame()
    {
        await LocalStorage.RemoveItemAsync("currentFactionId");
        await LocalStorage.RemoveItemAsync("currentGameId");
        await LocalStorage.RemoveItemAsync("currentPlayerName");
        _isInGame = false;
        Navigation.NavigateTo("/");
    }
    
    private async Task DismissDisclaimer()
    {
        _showDisclaimer = false;
        await LocalStorage.SetItemAsync("disclaimer-dismissed", true);
    }

    private bool IsActive(string href, bool exact = false)
    {
        var relativePath = "/" + Navigation.ToBaseRelativePath(Navigation.Uri);
        if (exact)
        {
            return relativePath == href;
        }
        return relativePath.StartsWith(href);
    }
}
