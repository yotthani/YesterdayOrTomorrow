@page "/game/theme-showcase"
@layout StellarisLayout
@using MudBlazor

<PageTitle>Theme Showcase - Real SVG Assets</PageTitle>

<div class="showcase-page">
    <h1>🎨 FACTION UI SHOWCASE - MIT ECHTEN SVG ASSETS</h1>
    <p class="subtitle">Jede Fraktion nutzt die detaillierten SVG-Frames aus /assets/ui/themes/</p>

    @* ============================================
       LCARS / FEDERATION
       ============================================ *@
    <section class="faction-section">
        <h2 class="faction-title lcars">FEDERATION / LCARS - panel-frame-detailed.svg</h2>
        <div class="lcars-demo">
            <div class="lcars-frame">
                <div class="lcars-content">
                    <div class="lcars-header">SYSTEM INFORMATION</div>
                    <div class="lcars-body">
                        <p><strong>System:</strong> Sol System</p>
                        <p><strong>Classification:</strong> Class M - Terran</p>
                        <p><strong>Population:</strong> 8.2 Billion</p>
                        <p><strong>Status:</strong> Federation Homeworld</p>
                        <div class="lcars-buttons">
                            <button class="lcars-btn orange">SCAN</button>
                            <button class="lcars-btn violet">COLONIZE</button>
                            <button class="lcars-btn blue">DETAILS</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="lcars-sidebar-demo">
                <div class="lcars-sidebar-item active">🌌 Galaxy Map</div>
                <div class="lcars-sidebar-item">👥 Contacts</div>
                <div class="lcars-sidebar-item">🔬 Research</div>
                <div class="lcars-sidebar-item">⚔️ Fleets</div>
                <div class="lcars-sidebar-item">📊 Empire</div>
            </div>
        </div>
    </section>

    @* ============================================
       KLINGON
       ============================================ *@
    <section class="faction-section">
        <h2 class="faction-title klingon">KLINGON EMPIRE - panel-frame-detailed.svg</h2>
        <div class="klingon-demo">
            <div class="klingon-frame">
                <div class="klingon-content">
                    <div class="klingon-header">⚔️ BATTLE STATUS ⚔️</div>
                    <div class="klingon-body">
                        <p><strong>System:</strong> Qo'noS - Homeworld</p>
                        <p><strong>Warriors Ready:</strong> 50,000</p>
                        <p><strong>Fleet Status:</strong> MAXIMUM ALERT</p>
                        <p><strong>Honor Level:</strong> GLORIOUS</p>
                        <div class="klingon-buttons">
                            <button class="klingon-btn">ATTACK!</button>
                            <button class="klingon-btn">CONQUEST</button>
                            <button class="klingon-btn">GLORY</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="klingon-sidebar-demo">
                <div class="klingon-sidebar-item active">🌌 EMPIRE</div>
                <div class="klingon-sidebar-item">⚔️ WARRIORS</div>
                <div class="klingon-sidebar-item">🛡️ HONOR</div>
                <div class="klingon-sidebar-item">💀 ENEMIES</div>
            </div>
        </div>
    </section>

    @* ============================================
       ROMULAN
       ============================================ *@
    <section class="faction-section">
        <h2 class="faction-title romulan">ROMULAN STAR EMPIRE - panel-frame-detailed.svg</h2>
        <div class="romulan-demo">
            <div class="romulan-frame">
                <div class="romulan-content">
                    <div class="romulan-header">🦅 INTELLIGENCE REPORT 🦅</div>
                    <div class="romulan-body">
                        <p><strong>System:</strong> Romulus - Capital</p>
                        <p><strong>Cloaked Ships:</strong> 127 Active</p>
                        <p><strong>Senate Approval:</strong> 78%</p>
                        <p><strong>Tal Shiar Status:</strong> OPERATIONAL</p>
                        <div class="romulan-buttons">
                            <button class="romulan-btn">INFILTRATE</button>
                            <button class="romulan-btn">OBSERVE</button>
                            <button class="romulan-btn">SCHEME</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="romulan-sidebar-demo">
                <div class="romulan-sidebar-item active">🌌 Empire</div>
                <div class="romulan-sidebar-item">👁️ Intelligence</div>
                <div class="romulan-sidebar-item">🔮 Senate</div>
                <div class="romulan-sidebar-item">⚔️ Tal Shiar</div>
            </div>
        </div>
    </section>

    @* ============================================
       PNG NEBULA + CSS FRAME HYBRID
       ============================================ *@
    <section class="faction-section">
        <h2 class="faction-title hybrid">🌌 HYBRID: PNG Nebula + CSS Frames (WOW Version)</h2>
        <p class="hybrid-desc">Kombination aus echten PNG-Nebula-Hintergründen mit CSS-basierten UI-Elementen</p>

        <div class="hybrid-grid">
            @* KLINGON - Red Nebula *@
            <div class="hybrid-panel klingon-hybrid">
                <div class="nebula-bg klingon-nebula"></div>
                <div class="css-frame klingon-css-frame">
                    <div class="frame-top"></div>
                    <div class="frame-left">
                        <div class="sidebar-btn active"></div>
                        <div class="sidebar-btn"></div>
                        <div class="sidebar-btn"></div>
                        <div class="emblem">⚔️</div>
                        <div class="sidebar-btn"></div>
                    </div>
                    <div class="frame-bottom"></div>
                    <div class="frame-right"></div>
                    <div class="corner-spike tl"></div>
                    <div class="corner-spike tr"></div>
                    <div class="corner-spike bl"></div>
                    <div class="corner-spike br"></div>
                </div>
                <div class="hybrid-content">
                    <h3>KLINGON EMPIRE</h3>
                    <p>Qo'noS System • Warriors: 50,000</p>
                    <div class="hybrid-btns">
                        <button class="h-btn klingon">ATTACK</button>
                        <button class="h-btn klingon">GLORY</button>
                    </div>
                </div>
            </div>

            @* ROMULAN - Green Nebula *@
            <div class="hybrid-panel romulan-hybrid">
                <div class="nebula-bg romulan-nebula"></div>
                <div class="css-frame romulan-css-frame">
                    <div class="frame-top"></div>
                    <div class="frame-left">
                        <div class="sidebar-btn active"></div>
                        <div class="sidebar-btn"></div>
                        <div class="sidebar-btn"></div>
                        <div class="emblem">🦅</div>
                        <div class="sidebar-btn"></div>
                    </div>
                    <div class="frame-bottom"></div>
                    <div class="frame-right"></div>
                    <div class="corner-wing tl"></div>
                    <div class="corner-wing tr"></div>
                    <div class="corner-wing bl"></div>
                    <div class="corner-wing br"></div>
                </div>
                <div class="hybrid-content">
                    <h3>ROMULAN STAR EMPIRE</h3>
                    <p>Romulus • Cloaked Ships: 127</p>
                    <div class="hybrid-btns">
                        <button class="h-btn romulan">INFILTRATE</button>
                        <button class="h-btn romulan">SCHEME</button>
                    </div>
                </div>
            </div>

            @* FEDERATION - Blue/Purple Nebula *@
            <div class="hybrid-panel federation-hybrid">
                <div class="nebula-bg federation-nebula"></div>
                <div class="css-frame federation-css-frame">
                    <div class="lcars-top-bar">
                        <div class="lcars-cap"></div>
                        <div class="lcars-seg orange"></div>
                        <div class="lcars-seg tan"></div>
                        <div class="lcars-seg violet"></div>
                        <div class="lcars-seg blue"></div>
                    </div>
                    <div class="lcars-sidebar">
                        <div class="lcars-sidebar-seg pink"></div>
                        <div class="lcars-sidebar-seg blue"></div>
                        <div class="lcars-sidebar-seg orange"></div>
                        <div class="lcars-sidebar-seg violet"></div>
                        <div class="lcars-sidebar-seg tan"></div>
                    </div>
                    <div class="lcars-bottom-bar">
                        <div class="lcars-seg violet"></div>
                        <div class="lcars-seg pink"></div>
                    </div>
                </div>
                <div class="hybrid-content lcars-content-pos">
                    <h3>UNITED FEDERATION</h3>
                    <p>Sol System • Pop: 8.2 Billion</p>
                    <div class="hybrid-btns">
                        <button class="h-btn federation">SCAN</button>
                        <button class="h-btn federation violet">HAIL</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* ============================================
       SIDE-BY-SIDE COMPARISON
       ============================================ *@
    <section class="faction-section">
        <h2 class="faction-title comparison">SIDE-BY-SIDE: SVG vs HYBRID</h2>
        <div class="comparison-grid">
            <div class="mini-lcars">
                <div class="mini-frame lcars-bg">
                    <span class="label">SVG</span>
                </div>
            </div>
            <div class="mini-klingon">
                <div class="mini-frame klingon-bg">
                    <span class="label">SVG</span>
                </div>
            </div>
            <div class="mini-romulan">
                <div class="mini-frame romulan-bg">
                    <span class="label">SVG</span>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
/* =============================================
   PAGE LAYOUT
   ============================================= */
.showcase-page {
    padding: 24px;
    background: linear-gradient(180deg, #0a0a12 0%, #050508 100%);
    min-height: 100vh;
}

.showcase-page h1 {
    color: #fff;
    font-size: 28px;
    margin-bottom: 8px;
    text-align: center;
}

.showcase-page .subtitle {
    color: #888;
    margin-bottom: 40px;
    text-align: center;
}

.faction-section {
    margin-bottom: 60px;
}

.faction-title {
    font-size: 18px;
    padding: 12px 20px;
    margin-bottom: 20px;
    border-radius: 4px;
    font-weight: 700;
}

.faction-title.lcars {
    background: linear-gradient(90deg, #ff9900 0%, #cc6600 50%, transparent 100%);
    color: #000;
}
.faction-title.klingon {
    background: linear-gradient(90deg, #cc0000 0%, #660000 50%, transparent 100%);
    color: #fff;
}
.faction-title.romulan {
    background: linear-gradient(90deg, #00aa44 0%, #006622 50%, transparent 100%);
    color: #fff;
}
.faction-title.comparison {
    background: linear-gradient(90deg, #4a9eff 0%, #2a4e88 50%, transparent 100%);
    color: #fff;
}

/* =============================================
   LCARS / FEDERATION STYLES
   Using: /assets/ui/themes/lcars/panel-frame-detailed.svg
   ============================================= */
.lcars-demo {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
}

.lcars-frame {
    flex: 1;
    min-width: 700px;
    min-height: 450px;
    background-image: url('/assets/ui/themes/lcars/panel-frame-detailed.svg');
    background-size: 100% 100%;
    background-repeat: no-repeat;
    position: relative;
}

.lcars-content {
    position: absolute;
    top: 12%;
    left: 15%;
    right: 3%;
    bottom: 12%;
    padding: 20px;
}

.lcars-header {
    color: #ff9900;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 2px;
    margin-bottom: 12px;
    text-shadow: 0 0 10px rgba(255, 153, 0, 0.5);
}

.lcars-body {
    color: #aaddff;
    font-size: 12px;
    line-height: 1.6;
}

.lcars-body p {
    margin: 4px 0;
}

.lcars-buttons {
    display: flex;
    gap: 8px;
    margin-top: 16px;
    flex-wrap: wrap;
}

.lcars-btn {
    padding: 6px 16px;
    border: none;
    border-radius: 12px;
    font-weight: 600;
    font-size: 11px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.lcars-btn.orange {
    background: linear-gradient(180deg, #ff9900 0%, #cc6600 100%);
    color: #000;
}

.lcars-btn.violet {
    background: linear-gradient(180deg, #cc99ff 0%, #8855bb 100%);
    color: #000;
}

.lcars-btn.blue {
    background: linear-gradient(180deg, #99ccff 0%, #5588cc 100%);
    color: #000;
}

.lcars-sidebar-demo {
    width: 200px;
    background: linear-gradient(180deg, #cc9966 0%, #996633 100%);
    border-radius: 0 20px 20px 0;
    overflow: hidden;
}

.lcars-sidebar-item {
    padding: 16px 20px;
    background: #000;
    margin: 2px;
    color: #ff9900;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s;
}

.lcars-sidebar-item:first-child {
    border-radius: 0 18px 0 0;
}

.lcars-sidebar-item:last-child {
    border-radius: 0 0 18px 0;
}

.lcars-sidebar-item.active {
    background: #1a1a30;
    color: #ffcc00;
}

.lcars-sidebar-item:hover:not(.active) {
    background: #0a0a20;
}

/* =============================================
   KLINGON STYLES
   Using: /assets/ui/themes/klingon/panel-frame-detailed.svg
   ============================================= */
.klingon-demo {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
}

.klingon-frame {
    flex: 1;
    min-width: 700px;
    min-height: 500px;
    background-image: url('/assets/ui/themes/klingon/panel-frame-detailed.svg');
    background-size: 100% 100%;
    background-repeat: no-repeat;
    position: relative;
}

.klingon-content {
    position: absolute;
    top: 18%;
    left: 18%;
    right: 8%;
    bottom: 18%;
    padding: 20px;
}

.klingon-header {
    color: #ff4444;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 4px;
    margin-bottom: 20px;
    text-shadow: 0 0 15px rgba(255, 50, 50, 0.8);
    text-align: center;
}

.klingon-body {
    color: #ff8888;
    font-size: 14px;
    line-height: 1.8;
}

.klingon-body p {
    margin: 8px 0;
}

.klingon-buttons {
    display: flex;
    gap: 12px;
    margin-top: 24px;
}

.klingon-btn {
    padding: 10px 24px;
    background: linear-gradient(180deg, #cc0000 0%, #660000 100%);
    border: 2px solid #ff4444;
    color: #fff;
    font-weight: 700;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 2px;
    clip-path: polygon(10px 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
    transition: all 0.2s;
}

.klingon-btn:hover {
    background: linear-gradient(180deg, #ff4444 0%, #cc0000 100%);
    box-shadow: 0 0 20px rgba(255, 50, 50, 0.5);
}

.klingon-sidebar-demo {
    width: 180px;
    background: linear-gradient(180deg, #2a0a0a 0%, #0a0000 100%);
    border: 2px solid #660000;
}

.klingon-sidebar-item {
    padding: 16px 20px;
    color: #cc6666;
    cursor: pointer;
    font-weight: 700;
    border-left: 4px solid transparent;
    transition: all 0.2s;
}

.klingon-sidebar-item.active {
    background: linear-gradient(90deg, rgba(204, 0, 0, 0.4), transparent);
    color: #ff4444;
    border-left-color: #cc0000;
}

.klingon-sidebar-item:hover:not(.active) {
    background: rgba(204, 0, 0, 0.1);
    color: #ff6666;
}

/* =============================================
   ROMULAN STYLES
   Using: /assets/ui/themes/romulan/panel-frame-detailed.svg
   ============================================= */
.romulan-demo {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
}

.romulan-frame {
    flex: 1;
    min-width: 500px;
    min-height: 400px;
    background-image: url('/assets/ui/themes/romulan/panel-frame-detailed.svg');
    background-size: 100% 100%;
    background-repeat: no-repeat;
    position: relative;
}

.romulan-content {
    position: absolute;
    top: 100px;
    left: 120px;
    right: 50px;
    bottom: 80px;
    padding: 16px;
}

.romulan-header {
    color: #44ff88;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 3px;
    margin-bottom: 20px;
    text-shadow: 0 0 15px rgba(0, 255, 170, 0.6);
    text-align: center;
}

.romulan-body {
    color: #88ccaa;
    font-size: 14px;
    line-height: 1.8;
}

.romulan-body p {
    margin: 8px 0;
}

.romulan-buttons {
    display: flex;
    gap: 12px;
    margin-top: 24px;
}

.romulan-btn {
    padding: 10px 24px;
    background: linear-gradient(180deg, #00aa44 0%, #006622 100%);
    border: 1px solid #44ff88;
    border-radius: 4px;
    color: #fff;
    font-weight: 600;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.2s;
}

.romulan-btn:hover {
    background: linear-gradient(180deg, #00cc55 0%, #00aa44 100%);
    box-shadow: 0 0 20px rgba(0, 255, 170, 0.4);
}

.romulan-sidebar-demo {
    width: 180px;
    background: linear-gradient(180deg, #0a1a10 0%, #000a04 100%);
    border: 1px solid rgba(0, 170, 68, 0.4);
    border-radius: 8px;
}

.romulan-sidebar-item {
    padding: 16px 20px;
    color: #66aa88;
    cursor: pointer;
    font-weight: 600;
    border-left: 3px solid transparent;
    transition: all 0.2s;
}

.romulan-sidebar-item.active {
    background: linear-gradient(90deg, rgba(0, 170, 68, 0.3), transparent);
    color: #44ff88;
    border-left-color: #00aa44;
}

.romulan-sidebar-item:hover:not(.active) {
    background: rgba(0, 170, 68, 0.1);
    color: #88ffaa;
}

/* =============================================
   SIDE-BY-SIDE COMPARISON
   ============================================= */
.comparison-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}

.mini-frame {
    height: 300px;
    background-size: 100% 100%;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
}

.mini-frame .label {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 20px;
    background: rgba(0,0,0,0.8);
    color: #fff;
    font-weight: 700;
    letter-spacing: 2px;
    border-radius: 4px;
}

.lcars-bg {
    background-image: url('/assets/ui/themes/lcars/panel-frame-detailed.svg');
}

.klingon-bg {
    background-image: url('/assets/ui/themes/klingon/panel-frame-detailed.svg');
}

.romulan-bg {
    background-image: url('/assets/ui/themes/romulan/panel-frame-detailed.svg');
}

/* =============================================
   HYBRID PNG + CSS SECTION
   ============================================= */
.faction-title.hybrid {
    background: linear-gradient(90deg, #ff6600 0%, #cc00ff 50%, transparent 100%);
    color: #fff;
}

.hybrid-desc {
    color: #aaa;
    margin-bottom: 24px;
    font-style: italic;
}

.hybrid-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}

.hybrid-panel {
    position: relative;
    height: 450px;
    border-radius: 8px;
    overflow: hidden;
}

/* PNG Nebula Backgrounds */
.nebula-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-size: cover;
    background-position: center;
    z-index: 1;
}

.klingon-nebula {
    background:
        radial-gradient(ellipse at 30% 20%, rgba(255,50,0,0.4) 0%, transparent 50%),
        radial-gradient(ellipse at 70% 80%, rgba(255,100,0,0.3) 0%, transparent 40%),
        radial-gradient(ellipse at 50% 50%, rgba(100,0,0,0.6) 0%, transparent 70%),
        linear-gradient(180deg, #1a0505 0%, #0a0000 100%);
}

.romulan-nebula {
    background:
        radial-gradient(ellipse at 20% 30%, rgba(0,255,100,0.3) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 70%, rgba(0,200,150,0.25) 0%, transparent 40%),
        radial-gradient(ellipse at 50% 50%, rgba(0,80,50,0.5) 0%, transparent 70%),
        linear-gradient(180deg, #051510 0%, #000a04 100%);
}

.federation-nebula {
    background:
        radial-gradient(ellipse at 25% 25%, rgba(255,153,0,0.3) 0%, transparent 40%),
        radial-gradient(ellipse at 75% 75%, rgba(150,100,255,0.25) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 50%, rgba(50,50,100,0.4) 0%, transparent 60%),
        linear-gradient(180deg, #0a0a1a 0%, #050510 100%);
}

/* CSS Frame Overlays */
.css-frame {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    pointer-events: none;
}

/* KLINGON CSS Frame */
.klingon-css-frame .frame-top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 70px;
    background: linear-gradient(180deg, #4a4a4a 0%, #1a1a1a 50%, #3a3a3a 100%);
    clip-path: polygon(0 0, 100% 0, 100% 100%, 85% 100%, 82% 80%, 65% 80%, 62% 100%, 38% 100%, 35% 80%, 18% 80%, 15% 100%, 0 100%);
    box-shadow: inset 0 2px 0 rgba(255,255,255,0.1), inset 0 -2px 0 rgba(0,0,0,0.3);
}

.klingon-css-frame .frame-top::after {
    content: '';
    position: absolute;
    top: 8px;
    left: 15%;
    right: 15%;
    height: 8px;
    background: linear-gradient(180deg, #ff4444 0%, #880000 50%, #ff3333 100%);
    box-shadow: 0 0 20px rgba(255,50,50,0.8), 0 0 40px rgba(255,50,50,0.4);
}

.klingon-css-frame .frame-left {
    position: absolute;
    top: 70px;
    left: 0;
    width: 100px;
    bottom: 70px;
    background: linear-gradient(90deg, #4a4a4a 0%, #1a1a1a 80%);
    display: flex;
    flex-direction: column;
    padding: 15px 10px;
    gap: 10px;
}

.klingon-css-frame .sidebar-btn {
    height: 40px;
    background: linear-gradient(90deg, #2a2a2a, #1a1a1a);
    border-left: 4px solid #440000;
    transition: all 0.2s;
}

.klingon-css-frame .sidebar-btn.active {
    background: linear-gradient(90deg, rgba(150,0,0,0.4), transparent);
    border-left-color: #ff4444;
    box-shadow: inset 0 0 20px rgba(255,50,50,0.3);
}

.klingon-css-frame .emblem {
    width: 80px;
    height: 80px;
    margin: 10px auto;
    background: linear-gradient(135deg, #3a3a3a, #1a1a1a);
    border: 3px solid #880000;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    box-shadow: 0 0 20px rgba(255,50,50,0.5), inset 0 0 20px rgba(0,0,0,0.5);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
}

.klingon-css-frame .frame-bottom {
