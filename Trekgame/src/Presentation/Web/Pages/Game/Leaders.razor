    private int GetXpPercent(LeaderDto leader) =>
        leader.Level >= 10 ? 100 : Math.Min(100, leader.ExperiencePoints % 100);

    private string GetClassStyle(string classId) => classId?.ToLower() switch
    {
        "admiral" or "fleet_commander" => "admiral",
        "governor" or "administrator" => "governor",
        "scientist" or "researcher" => "scientist",
        "general" or "ground_commander" => "general",
        "diplomat" or "ambassador" => "diplomat",
        "spymaster" or "agent_handler" => "spymaster",
        _ => ""
    };

    // Helper types for assignment modal
    public class FleetInfo { public Guid Id { get; set; } public string Name { get; set; } = ""; public int ShipCount { get; set; } }
    public class ColonyInfo { public Guid Id { get; set; } public string Name { get; set; } = ""; public int Population { get; set; } }
