    private async Task ShowSkillPanel()
    {
        if (_selectedLeader == null) return;
        try { _availableSkills = await Api.GetAvailableSkillsAsync(_selectedLeader.Id); }
        catch { _availableSkills = []; }
        _showSkillPanel = true;
    }

