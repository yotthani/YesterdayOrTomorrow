@page "/game/assets"
@page "/game/showcase"
@using StarTrekGame.Web.Components.UI

<PageTitle>UI Showcase - Galactic Strategy</PageTitle>

<div class="showcase-container">
    <FederationPanel Title="UI & Asset Showcase" AccentColor="accent" Padding="1rem">
        <div class="tabs">
            <FederationButton OnClick="() => _activeTab = "components"" Variant="@(_activeTab == "components" ? "primary" : "outline")">UI Components</FederationButton>
            <FederationButton OnClick="() => _activeTab = "assets"" Variant="@(_activeTab == "assets" ? "primary" : "outline")">Game Assets</FederationButton>
        </div>

        @if (_activeTab == "components")
        {
            <div class="component-section">
                <FederationPanel Title="Buttons" HeaderColor="secondary" Class="showcase-item">
                    <div class="button-showcase">
                        <FederationButton OnClick="() => PlaySound('click')">Primary</FederationButton>
                        <FederationButton OnClick="() => PlaySound('click')" Variant="secondary">Secondary</FederationButton>
                        <FederationButton OnClick="() => PlaySound('success')" Variant="success">Success</FederationButton>
                        <FederationButton OnClick="() => PlaySound('error')" Variant="danger">Danger</FederationButton>
                        <FederationButton OnClick="() => PlaySound('click')" Variant="outline">Outline</FederationButton>
                        <FederationButton OnClick="() => PlaySound('select')" Variant="pill">Pill</FederationButton>
                        <FederationButton Disabled="true">Disabled</FederationButton>
                        <FederationButton GlowPulse="true" OnClick="() => PlaySound('notification')">Glow Pulse</FederationButton>
                    </div>
                    <div class="button-showcase">
                        <FederationButton Size="small" OnClick="() => PlaySound('click')">Small</FederationButton>
                        <FederationButton Size="medium" OnClick="() => PlaySound('click')">Medium</FederationButton>
                        <FederationButton Size="large" OnClick="() => PlaySound('click')">Large</FederationButton>
                    </div>
                </FederationPanel>
                
                <FederationPanel Title="Data Cards" HeaderColor="secondary" Class="showcase-item">
                    <div class="card-showcase">
                        <FederationDataCard Label="Population" Value="7.8B" Icon="🧑‍🤝‍🧑" />
                        <FederationDataCard Label="Approval" Value="88%" Icon="👍" Color="success" />
                        <FederationDataCard Label="Energy" Value="-500" Icon="⚡" Color="danger" />
                        <FederationDataCard Label="Research" Value="+1200" Icon="🔬" Color="primary" />
                        <FederationDataCard Label="Trade Value" Value="1.2M" Icon="💰" Color="accent" Compact="true" />
                    </div>
                </FederationPanel>

                <FederationPanel Title="Modals & Panels" HeaderColor="secondary" Class="showcase-item">
                    <FederationButton OnClick="() => _showModal = true">Show Modal</FederationButton>
                     <p class="mt-2">This showcases a modal dialog built with a FederationPanel.</p>
                </FederationPanel>
                
            </div>
        }
        else
        {
            <div class="asset-tab-content">
                 @foreach (var faction in _factionAssets.Where(f => f.Value.Any()))
                {
                    <FederationPanel Title="@GetFactionDisplayName(faction.Key)" Class="mb-4" HeaderColor="secondary">
                        <div class="faction-section @faction.Key.ToLower()">
                             @foreach (var category in faction.Value)
                            {
                                <div class="category-section">
                                    <h5>@GetCategoryDisplayName(category.Category) <span class="asset-count">(@category.TotalAssets)</span></h5>
                                    <div class="assets-grid">
                                        @for (int i = 0; i < category.TotalAssets; i++)
                                        {
                                            var row = i / category.Columns;
                                            var col = i % category.Columns;
                                            var assetName = GetAssetName(category.Names, i);
                                            <div class="asset-card">
                                                <div class="asset-sprite" style="@GetAssetStyle(faction.Key, category, row, col)"></div>
                                                <div class="asset-name">@assetName</div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </FederationPanel>
                }
                 <FederationPanel Title="Universal Assets" Class="mb-4" HeaderColor="secondary">
                    @foreach (var category in _universalAssets)
                    {
                        <div class="category-section">
                            <h5>@GetCategoryDisplayName(category.Category) <span class="asset-count">(@category.TotalAssets)</span></h5>
                            <div class="assets-grid">
                                @for (int i = 0; i < category.TotalAssets; i++)
                                {
                                    var row = i / category.Columns;
                                    var col = i % category.Columns;
                                    var assetName = GetAssetName(category.Names, i);
                                    <div class="asset-card">
                                        <div class="asset-sprite" style="@GetUniversalAssetStyle(category, row, col)"></div>
                                        <div class="asset-name">@assetName</div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </FederationPanel>
            </div>
        }
    </FederationPanel>
</div>

@if (_showModal)
{
    <div class="modal-backdrop" @onclick="() => _showModal = false">
        <div @onclick:stopPropagation="true">
            <FederationPanel Title="Example Modal" Class="modal-dialog">
                <p>This is a modal dialog. You can put any content you want here, including other components.</p>
                <FederationDataCard Label="Status" Value="Nominal" Icon="✅" Color="success" />
                 <div class="dialog-actions">
                    <FederationButton OnClick="() => _showModal = false" Variant="secondary">Cancel</FederationButton>
                    <FederationButton OnClick="() => { _showModal = false; PlaySound('success'); }" Variant="primary">Confirm</FederationButton>
                </div>
            </FederationPanel>
        </div>
    </div>
}

<style>
    .showcase-container {
        padding: 1rem;
        max-width: 1800px;
        margin: auto;
    }
    .tabs {
        display: flex;
        gap: 1rem;
        margin-bottom: 1rem;
        padding: 0 0.5rem;
    }
    .component-section {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    .showcase-item {
        padding: 1.5rem;
    }
    .button-showcase, .card-showcase {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: center;
    }
    .modal-dialog {
        width: 500px;
        max-width: 90vw;
    }
    .dialog-actions {
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--federation-border);
    }
    .mt-2 { margin-top: 0.5rem; }
    .mb-4 { margin-bottom: 1rem; }
    .asset-tab-content { padding-top: 1rem; }

    /* Asset Grid Styles */
    .category-section h5 {
        font-size: 1rem;
        color: var(--federation-accent-light);
        margin: 1rem 0 0.5rem 0;
        border-bottom: 1px solid var(--federation-border);
        padding-bottom: 0.5rem;
    }
    .asset-count {
        font-size: 0.8rem;
        color: var(--federation-text-dim);
        font-weight: normal;
    }
    .assets-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 12px;
    }
    .asset-card {
        background: var(--federation-bg-medium);
        border: 1px solid var(--federation-border);
        border-radius: 8px;
        padding: 8px;
        text-align: center;
    }
    .asset-sprite {
        width: 100px;
        height: 100px;
        margin: 0 auto 6px;
        background-repeat: no-repeat;
        border-radius: 4px;
        background-color: var(--federation-bg-dark);
    }
    .asset-name {
        font-size: 10px;
        color: var(--federation-text-dim);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

@code {
    private string _activeTab = "components";
    private bool _showModal = false;

    // Method to play sound
    private async Task PlaySound(string soundType)
    {
        // JS interop logic to play sound
    }

    // --- Existing Asset Showcase Code ---
    private record AssetCategory(string Category, string SpritePath, int Columns, int Rows, int CellSize, string[]? Names = null)
    {
        public int TotalAssets => Columns * Rows;
    }
    
    private Dictionary<string, List<AssetCategory>> _factionAssets = new();
    private List<AssetCategory> _universalAssets = new();
    
    protected override void OnInitialized()
    {
        // Federation
        _factionAssets["Federation"] = new List<AssetCategory>
        {
            new("Military Ships", "/assets/factions/federation/federation_militaryships_spritesheet.png", 6, 6, 360, GetFederationMilitaryShipNames()),
            new("Civilian Ships", "/assets/factions/federation/federation_civilianships_spritesheet.png", 6, 6, 360, GetFederationCivilianShipNames()),
        };
        
        // Klingon
        _factionAssets["Klingon"] = new List<AssetCategory>
        {
            new("Military Ships", "/assets/factions/klingon/klingon_militaryships_spritesheet.png", 6, 6, 360, GetKlingonMilitaryShipNames()),
        };

        _universalAssets = new List<AssetCategory>
        {
            new("Planets", "/assets/universal/planets_spritesheet.png", 6, 6, 360),
            new("Stars", "/assets/universal/stars_spritesheet.png", 4, 4, 360),
        };
    }
    
    private string GetAssetStyle(string faction, AssetCategory category, int row, int col)
    {
        var displaySize = 100;
        var scale = (double)displaySize / category.CellSize;
        var bgWidth = category.Columns * category.CellSize * scale;
        var bgHeight = category.Rows * category.CellSize * scale;
        var x = -col * category.CellSize * scale;
        var y = -row * category.CellSize * scale;
        
        return $"background-image: url('{category.SpritePath}'); background-position: {x}px {y}px; background-size: {bgWidth}px {bgHeight}px;";
    }
    
    private string GetUniversalAssetStyle(AssetCategory category, int row, int col)
    {
        var displaySize = 100;
        var scale = (double)displaySize / category.CellSize;
        var bgWidth = category.Columns * category.CellSize * scale;
        var bgHeight = category.Rows * category.CellSize * scale;
        var x = -col * category.CellSize * scale;
        var y = -row * category.CellSize * scale;
        
        return $"background-image: url('{category.SpritePath}'); background-position: {x}px {y}px; background-size: {bgWidth}px {bgHeight}px;";
    }
    
    private string GetAssetName(string[]? names, int index)
    {
        if (names != null && index < names.Length)
            return names[index];
        return $"Asset {index + 1}";
    }
    
    private string GetFactionDisplayName(string faction) => faction;
    private string GetCategoryDisplayName(string category) => category;

    // Ship name arrays
    private string[] GetFederationMilitaryShipNames() => new[] { "Constitution", "Galaxy", "Sovereign", "Defiant" };
    private string[] GetFederationCivilianShipNames() => new[] { "Shuttle", "Freighter", "Colony Ship" };
    private string[] GetKlingonMilitaryShipNames() => new[] { "B'rel Bird of Prey", "K'vort Bird of Prey", "Vor'cha Cruiser" };
}
