@code {
    [Parameter] public Guid ColonyId { get; set; }
    [CascadingParameter(Name = "GameState")] public StellarisLayout.GameLayoutState? GameState { get; set; }

    private List<ArmyDto> _garrison = [];
    private List<ArmyDto> _embarkedArmies = [];
    private List<ArmyDto> _stationedArmies = [];
    private GroundCombatResultDto? _invasionResult;
    private string _bombardmentLevel = "standard";
    private bool _isInvading;
    private bool _isLoading = true;
    private string? _colonyName;
    private Guid? _fleetId;
    private string? _errorMessage;
    private Guid? _factionId;
    private string _selectedArmyType = "";
    private bool _isRecruiting;

    protected override async Task OnInitializedAsync()
    {
        GameState?.SetTopbarOverride("⚔", "GROUND COMBAT", "",
            cssClass: "combat-header", showResources: true, showEndTurn: false);

        try
        {
            await LoadData();
        }
        catch
        {
            LoadMockData();
        }

        if (GameState != null)
            GameState.SetTopbarOverride("⚔", "GROUND COMBAT", _colonyName ?? "",
                cssClass: "combat-header", showResources: true, showEndTurn: false);

        _isLoading = false;
    }

    public void Dispose()
    {
        GameState?.ResetTopbar();
    }

    private async Task LoadData()
    {
        _factionId = GameState?.FactionId;
        if (!_factionId.HasValue)
        {
            _factionId = await LocalStorage.GetItemAsync<Guid?>("currentFactionId");
        }

        if (!_factionId.HasValue)
        {
            LoadMockData();
            return;
        }

        // Load colony info
        var colony = await Api.GetColonyAsync(ColonyId);
        _colonyName = colony?.Name ?? "Unknown Colony";

        // Load garrison
        _garrison = await Api.GetGarrisonAsync(ColonyId);

        // Load active invasion if any
        _invasionResult = await Api.GetActiveInvasionAsync(ColonyId);

        // Load faction armies to find stationed ones at this colony
        var allArmies = await Api.GetFactionArmiesAsync(_factionId.Value);
        _stationedArmies = allArmies.Where(a => a.ColonyId == ColonyId && a.FleetId == null).ToList();

        // Load fleets to find one in the same system
        var fleets = await Api.GetFleetsAsync(_factionId.Value);
        if (colony != null)
        {
            // Find first fleet in same system that has the colony
            var fleetInSystem = fleets.FirstOrDefault(f => f.CurrentSystemId == GetSystemIdFromColony(colony));
            if (fleetInSystem != null)
            {
                _fleetId = fleetInSystem.Id;
                _embarkedArmies = await Api.GetEmbarkedArmiesAsync(fleetInSystem.Id);
            }
        }
    }

    private Guid GetSystemIdFromColony(ColonyDetailDto colony) => colony.SystemId;

    private void LoadMockData()
    {
        _colonyName = "Cardassia Prime";
        _factionId = Guid.NewGuid();
        var fid = _factionId.Value;
        var enemyFid = Guid.NewGuid();
        _fleetId = Guid.NewGuid();

        _embarkedArmies = new()
        {
            new(Guid.NewGuid(), fid, "1st MACO Division", "MACO Team", 25, 15, 100, 100, 90, "Veteran", "Ready", null, _fleetId, false, 0, 2),
            new(Guid.NewGuid(), fid, "3rd Assault Brigade", "Assault Division", 20, 12, 80, 80, 85, "Regular", "Ready", null, _fleetId, false, 0, 1),
            new(Guid.NewGuid(), fid, "7th Infantry Regiment", "Infantry", 12, 10, 100, 100, 70, "Green", "Ready", null, _fleetId, false, 0, 1),
        };

        _garrison = new()
        {
            new(Guid.NewGuid(), enemyFid, "Cardassian Guard", "Heavy Weapons", 18, 22, 90, 90, 95, "Elite", "Defending", ColonyId, null, false, 0, 2),
            new(Guid.NewGuid(), enemyFid, "Obsidian Order Ops", "Elite Guard", 22, 18, 70, 70, 80, "Veteran", "Defending", ColonyId, null, false, 0, 3),
            new(Guid.NewGuid(), enemyFid, "Militia Detachment", "Infantry", 8, 8, 60, 60, 50, "Green", "Defending", ColonyId, null, false, 0, 1),
        };

        _stationedArmies = new()
        {
            new(Guid.NewGuid(), fid, "2nd Reserve Battalion", "Infantry", 12, 10, 100, 100, 75, "Regular", "Stationed", ColonyId, null, false, 0, 1),
        };
    }

    private bool CanLaunchInvasion() => _fleetId.HasValue && _embarkedArmies.Any() && !_isInvading && _invasionResult == null;

    private async Task LaunchInvasion()
    {
        if (!CanLaunchInvasion()) return;
        _isInvading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            _invasionResult = await Api.InvadeColonyAsync(_fleetId!.Value, ColonyId, _bombardmentLevel);
            Snackbar.Add("Invasion resolved!", _invasionResult.WinnerFactionId == _factionId ? Severity.Success : Severity.Warning);

            // Reload armies after battle
            _garrison = await Api.GetGarrisonAsync(ColonyId);
            if (_factionId.HasValue)
            {
                var allArmies = await Api.GetFactionArmiesAsync(_factionId.Value);
                _stationedArmies = allArmies.Where(a => a.ColonyId == ColonyId && a.FleetId == null).ToList();
            }
            if (_fleetId.HasValue)
            {
                _embarkedArmies = await Api.GetEmbarkedArmiesAsync(_fleetId.Value);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Invasion failed: {ex.Message}";
            Snackbar.Add(_errorMessage, Severity.Error);
        }
        finally
        {
            _isInvading = false;
        }
    }

    private async Task RecruitArmy()
    {
        if (string.IsNullOrEmpty(_selectedArmyType)) return;
        _isRecruiting = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var newArmy = await Api.RecruitArmyAsync(ColonyId, _selectedArmyType);
            _stationedArmies.Add(newArmy);
            Snackbar.Add($"Recruiting {newArmy.Name}...", Severity.Success);
            _selectedArmyType = "";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Recruitment failed: {ex.Message}";
            Snackbar.Add(_errorMessage, Severity.Error);
        }
        finally
        {
            _isRecruiting = false;
        }
    }

    private async Task EmbarkArmy(Guid armyId)
    {
        if (!_fleetId.HasValue) return;
        try
        {
            await Api.EmbarkArmyAsync(armyId, _fleetId.Value);
            var army = _stationedArmies.FirstOrDefault(a => a.Id == armyId);
            if (army != null)
            {
                _stationedArmies.Remove(army);
                _embarkedArmies.Add(army);
            }
            Snackbar.Add("Army embarked", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Embark failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task DisembarkArmy(Guid armyId)
    {
        try
        {
            await Api.DisembarkArmyAsync(armyId, ColonyId);
            var army = _embarkedArmies.FirstOrDefault(a => a.Id == armyId);
            if (army != null)
            {
                _embarkedArmies.Remove(army);
                _stationedArmies.Add(army);
            }
            Snackbar.Add("Army disembarked", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Disembark failed: {ex.Message}", Severity.Error);
        }
    }

    private void DismissResult()
    {
        _invasionResult = null;
    }

    private string GetInvasionStatusClass()
    {
        if (_invasionResult != null && _invasionResult.IsResolved) return "resolved";
        if (_invasionResult != null) return "active";
        return "idle";
    }

    private string GetInvasionStatusText()
    {
        if (_invasionResult != null && _invasionResult.IsResolved) return "RESOLVED";
        if (_invasionResult != null) return "ACTIVE INVASION";
        return "NO INVASION";
    }
}
