.nebula-effect{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,rgba(100,50,150,0.1) 0%,transparent 50%)}
.combat-log{position:absolute;top:16px;left:50%;transform:translateX(-50%);width:400px;background:rgba(10,15,25,0.9);border:1px solid var(--st-border-dark);border-radius:8px;z-index:10}
.log-header{padding:8px 12px;background:rgba(0,0,0,0.3);font-size:10px;color:var(--st-text-dim);letter-spacing:1px;border-bottom:1px solid var(--st-border-dark)}
.log-content{padding:8px;max-height:150px;overflow-y:auto}
.log-entry{padding:4px 8px;font-size:11px;margin-bottom:2px;border-radius:3px}
.log-entry.damage{background:rgba(255,68,68,0.1);color:var(--st-accent-red)}.log-entry.hit{color:var(--st-text-muted)}.log-entry.destroy{background:rgba(255,170,68,0.1);color:var(--st-accent-orange)}.log-entry.info{color:var(--st-text-dim)}
.log-time{color:var(--st-text-dim);margin-right:8px}
.combat-visualization{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:80%;height:200px;display:flex;align-items:center;justify-content:space-between}
.fleet-vis{display:flex;flex-direction:column;gap:12px}
.ship-sprite{width:50px;height:50px;position:relative}
.ship-sprite.friendly{background:var(--st-accent-blue);clip-path:polygon(100% 50%,0% 0%,0% 100%)}.ship-sprite.enemy{background:var(--st-accent-red);clip-path:polygon(0% 50%,100% 0%,100% 100%)}
.weapon-fire{position:absolute;right:-30px;top:50%;width:30px;height:2px;background:linear-gradient(90deg,var(--st-accent-blue),transparent);opacity:0;transition:opacity 0.1s}.weapon-fire.active{opacity:1;animation:fire 0.2s}
.combat-controls{position:absolute;bottom:20px;left:50%;transform:translateX(-50%);display:flex;gap:12px;z-index:10}
.tactical-btn{background:linear-gradient(135deg,rgba(100,60,200,0.3),rgba(60,100,200,0.3))!important;border-color:rgba(140,100,255,0.5)!important;color:#c4b5fd!important;text-decoration:none;display:flex;align-items:center;gap:6px}
.tactical-btn:hover{background:linear-gradient(135deg,rgba(100,60,200,0.5),rgba(60,100,200,0.5))!important;border-color:rgba(140,100,255,0.8)!important}
.combat-result{position:fixed;inset:0;background:rgba(0,0,0,0.9);display:flex;align-items:center;justify-content:center;z-index:100}
.result-content{text-align:center;padding:40px;background:var(--st-gradient-panel);border:1px solid var(--st-border-bright);border-radius:12px}
.combat-result.victory .result-content{border-color:var(--st-accent-green);box-shadow:0 0 40px rgba(68,221,102,0.3)}
.combat-result.defeat .result-content{border-color:var(--st-accent-red);box-shadow:0 0 40px rgba(255,68,68,0.3)}
.result-content h2{font-family:var(--st-font-display);font-size:36px;letter-spacing:4px;margin:0 0 24px}
.victory h2{color:var(--st-accent-green)}.defeat h2{color:var(--st-accent-red)}
.result-stats{display:flex;gap:32px;margin-bottom:32px}.result-stats .stat{text-align:center}.stat .label{display:block;font-size:11px;color:var(--st-text-dim);margin-bottom:4px}.stat .value{font-family:var(--st-font-display);font-size:24px;color:var(--st-text-bright)}
@@keyframes blink{0%,100%{opacity:1}50%{opacity:0.3}}
@@keyframes fire{0%{width:0}100%{width:100px}}
</style>
@inject NavigationManager Nav
@inject IGameApiClient Api
@inject ILocalStorageService LocalStorage
@inject ISnackbar Snackbar
@code{
    [Parameter] public Guid? CombatId { get; set; }
    [CascadingParameter(Name = "GameState")] public StellarisLayout.GameLayoutState? GameState { get; set; }

    // Combat state
    Guid _combatId;
    Guid _factionId;
    bool _isAttacker;
    bool _isApiLoaded;

    // UI state
    List<ShipState> _playerShips = new();
    List<ShipState> _enemyShips = new();
    List<LogEntry> _combatLog = new();
    int _playerPower = 0;
    int _enemyPower = 0;
    int _playerMorale = 100;
    int _round = 0;
    string _currentPhase = "setup";
    bool _combatEnded;
    bool _playerWon;
    string _autoResolveTimer = "0:30";
    string _playerFactionName = "YOUR FLEET";
    string _enemyFactionName = "ENEMY FLEET";
    string _systemName = "Unknown System";

    protected override async Task OnInitializedAsync()
    {
        // Override topbar for combat mode
        GameState?.SetTopbarOverride("⚠", "COMBAT ENGAGEMENT", _systemName,
            cssClass: "combat-header", showResources: true, showEndTurn: false);

        try
        {
            await LoadFromApi();
        }
        catch
        {
            LoadMockData();
        }

        // Update topbar subtitle with actual system name after loading
        if (GameState != null)
            GameState.SetTopbarOverride("⚠", "COMBAT ENGAGEMENT", _systemName,
                cssClass: "combat-header", showResources: true, showEndTurn: false);
    }

    public void Dispose()
    {
        GameState?.ResetTopbar();
    }

    async Task LoadFromApi()
    {
        CombatStateDto? combat = null;

        // Try loading by CombatId parameter first
        if (CombatId.HasValue)
        {
            combat = await Api.GetCombatByIdAsync(CombatId.Value);
        }

        if (combat == null)
        {
            LoadMockData();
            return;
        }

        _combatId = combat.CombatId;
        _systemName = combat.SystemName;
        _round = combat.Round;

        // Determine which side the player is on
        var factionIdStr = await LocalStorage.GetItemAsStringAsync("currentFactionId");
        if (Guid.TryParse(factionIdStr?.Trim('"'), out var fid))
            _factionId = fid;

        _isAttacker = _factionId == combat.AttackerId;
        _playerFactionName = _isAttacker ? combat.AttackerName : combat.DefenderName;
        _enemyFactionName = _isAttacker ? combat.DefenderName : combat.AttackerName;

        var playerShipDtos = _isAttacker ? combat.AttackerShips : combat.DefenderShips;
        var enemyShipDtos = _isAttacker ? combat.DefenderShips : combat.AttackerShips;

        _playerShips = playerShipDtos.Select(s => new ShipState
        {
            ShipId = s.ShipId,
            Name = s.Name,
            Class = s.ShipClass,
            Health = s.MaxHealth > 0 ? (int)(s.Health * 100.0 / s.MaxHealth) : 100,
            Shields = s.MaxShields > 0 ? (int)(s.Shields * 100.0 / s.MaxShields) : 0,
            IsDestroyed = s.IsDestroyed
        }).ToList();

        _enemyShips = enemyShipDtos.Select(s => new ShipState
        {
            ShipId = s.ShipId,
            Name = s.Name,
            Class = s.ShipClass,
            Health = s.MaxHealth > 0 ? (int)(s.Health * 100.0 / s.MaxHealth) : 100,
            Shields = s.MaxShields > 0 ? (int)(s.Shields * 100.0 / s.MaxShields) : 0,
            IsDestroyed = s.IsDestroyed
        }).ToList();

        _playerPower = playerShipDtos.Where(s => !s.IsDestroyed).Sum(s => s.WeaponPower);
        _enemyPower = enemyShipDtos.Where(s => !s.IsDestroyed).Sum(s => s.WeaponPower);

        if (combat.IsResolved)
        {
            _combatEnded = true;
            _playerWon = combat.WinnerId == _factionId;
            _currentPhase = "resolved";
        }

        _isApiLoaded = true;
        _combatLog.Add(new() { Turn = 0, Type = "info", Message = $"Combat engagement at {_systemName}" });
    }

    void LoadMockData()
    {
        _playerShips = new()
        {
            new() { Name = "USS Enterprise", Class = "Cruiser", Health = 100 },
            new() { Name = "USS Defiant", Class = "Frigate", Health = 100 },
            new() { Name = "USS Voyager", Class = "Cruiser", Health = 100 },
            new() { Name = "USS Reliant", Class = "Frigate", Health = 100 }
        };
        _enemyShips = new()
        {
            new() { Name = "IKS Rotarran", Class = "Cruiser", Health = 100 },
            new() { Name = "IKS Negh'Var", Class = "Battleship", Health = 100 },
            new() { Name = "IKS Pagh", Class = "Frigate", Health = 100 }
        };
        _playerPower = 2400;
        _enemyPower = 2100;
        _playerFactionName = "FEDERATION FLEET";
        _enemyFactionName = "KLINGON FLEET";
        _systemName = "Sol System • Sector 001";
        _combatLog.Add(new() { Turn = 0, Type = "info", Message = "Combat engagement initiated" });
    }

    async Task NextPhase()
    {
        if (_currentPhase == "setup")
        {
            _currentPhase = "combat";
            _combatLog.Add(new() { Turn = 1, Type = "info", Message = "Combat phase begins" });
            return;
        }

        if (_isApiLoaded)
        {
            try
            {
                var result = await Api.ExecuteCombatRoundAsync(_combatId);
                if (result != null)
                {
                    _round = result.Round;
                    UpdateShipsFromDto(result.AttackerShips, result.DefenderShips);
                    foreach (var msg in result.RoundLog)
                    {
                        var type = msg.Contains("destroyed") ? "destroy"
                                 : msg.Contains("dmg") || msg.Contains("hits") ? "damage"
                                 : "info";
                        _combatLog.Add(new() { Turn = _round, Type = type, Message = msg });
                    }
                    if (result.CombatEnded)
                    {
                        _combatEnded = true;
                        _playerWon = result.WinnerId == _factionId;
                    }
                    RecalcPower();
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Combat round error: {ex.Message}", Severity.Error);
                _round++;
                SimulateCombatRoundLocal();
                CheckCombatEnd();
            }
        }
        else
        {
            _round++;
            SimulateCombatRoundLocal();
            CheckCombatEnd();
        }
    }

    async Task AutoResolve()
    {
        if (_isApiLoaded)
        {
            try
            {
                var result = await Api.AutoResolveCombatAsync(_combatId);
                if (result != null)
                {
                    _combatEnded = true;
                    _playerWon = result.WinnerId == _factionId;
                    _round = result.Rounds;
                    foreach (var msg in result.BattleLog)
                    {
                        var type = msg.Contains("destroyed") ? "destroy"
                                 : msg.StartsWith("---") ? "info"
                                 : "damage";
                        _combatLog.Add(new() { Turn = _round, Type = type, Message = msg });
                    }
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Auto-resolve error: {ex.Message}", Severity.Error);
                while (!_combatEnded) { _round++; SimulateCombatRoundLocal(); CheckCombatEnd(); }
            }
        }
        else
        {
            while (!_combatEnded) { _round++; SimulateCombatRoundLocal(); CheckCombatEnd(); }
        }
    }

    async Task Retreat()
    {
        if (_isApiLoaded)
        {
            try { await Api.RetreatFromCombatAsync(_combatId, _factionId); }
            catch { /* retreat errors non-critical */ }
        }
        _combatEnded = true;
        _playerWon = false;
        _combatLog.Add(new() { Turn = _round, Type = "info", Message = "Fleet retreating..." });
    }

    // ── API Response → UI Sync ─────────────────────────
    void UpdateShipsFromDto(List<CombatShipDto> attackerShips, List<CombatShipDto> defenderShips)
    {
        var playerDtos = _isAttacker ? attackerShips : defenderShips;
        var enemyDtos = _isAttacker ? defenderShips : attackerShips;

        foreach (var dto in playerDtos)
        {
            var ship = _playerShips.FirstOrDefault(s => s.ShipId == dto.ShipId);
            if (ship != null)
            {
                ship.Health = dto.MaxHealth > 0 ? (int)(dto.Health * 100.0 / dto.MaxHealth) : 0;
                ship.Shields = dto.MaxShields > 0 ? (int)(dto.Shields * 100.0 / dto.MaxShields) : 0;
                ship.IsDestroyed = dto.IsDestroyed;
                if (dto.Health > 0 && !dto.IsDestroyed) ship.IsFiring = true;
            }
        }

        foreach (var dto in enemyDtos)
        {
            var ship = _enemyShips.FirstOrDefault(s => s.ShipId == dto.ShipId);
            if (ship != null)
            {
                ship.Health = dto.MaxHealth > 0 ? (int)(dto.Health * 100.0 / dto.MaxHealth) : 0;
                ship.Shields = dto.MaxShields > 0 ? (int)(dto.Shields * 100.0 / dto.MaxShields) : 0;
                ship.IsDestroyed = dto.IsDestroyed;
            }
        }
    }

    void RecalcPower()
    {
        _playerPower = _playerShips.Where(s => !s.IsDestroyed && s.Health > 0).Count() * 600;
        _enemyPower = _enemyShips.Where(s => !s.IsDestroyed && s.Health > 0).Count() * 700;
    }

    // ── Local Fallback Simulation ─────────────────────
    void SimulateCombatRoundLocal()
    {
        var rnd = new Random();
        foreach (var s in _playerShips.Where(s => s.Health > 0))
        {
            var target = _enemyShips.Where(e => e.Health > 0).OrderBy(_ => rnd.Next()).FirstOrDefault();
            if (target != null)
            {
                var dmg = rnd.Next(15, 35);
                target.Health = Math.Max(0, target.Health - dmg);
                s.IsFiring = true;
                _combatLog.Add(new() { Turn = _round, Type = "damage", Message = $"{s.Name} hits {target.Name} for {dmg} damage" });
                if (target.Health <= 0)
                    _combatLog.Add(new() { Turn = _round, Type = "destroy", Message = $"{target.Name} destroyed!" });
            }
        }
        foreach (var s in _enemyShips.Where(s => s.Health > 0))
        {
            var target = _playerShips.Where(e => e.Health > 0).OrderBy(_ => rnd.Next()).FirstOrDefault();
            if (target != null)
            {
                var dmg = rnd.Next(10, 30);
                target.Health = Math.Max(0, target.Health - dmg);
                _combatLog.Add(new() { Turn = _round, Type = "damage", Message = $"{s.Name} hits {target.Name} for {dmg} damage" });
                if (target.Health <= 0)
                    _combatLog.Add(new() { Turn = _round, Type = "destroy", Message = $"{target.Name} destroyed!" });
            }
        }
    }

    void CheckCombatEnd()
    {
        if (_enemyShips.All(s => s.Health <= 0)) { _combatEnded = true; _playerWon = true; }
        if (_playerShips.All(s => s.Health <= 0)) { _combatEnded = true; _playerWon = false; }
    }

    // ── Models ──────────────────────────────────────────
    class ShipState
    {
        public Guid ShipId;
        public string Name = "";
        public string Class = "";
        public int Health;
        public int Shields;
        public bool IsFiring;
        public bool IsTarget;
        public bool IsDestroyed;
    }

    class LogEntry { public int Turn; public string Type = ""; public string Message = ""; }
}
