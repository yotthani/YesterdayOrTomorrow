@page "/game/system-new/{SystemId:guid}"
@page "/game/system/{SystemId:guid}"
@page "/game/system-view/{SystemId:guid}"
@layout StellarisLayout
@using StarTrekGame.Web.Services
@inject IGameApiClient Api
@inject NavigationManager Nav
@inject AssetService AssetService

<PageTitle>System View - TrekGame</PageTitle>

<div class="stellaris-layout">
    <header class="st-topbar">
        <div class="st-empire-badge">
            <div class="st-empire-flag">🌐</div>
            <div class="st-empire-info">
                <span class="st-empire-name">@(_system?.Name ?? "Unknown") System</span>
                <span class="st-empire-type">Stellar Cartography</span>
            </div>
        </div>
        <div class="st-game-controls">
            <button class="st-btn" @onclick='() => Nav.NavigateTo("/game/galaxy")'>← BACK TO GALAXY</button>
        </div>
    </header>
    
    <div class="st-main">
        <aside class="st-sidebar-left">
            <nav class="st-nav">
                <a href="/game/galaxy" class="st-nav-btn"><span class="st-nav-icon">🌌</span><span class="st-nav-label">Galaxy</span></a>
                <a href="/game/colonies" class="st-nav-btn"><span class="st-nav-icon">🏠</span><span class="st-nav-label">Colonies</span></a>
            </nav>
        </aside>
        
        <div class="system-content">
            <div class="system-view">
                <!-- Star (using spritesheet asset) -->
                <div class="star-container" @onmouseenter="ShowStarTooltip" @onmouseleave="HideTooltip">
                    <div class="star-sprite" style="@GetStarSpriteStyle()">
                        <div class="star-corona"></div>
                    </div>
                    <span class="star-label">@(_system?.Name ?? "Star") • @_starType Star</span>
                    <div class="star-tooltip @(_showStarTooltip ? "visible" : "")">
                        <span class="tt-name">@(_system?.Name ?? "Star") System</span>
                        <span class="tt-type">@_starType Star</span>
                        <span class="tt-info">Planets: @_planets.Count</span>
                        <span class="tt-info">Habitable: @_planets.Count(p => p.Habitability >= 50)</span>
                        <span class="tt-info">Colonies: @_planets.Count(p => p.HasColony)</span>
                    </div>
                </div>
                
                <!-- Orbits and Planets -->
                <div class="orbits-container">
                    @for (int i = 0; i < _planets.Count; i++)
                    {
                        var planet = _planets[i];
                        var idx = i;
                        var orbitWidth = 180 + idx * 90;
                        var orbitHeight = (int)(orbitWidth * 0.35);
                        var duration = 20 + idx * 10;
                        var startAngle = (idx * 73 + idx * idx * 31) % 360;
                        var delay = -(startAngle / 360.0) * duration;
                        var planetSize = GetPlanetDisplaySize(planet);
                        var spinDuration = GetPlanetSpinDuration(planet);

                        <div class="orbit-ring" style="width: @(orbitWidth * 2)px; height: @(orbitHeight * 2)px;">
                            <div class="planet-orbit-path"
                                 style="animation-duration: @(duration)s; animation-delay: @(delay)s;
                                        offset-path: ellipse(@(orbitWidth)px @(orbitHeight)px at center);">
                                <div class="planet @(_selectedPlanet?.Id == planet.Id ? "selected" : "")"
                                     style="@GetPlanetStyle(planet, planetSize); --spin-duration: @(spinDuration)s;"
                                     @onclick="() => SelectPlanet(idx)"
                                     @onmouseenter="() => ShowPlanetTooltip(planet)"
                                     @onmouseleave="HideTooltip">
                                    @if (planet.HasColony)
                                    {
                                        <div class="colony-marker">🏠</div>
                                    }
                                    <div class="planet-tooltip">
                                        <span class="tt-name">@planet.Name</span>
                                        <span class="tt-type">@planet.Type • Size @planet.Size</span>
                                        <span class="tt-hab @GetHabitabilityClass(planet.Habitability)">Habitability: @planet.Habitability%</span>
                                        @if (planet.HasColony)
                                        {
                                            <span class="tt-colony">🏠 Pop: @planet.Population.ToString("N0")</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                
                <!-- Fleets -->
                <div class="fleets-in-system">
                    @foreach (var fleet in _fleets)
                    {
                        <div class="fleet-marker" title="@fleet.Name — @fleet.Ships ships">
                            <span class="fleet-icon">▲</span>
                            <span class="fleet-name">@fleet.Name</span>
                            <span class="fleet-ships">@fleet.Ships 🚀</span>
                        </div>
                    }
                </div>
            </div>
        </div>
        
        <aside class="st-sidebar-right" style="width: 320px;">
            <div class="st-outliner">
                <div class="st-outliner-header">
                    <span class="st-outliner-title">SYSTEM INFO</span>
                </div>
                
                @if (_selectedPlanet != null)
                {
                    <div class="planet-detail">
                        <div class="detail-header @_selectedPlanet.Type.ToLower()">
                            <div class="planet-preview">
                                <div class="planet-sphere" style="@GetPlanetStyle(_selectedPlanet, 60)"></div>
                            </div>
                            <div class="planet-title">
                                <h3>@_selectedPlanet.Name</h3>
                                <span>@_selectedPlanet.Type World</span>
                            </div>
                        </div>
                        <div class="detail-body">
                            <div class="info-section">
                                <h4>CHARACTERISTICS</h4>
                                <div class="info-row"><span>Size</span><span>@_selectedPlanet.Size</span></div>
                                <div class="info-row"><span>Climate</span><span>@_selectedPlanet.Climate</span></div>
                                <div class="info-row">
                                    <span>Habitability</span>
                                    <span class="@GetHabitabilityClass(_selectedPlanet.Habitability)">@_selectedPlanet.Habitability%</span>
                                </div>
                            </div>
                            <div class="info-section">
                                <h4>RESOURCES</h4>
                                <div class="resource-grid">
                                    @foreach (var r in _selectedPlanet.Resources)
                                    {
                                        <div class="resource-item">
                                            <span class="res-icon">@r.Icon</span>
                                            <span class="res-val">@r.Value</span>
                                        </div>
                                    }
                                </div>
                            </div>
                            @if (_selectedPlanet.HasColony)
                            {
                                <div class="info-section">
                                    <h4>COLONY</h4>
                                    <div class="info-row"><span>Population</span><span>@_selectedPlanet.Population.ToString("N0")</span></div>
                                    <button class="st-btn primary" style="width:100%;margin-top:12px;" @onclick="ManageColony">MANAGE COLONY</button>
                                </div>
                            }
                            else if (_selectedPlanet.Habitability >= 50)
                            {
                                <button class="st-btn success" style="width:100%;margin-top:16px;">COLONIZE PLANET</button>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="system-overview">
                        <div class="info-section">
                            <h4>SYSTEM DATA</h4>
                            <div class="info-row"><span>Star Type</span><span>@_starType</span></div>
                            <div class="info-row"><span>Planets</span><span>@_planets.Count</span></div>
                            <div class="info-row"><span>Habitable</span><span>@_planets.Count(p => p.Habitability >= 50)</span></div>
                            <div class="info-row"><span>Colonies</span><span>@_planets.Count(p => p.HasColony)</span></div>
                        </div>
                        <div class="info-section">
                            <h4>FLEETS</h4>
                            @foreach (var f in _fleets)
                            {
                                <div class="fleet-item">
                                    <span>▲ @f.Name</span>
                                    <span>@f.Ships ships</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </aside>
    </div>
</div>

<style>
    .system-content {
        flex: 1;
        position: relative;
        background: radial-gradient(ellipse at 25% 50%, #0a1428 0%, #040810 100%);
        overflow: hidden;
    }
    
    .system-view {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .star-container {
        position: absolute;
        left: 25%;
        top: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        z-index: 10;
    }
    
    .star-sprite {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        position: relative;
        background-repeat: no-repeat;
        filter: drop-shadow(0 0 30px rgba(255, 200, 100, 0.6));
    }

    /* Fallback CSS styles (used if spritesheet fails to load) */
    .star {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        position: relative;
    }

    .star.yellow {
        background: radial-gradient(circle, #fff 0%, #ffee88 30%, #ffaa00 70%, #ff6600 100%);
        box-shadow: 0 0 60px #ffaa00, 0 0 120px rgba(255, 170, 0, 0.5);
    }

    .star.red {
        background: radial-gradient(circle, #ffcccc 0%, #ff6666 30%, #cc0000 100%);
        box-shadow: 0 0 60px #cc0000;
    }

    .star.blue {
        background: radial-gradient(circle, #fff 0%, #aaddff 30%, #4488ff 100%);
        box-shadow: 0 0 60px #4488ff;
    }

    .star.orange {
        background: radial-gradient(circle, #fff 0%, #ffcc88 30%, #ff8800 100%);
        box-shadow: 0 0 60px #ff8800;
    }

    .star.white {
        background: radial-gradient(circle, #fff 0%, #eeeeff 50%, #aabbcc 100%);
        box-shadow: 0 0 60px #ffffff;
    }
    
    .star-corona {
        position: absolute;
        inset: -30px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(255, 200, 100, 0.3) 0%, transparent 70%);
        animation: pulse 4s ease-in-out infinite;
    }
    
    .star-label {
        display: block;
        margin-top: 20px;
        font-size: 12px;
        color: rgba(200, 220, 255, 0.7);
    }
    
    .orbits-container {
        position: absolute;
        left: 25%;
        top: 50%;
        transform: translate(-50%, -50%);
    }
    
    .orbit-ring {
        position: absolute;
        border: 1px solid rgba(100, 150, 200, 0.2);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        pointer-events: none;  /* Let clicks pass through orbit rings */
    }

    .planet-orbit-path {
        position: absolute;
        width: 100%;
        height: 100%;
        animation: orbit-ellipse linear infinite;
        pointer-events: none;  /* Let clicks pass through orbit path container */
        offset-rotate: 0deg;  /* Keep planet upright during orbit */
    }

    .planet {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 32px;
        height: 32px;
        border-radius: 50%;
        cursor: pointer;
        transition: box-shadow 0.2s ease, transform 0.2s ease;
        box-shadow: 0 0 10px rgba(100, 150, 200, 0.3);
        pointer-events: auto;  /* Planets catch clicks */
        z-index: 50;  /* Base z-index for all planets */
    }
    
    .planet:hover {
        transform: translateX(-50%) scale(1.4);
        box-shadow: 0 0 25px rgba(100, 180, 255, 0.6);
        z-index: 100;
    }
    
    .planet.selected {
        transform: translateX(-50%) scale(1.3);
        box-shadow: 0 0 25px rgba(255, 200, 100, 0.8);
        z-index: 100;
    }

    /* Planet rotation animation - creates spinning effect */
    .planet {
        animation: planet-spin var(--spin-duration, 20s) linear infinite;
        overflow: hidden;
        position: relative;
    }

    /* Inner rotating layer for the planet texture */
    .planet::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        border-radius: 50%;
        background: inherit;
        background-size: inherit;
        background-position: inherit;
        animation: texture-scroll var(--spin-duration, 20s) linear infinite;
    }

    @@keyframes texture-scroll {
        0% { background-position-x: 0; }
        100% { background-position-x: 100%; }
    }

    /* Add subtle 3D rotation effect with shadow movement */
    .planet::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        border-radius: 50%;
        background: linear-gradient(
            -70deg,
            transparent 30%,
            rgba(255, 255, 255, 0.1) 45%,
            transparent 50%,
            transparent 70%,
            rgba(0, 0, 0, 0.3) 85%,
            rgba(0, 0, 0, 0.5) 100%
        );
        pointer-events: none;
    }

    /* Planet styles are now set dynamically via AssetService.GetPlanetStyle() */
    /* This mixes generated spritesheet assets with sourced individual assets */

    .colony-marker {
        position: absolute;
        top: -10px;
        right: -10px;
        font-size: 14px;
    }
    
    .fleets-in-system {
        position: absolute;
        right: 30px;
        top: 50%;
        transform: translateY(-50%);
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    
    .fleet-marker {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        background: rgba(20, 30, 50, 0.85);
        border: 1px solid rgba(100, 150, 200, 0.3);
        border-radius: 6px;
    }
    
    .fleet-icon { color: #ffcc00; font-size: 14px; }
    .fleet-name { font-size: 12px; color: #fff; }
    .fleet-ships { font-size: 10px; color: rgba(200, 220, 255, 0.6); margin-left: auto; }

    /* Tooltips */
    .planet-tooltip, .star-tooltip {
        position: absolute;
        bottom: calc(100% + 12px);
        left: 50%;
        transform: translateX(-50%);
        background: rgba(8, 14, 25, 0.95);
        border: 1px solid rgba(100, 150, 200, 0.5);
        border-radius: 6px;
        padding: 8px 12px;
        min-width: 160px;
        display: flex;
        flex-direction: column;
        gap: 3px;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.2s;
        z-index: 200;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.6);
    }
    .planet:hover .planet-tooltip,
    .star-tooltip.visible {
        opacity: 1;
    }
    .tt-name { font-size: 13px; font-weight: 600; color: #fff; }
    .tt-type { font-size: 10px; color: rgba(200, 220, 255, 0.6); }
    .tt-hab { font-size: 11px; }
    .tt-hab.good { color: #44dd66; }
    .tt-hab.medium { color: #ffcc00; }
    .tt-hab.poor { color: #ff6666; }
    .tt-colony { font-size: 10px; color: #88ccff; margin-top: 2px; }
    .tt-info { font-size: 10px; color: rgba(200, 220, 255, 0.7); }
    
    /* Detail Panel */
    .planet-detail { }
    
    .detail-header {
        display: flex;
        gap: 16px;
        padding: 16px;
        border-bottom: 1px solid rgba(100, 150, 200, 0.2);
    }
    
    .detail-header.terran { background: linear-gradient(180deg, rgba(74, 136, 74, 0.2), transparent); }
    .detail-header.desert { background: linear-gradient(180deg, rgba(180, 140, 60, 0.2), transparent); }
    .detail-header.arctic { background: linear-gradient(180deg, rgba(100, 160, 220, 0.2), transparent); }
    .detail-header.oceanic { background: linear-gradient(180deg, rgba(40, 100, 180, 0.2), transparent); }
    .detail-header.barren { background: linear-gradient(180deg, rgba(100, 100, 100, 0.2), transparent); }
    .detail-header.volcanic { background: linear-gradient(180deg, rgba(180, 60, 30, 0.2), transparent); }
    .detail-header.gasgiant { background: linear-gradient(180deg, rgba(200, 160, 100, 0.2), transparent); }
    
    .planet-preview { width: 60px; height: 60px; }

    /* Planet sphere styles are now set dynamically via AssetService.GetPlanetStyle() */
    .planet-sphere {
        border-radius: 50%;
    }

    .planet-title h3 {
        font-size: 16px;
        color: #fff;
        margin: 0 0 4px;
    }
    
    .planet-title span {
        font-size: 11px;
        color: rgba(200, 220, 255, 0.6);
    }
    
    .detail-body { padding: 16px; }
    
    .info-section {
        margin-bottom: 20px;
    }
    
    .info-section h4 {
        font-size: 10px;
        color: rgba(200, 220, 255, 0.5);
        letter-spacing: 1px;
        margin: 0 0 10px;
        padding-bottom: 6px;
        border-bottom: 1px solid rgba(100, 150, 200, 0.2);
    }
    
    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 4px 0;
        font-size: 12px;
    }
    
    .info-row span:first-child { color: rgba(200, 220, 255, 0.6); }
    .info-row span:last-child { color: #fff; }
    
    .info-row .good { color: #44dd66; }
    .info-row .medium { color: #ffcc00; }
    .info-row .poor { color: #ff6666; }
    
    .resource-grid {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }
    
    .resource-item {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 10px;
        background: rgba(30, 45, 70, 0.6);
        border-radius: 4px;
    }
    
    .res-icon { font-size: 14px; }
    .res-val { font-size: 12px; color: #fff; }
    
    .system-overview { padding: 16px; }
    
    .fleet-item {
        display: flex;
        justify-content: space-between;
        padding: 8px;
        background: rgba(30, 45, 70, 0.6);
        border-radius: 4px;
        margin-bottom: 6px;
        font-size: 11px;
        color: rgba(200, 220, 255, 0.7);
    }
    
    /* Fallback rotation animation (for browsers without offset-path support) */
    @@keyframes orbit {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    /* Elliptical orbit using offset-path (modern browsers) */
    @@keyframes orbit-ellipse {
        from { offset-distance: 0%; }
        to { offset-distance: 100%; }
    }
    
    @@keyframes pulse {
        0%, 100% { opacity: 0.5; transform: scale(1); }
        50% { opacity: 0.8; transform: scale(1.1); }
    }
</style>

@code {
    [Parameter] public Guid SystemId { get; set; }
    
    private StarSystemDto? _system;
    private string _starType = "Yellow";
    private List<PlanetData> _planets = new();
    private PlanetData? _selectedPlanet;
    private List<FleetData> _fleets = new();
    private Dictionary<string, PlanetAsset?> _planetAssets = new();  // Cached planet assets
    private bool _showStarTooltip = false;

    protected override async Task OnInitializedAsync()
    {
        // Initialize asset service for mixed planet assets
        await AssetService.InitializeAsync();

        try
        {
            var games = await Api.GetGamesAsync();
            var gameId = games.FirstOrDefault()?.Id ?? Guid.Empty;
            var systems = await Api.GetKnownSystemsAsync(gameId, Guid.Empty);
            _system = systems.FirstOrDefault(s => s.Id == SystemId) ?? systems.FirstOrDefault();
        }
        catch { }

        GenerateSystemData();

        // Cache planet assets for rendering
        foreach (var planet in _planets)
        {
            _planetAssets[planet.Id.ToString()] = AssetService.GetPlanetForIdentifier(planet.Type.ToLower(), planet.Name);
        }
    }

    private string GetPlanetStyle(PlanetData planet, int size)
    {
        var key = planet.Id.ToString();
        if (_planetAssets.TryGetValue(key, out var asset) && asset != null)
        {
            return AssetService.GetPlanetStyle(asset, size);
        }
        // Fallback to default spritesheet style
        return GetFallbackPlanetStyle(planet.Type.ToLower(), size);
    }

    private string GetFallbackPlanetStyle(string planetType, int size)
    {
        var (row, col) = planetType switch
        {
            "terran" => (0, 0),
            "oceanic" => (0, 1),
            "jungle" => (0, 2),
            "arctic" => (0, 3),
            "desert" => (0, 4),
            "gasgiant" => (1, 0),
            "barren" => (2, 0),
            "volcanic" => (2, 2),
            _ => (0, 0)
        };
        var scale = size / 360.0;
        var bgSize = (int)(2160 * scale);
        var x = (int)(col * 360 * scale);
        var y = (int)(row * 360 * scale);
        return $"background-image: url('/assets/universal/planets_spritesheet.png'); " +
               $"background-size: {bgSize}px {bgSize}px; " +
               $"background-position: -{x}px -{y}px; " +
               $"width: {size}px; height: {size}px; border-radius: 50%;";
    }

    /// <summary>
    /// Get display size for a planet based on type and size attribute.
    /// Mimics real-world size variations:
    /// - Gas giants: 50-80px (Jupiter/Saturn scale)
    /// - Terran/Oceanic: 24-36px (Earth-like)
    /// - Desert/Arctic/Volcanic: 20-32px (Mars-like)
    /// - Barren: 12-24px (Mercury/Moon scale)
    /// </summary>
    private int GetPlanetDisplaySize(PlanetData planet)
    {
        // Base size ranges by planet type (min, max)
        var (minSize, maxSize) = planet.Type.ToLower() switch
        {
            "gasgiant" => (50, 80),      // Gas giants are huge (Jupiter = 11x Earth)
            "terran" => (26, 36),        // Earth-like planets
            "oceanic" => (24, 34),       // Ocean worlds, similar to terran
            "jungle" => (24, 34),        // Jungle worlds
            "desert" => (20, 30),        // Mars-like (Mars = 0.5x Earth)
            "arctic" => (20, 30),        // Ice worlds
            "volcanic" => (18, 28),      // Volcanic worlds, often smaller
            "barren" => (14, 24),        // Mercury/Moon scale (Mercury = 0.38x Earth)
            _ => (22, 32)                // Default
        };

        // Use planet's Size attribute (typically 8-25) to interpolate within range
        // Normalize Size to 0-1 range (assuming Size is 5-30)
        var normalizedSize = Math.Clamp((planet.Size - 5) / 25.0, 0, 1);

        // Add some variation based on planet name hash for uniqueness
        var nameHash = planet.Name.GetHashCode();
        var variation = (Math.Abs(nameHash) % 10) / 10.0 * 0.2 - 0.1; // ±10% variation

        var finalRatio = Math.Clamp(normalizedSize + variation, 0, 1);
        return (int)(minSize + (maxSize - minSize) * finalRatio);
    }

    /// <summary>
    /// Get rotation speed for a planet (in seconds per rotation).
    /// Gas giants spin faster (Jupiter = 10 hours), rocky planets slower.
    /// </summary>
    private int GetPlanetSpinDuration(PlanetData planet)
    {
        // Base spin duration by planet type (seconds for visual rotation)
        var baseDuration = planet.Type.ToLower() switch
        {
            "gasgiant" => 8,      // Gas giants spin fast (Jupiter = 10h)
            "terran" => 20,       // Earth = 24h
            "oceanic" => 22,      // Similar to Earth
            "jungle" => 18,       // Slightly faster
            "desert" => 25,       // Mars-like (Mars = 24.6h)
            "arctic" => 24,       // Ice worlds
            "volcanic" => 30,     // Slower rotation
            "barren" => 40,       // Very slow (Mercury = 59 days!)
            _ => 20
        };

        // Add variation based on planet name for uniqueness
        var nameHash = Math.Abs(planet.Name.GetHashCode());
        var variation = (nameHash % 10) - 5; // ±5 seconds variation

        return Math.Max(5, baseDuration + variation);
    }

    private void GenerateSystemData()
    {
        var systemName = _system?.Name ?? "Unknown";

        // Check for canonical Star Trek systems first
        if (TryGenerateCanonicalSystem(systemName))
        {
            return;
        }

        var hash = systemName.GetHashCode();
        var random = new Random(hash);

        // Star type - use system's star type if available, otherwise generate from name hash
        var starTypes = new[] { "Yellow", "Red", "Blue", "Orange", "White" };
        var systemStarType = _system?.StarType;
        if (string.IsNullOrEmpty(systemStarType) || systemStarType.Equals("Unknown", StringComparison.OrdinalIgnoreCase))
        {
            // Generate consistent random star type from system name
            _starType = starTypes[Math.Abs(hash) % starTypes.Length];
        }
        else
        {
            _starType = systemStarType;
        }

        // Generate planets
        var planetTypes = new[] { "Terran", "Desert", "Arctic", "Oceanic", "Barren", "Volcanic" };
        var climates = new[] { "Temperate", "Arid", "Frozen", "Tropical", "Barren", "Molten" };
        var planetCount = random.Next(3, 7);

        _planets = new List<PlanetData>();
        for (int i = 0; i < planetCount; i++)
        {
            var typeIdx = random.Next(planetTypes.Length);
            var habitability = planetTypes[typeIdx] == "Terran" ? random.Next(60, 95) :
                               planetTypes[typeIdx] == "Oceanic" ? random.Next(50, 80) :
                               planetTypes[typeIdx] == "Desert" ? random.Next(30, 60) :
                               random.Next(5, 40);

            _planets.Add(new PlanetData
            {
                Id = Guid.NewGuid(),
                Name = $"{systemName} {ToRoman(i + 1)}",
                Type = planetTypes[typeIdx],
                Size = random.Next(8, 25),
                Climate = climates[typeIdx],
                Habitability = habitability,
                HasColony = i == 0 && _system?.ControllingFactionId != null,
                Population = i == 0 && _system?.ControllingFactionId != null ? (long)random.Next(1_000_000, int.MaxValue) : 0,
                Buildings = i == 0 ? random.Next(3, 8) : 0,
                Resources = new List<ResourceInfo>
                {
                    new() { Icon = "⚙️", Value = random.Next(2, 8) },
                    new() { Icon = "🔬", Value = random.Next(1, 5) },
                    new() { Icon = "💎", Value = random.Next(0, 3) }
                }
            });
        }

        // Sample fleets
        _fleets = new List<FleetData>
        {
            new() { Name = "1st Exploration Fleet", Ships = 5 },
            new() { Name = "Defense Squadron", Ships = 3 }
        };

        _selectedPlanet = _planets.FirstOrDefault();
    }

    private bool TryGenerateCanonicalSystem(string systemName)
    {
        var normalizedName = systemName.ToLower().Trim();

        switch (normalizedName)
        {
            case "sol":
            case "earth":
            case "terra":
                GenerateSolSystemData();
                return true;
            case "vulcan":
            case "40 eridani":
                GenerateVulcanSystemData();
                return true;
            case "qo'nos":
            case "kronos":
            case "klingon":
                GenerateQonosSystemData();
                return true;
            case "romulus":
            case "romulan":
                GenerateRomulusSystemData();
                return true;
            case "cardassia":
            case "cardassian":
                GenerateCardassiaSystemData();
                return true;
            case "bajor":
            case "bajoran":
                GenerateBajorSystemData();
                return true;
            case "ferenginar":
            case "ferengi":
                GenerateFerengiSystemData();
                return true;
            case "andoria":
            case "andorian":
                GenerateAndoriaSystemData();
                return true;
            default:
                return false;
        }
    }

