    private string GetHabitabilityClass(int hab) => hab >= 70 ? "good" : hab >= 40 ? "medium" : "poor";
    
    private string ToRoman(int num) => num switch
    {
        1 => "I", 2 => "II", 3 => "III", 4 => "IV", 5 => "V",
        6 => "VI", 7 => "VII", 8 => "VIII", 9 => "IX", 10 => "X",
        _ => num.ToString()
    };

    // Star spritesheet rendering
    // Spritesheet is 1440x1440px with 4x4 grid of 360px cells
    // Display size 100px = scale factor 100/360 = 0.278
    // background-size = 1440 * 0.278 = 400px
    // position offset = col * 360 * 0.278 = col * 100
    private string GetStarSpriteStyle()
    {
        var (row, col) = GetStarGridPosition(_starType);
        var displaySize = 100;
        var scaleFactor = displaySize / 360.0;
        var bgSize = (int)(1440 * scaleFactor);  // 400px
        var x = (int)(col * 360 * scaleFactor);  // col * 100
        var y = (int)(row * 360 * scaleFactor);  // row * 100

        return $"width: {displaySize}px; height: {displaySize}px; " +
               $"background-image: url('/assets/universal/stars_spritesheet.png'); " +
               $"background-position: -{x}px -{y}px; " +
               $"background-size: {bgSize}px {bgSize}px; " +
               $"border-radius: 50%;";
    }

    private (int row, int col) GetStarGridPosition(string starType) => starType?.ToLower() switch
    {
        "yellow" => (0, 0),   // Star Yellow Dwarf
        "orange" => (0, 1),   // Star Orange Dwarf
        "red" => (0, 2),      // Star Red Dwarf
        "blue" => (0, 3),     // Star Blue Giant
        "white" => (1, 2),    // Star White Giant
        "neutron" => (2, 0),  // Star Neutron Pulsar
        "blackhole" => (2, 1), // Star Black Hole
        _ => (0, 0)           // Default to Yellow Dwarf
    };
    
