@page "/game/tutorial"
@page "/game/help"
@using MudBlazor
@using StarTrekGame.Web.Services
@inject NavigationManager Navigation
@inject ThemeService ThemeService

<PageTitle>Tutorial - Galactic Strategy</PageTitle>

<div class="tutorial-wrapper">
    <div class="tutorial-page-header">
        <h1 class="page-title">📚 COMMANDER'S GUIDE</h1>
    </div>

    <div class="tutorial-content">
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Class="tutorial-tabs">
            
            @* Getting Started *@
            <MudTabPanel Text="🚀 Getting Started" Icon="@Icons.Material.Filled.PlayArrow">
                <div class="section">
                    <h2>Welcome, Commander!</h2>
                    <p>Galactic Strategy is a 4X space strategy game set in the Star Trek universe. Your mission is to lead your faction to galactic dominance through exploration, expansion, exploitation, and extermination.</p>
                    
                    <div class="info-cards">
                        <div class="info-card">
                            <div class="card-icon">🔭</div>
                            <h3>Explore</h3>
                            <p>Send scouts to discover new star systems and uncover the mysteries of the galaxy.</p>
                        </div>
                        <div class="info-card">
                            <div class="card-icon">🌍</div>
                            <h3>Expand</h3>
                            <p>Colonize habitable planets to grow your empire and increase your resources.</p>
                        </div>
                        <div class="info-card">
                            <div class="card-icon">⚙</div>
                            <h3>Exploit</h3>
                            <p>Build infrastructure and research technology to strengthen your civilization.</p>
                        </div>
                        <div class="info-card">
                            <div class="card-icon">⚔</div>
                            <h3>Exterminate</h3>
                            <p>Build powerful fleets to defend your territory and conquer your enemies.</p>
                        </div>
                    </div>

                    <h3>Quick Start Guide</h3>
                    <ol class="steps-list">
                        <li><strong>Check your Overview</strong> - See your faction status, resources, and victory progress</li>
                        <li><strong>Explore the Galaxy Map</strong> - Click systems to see details and plan expansion</li>
                        <li><strong>Manage your Colonies</strong> - Build ships and structures to grow stronger</li>
                        <li><strong>Command your Fleets</strong> - Move ships to explore or attack enemy systems</li>
                        <li><strong>End your Turn</strong> - Process the turn to see results and continue</li>
                    </ol>
                </div>
            </MudTabPanel>

            @* Galaxy Map *@
            <MudTabPanel Text="🗺️ Galaxy Map" Icon="@Icons.Material.Filled.Map">
                <div class="section">
                    <h2>Galaxy Map Navigation</h2>
                    
                    <div class="feature-block">
                        <h3>🖱️ Controls</h3>
                        <ul>
                            <li><strong>Click & Drag</strong> - Pan around the galaxy</li>
                            <li><strong>Scroll Wheel</strong> - Zoom in/out</li>
                            <li><strong>Click System</strong> - Select and view details</li>
                            <li><strong>Double-Click</strong> - Open system view</li>
                        </ul>
                    </div>

                    <div class="feature-block">
                        <h3>⭐ Star Types</h3>
                        <div class="star-legend">
                            <div class="legend-item"><span class="star yellow"></span> Yellow - Common, good habitability</div>
                            <div class="legend-item"><span class="star red"></span> Red - Dwarf stars, fewer planets</div>
                            <div class="legend-item"><span class="star blue"></span> Blue - Hot, resource-rich</div>
                            <div class="legend-item"><span class="star white"></span> White - Rare, high value</div>
                        </div>
                    </div>

                    <div class="feature-block">
                        <h3>🏴 Territory Colors</h3>
                        <p>Systems are color-coded by controlling faction. Your territory appears highlighted, while enemy and neutral systems show their respective colors.</p>
                    </div>

                    <div class="feature-block">
                        <h3>🚀 Fleet Icons</h3>
                        <ul>
                            <li><strong>Triangle (stationary)</strong> - Fleet at rest in system</li>
                            <li><strong>Triangle (moving)</strong> - Fleet in transit with engine trail</li>
                            <li><strong>Number</strong> - Ship count in fleet</li>
                        </ul>
                    </div>
                </div>
            </MudTabPanel>

            @* Fleets & Combat *@
            <MudTabPanel Text="⚔️ Fleets & Combat" Icon="@Icons.Material.Filled.RocketLaunch">
                <div class="section">
                    <h2>Fleet Management</h2>
                    
                    <div class="feature-block">
                        <h3>🚀 Ship Classes</h3>
                        <table class="data-table">
                            <thead>
                                <tr><th>Class</th><th>Role</th><th>Strength</th><th>Cost</th></tr>
                            </thead>
                            <tbody>
                                <tr><td>Scout</td><td>Exploration</td><td>Low</td><td>50⚙</td></tr>
                                <tr><td>Escort</td><td>Light Combat</td><td>Medium</td><td>80⚙</td></tr>
                                <tr><td>Destroyer</td><td>Balanced</td><td>Medium</td><td>120⚙</td></tr>
                                <tr><td>Cruiser</td><td>Heavy Combat</td><td>High</td><td>180⚙</td></tr>
                                <tr><td>Battleship</td><td>Capital Ship</td><td>Very High</td><td>300⚙</td></tr>
                                <tr><td>Transport</td><td>Cargo</td><td>Low</td><td>60⚙</td></tr>
                                <tr><td>Colony Ship</td><td>Colonization</td><td>None</td><td>150⚙</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="feature-block">
                        <h3>⚔️ The Thermopylae Principle</h3>
                        <p class="highlight-text">Combat in Galactic Strategy rewards tactical excellence over raw numbers. A smaller, well-positioned fleet with high morale and experienced crews can defeat a larger enemy force.</p>
                        <ul>
                            <li><strong>Morale</strong> - Affects combat effectiveness and retreat threshold</li>
                            <li><strong>Experience</strong> - Veteran ships deal more damage and take less</li>
                            <li><strong>Position</strong> - Defensive bonuses for system defenders</li>
                            <li><strong>Stance</strong> - Aggressive, Balanced, or Defensive postures</li>
                        </ul>
                    </div>

                    <div class="feature-block">
                        <h3>🎯 Combat Resolution</h3>
                        <ol>
                            <li>Fleets meeting in same system trigger combat</li>
                            <li>Combat proceeds in rounds until one side retreats or is destroyed</li>
                            <li>Ships fire based on weapon power, modified by experience</li>
                            <li>Shields absorb damage first, then hull takes hits</li>
                            <li>Critical hits can disable systems or cause extra damage</li>
                        </ol>
                    </div>
                </div>
            </MudTabPanel>

            @* Colonies *@
            <MudTabPanel Text="🌍 Colonies" Icon="@Icons.Material.Filled.LocationCity">
                <div class="section">
                    <h2>Colony Management</h2>
                    
                    <div class="feature-block">
                        <h3>📊 Colony Stats</h3>
                        <ul>
                            <li><strong>Population</strong> - Grows each turn, affects production</li>
                            <li><strong>Production (⚙)</strong> - Build speed for ships and structures</li>
                            <li><strong>Research (🔬)</strong> - Contributes to technology progress</li>
                            <li><strong>Defense (🛡)</strong> - Orbital defense strength</li>
                        </ul>
                    </div>

                    <div class="feature-block">
                        <h3>🏗️ Buildings</h3>
                        <table class="data-table">
                            <thead>
                                <tr><th>Building</th><th>Effect</th><th>Cost</th></tr>
                            </thead>
                            <tbody>
                                <tr><td>Shipyard</td><td>+50% ship production</td><td>200⚙</td></tr>
                                <tr><td>Research Lab</td><td>+25 research output</td><td>150⚙</td></tr>
                                <tr><td>Orbital Defense</td><td>+50 defense rating</td><td>180⚙</td></tr>
                                <tr><td>Mining Complex</td><td>+30% production</td><td>160⚙</td></tr>
                                <tr><td>Hydroponics</td><td>+20% pop growth</td><td>120⚙</td></tr>
                                <tr><td>Shield Generator</td><td>+25 planetary shields</td><td>220⚙</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="feature-block">
                        <h3>🌍 Colonization</h3>
                        <ol>
                            <li>Build a Colony Ship at any colony</li>
                            <li>Move the fleet to an unclaimed system with habitable planets</li>
                            <li>Select "Colonize" on an eligible planet</li>
                            <li>The Colony Ship is consumed to establish the new colony</li>
                        </ol>
                    </div>
                </div>
            </MudTabPanel>

            @* Victory Conditions *@
            <MudTabPanel Text="🏆 Victory" Icon="@Icons.Material.Filled.EmojiEvents">
                <div class="section">
                    <h2>Victory Conditions</h2>
                    <p>There are three ways to achieve victory in Galactic Strategy:</p>
                    
                    <div class="victory-cards">
                        <div class="victory-card conquest">
                            <div class="victory-icon">⚔️</div>
                            <h3>Conquest Victory</h3>
                            <p>Control 75% of all colonized systems in the galaxy. Achieved through military dominance and territorial expansion.</p>
                            <div class="victory-tip">Tip: Focus on building a strong fleet and targeting enemy homeworlds.</div>
                        </div>
                        
                        <div class="victory-card economic">
                            <div class="victory-icon">💰</div>
                            <h3>Economic Victory</h3>
                            <p>Accumulate 10,000 credits in your treasury. Build a thriving economy through trade and efficient colony management.</p>
                            <div class="victory-tip">Tip: Build Mining Complexes and focus on high-production colonies.</div>
                        </div>
                        
                        <div class="victory-card time">
                            <div class="victory-icon">⏱️</div>
                            <h3>Time Victory</h3>
                            <p>Have the highest score when Turn 100 is reached. Score is based on systems controlled, fleet strength, and technology.</p>
                            <div class="victory-tip">Tip: Balance expansion, economy, and military for the best overall score.</div>
                        </div>
                    </div>
                </div>
            </MudTabPanel>

            @* Keyboard Shortcuts *@
            <MudTabPanel Text="⌨️ Shortcuts" Icon="@Icons.Material.Filled.Keyboard">
                <div class="section">
                    <h2>Keyboard Shortcuts</h2>
                    
                    <div class="shortcuts-grid">
                        <div class="shortcut-group">
                            <h3>Navigation</h3>
                            <div class="shortcut"><kbd>M</kbd> Galaxy Map</div>
                            <div class="shortcut"><kbd>F</kbd> Fleets</div>
                            <div class="shortcut"><kbd>C</kbd> Colonies</div>
                            <div class="shortcut"><kbd>R</kbd> Research</div>
                            <div class="shortcut"><kbd>D</kbd> Diplomacy</div>
                            <div class="shortcut"><kbd>O</kbd> Overview</div>
                            <div class="shortcut"><kbd>S</kbd> Settings</div>
                        </div>
                        
                        <div class="shortcut-group">
                            <h3>Map Controls</h3>
                            <div class="shortcut"><kbd>+</kbd> Zoom In</div>
                            <div class="shortcut"><kbd>-</kbd> Zoom Out</div>
                            <div class="shortcut"><kbd>Space</kbd> Center Map</div>
                            <div class="shortcut"><kbd>Esc</kbd> Back / Close</div>
                        </div>
                        
                        <div class="shortcut-group">
                            <h3>Game</h3>
                            <div class="shortcut"><kbd>Enter</kbd> End Turn</div>
                            <div class="shortcut"><kbd>?</kbd> Help</div>
                        </div>
                    </div>
                </div>
            </MudTabPanel>

            @* Species & Traits *@
            <MudTabPanel Text="🧬 Species" Icon="@Icons.Material.Filled.Biotech">
                <div class="section">
                    <h2>Species & Traits System</h2>

                    <div class="feature-block">
                        <h3>📖 Encyclopedia</h3>
                        <p>Browse all 38 species across 6 quadrants (Alpha, Beta, Gamma, Delta, Borg, Xindi). Each species has unique traits, habitability preferences, and modifiers that affect gameplay.</p>
                        <ul>
                            <li><strong>Species Traits</strong> — Each species has genetic traits that provide bonuses (+Research, +Production, etc.)</li>
                            <li><strong>Habitability</strong> — Species thrive on different planet types (Arctic, Desert, Ocean, etc.)</li>
                            <li><strong>Special Flags</strong> — Some species are Telepathic, Shapeshifter, Cybernetic, or have other unique abilities</li>
                        </ul>
                    </div>

                    <div class="feature-block">
                        <h3>👥 Demographics</h3>
                        <p>View empire-wide species distribution and per-colony breakdown. Manage Species Rights to control how each species integrates into your empire.</p>
                        <table class="data-table">
                            <thead><tr><th>Right</th><th>Options</th><th>Effect</th></tr></thead>
                            <tbody>
                                <tr><td>Citizenship</td><td>Full / Caste / Restricted</td><td>Happiness, political power</td></tr>
                                <tr><td>Military Service</td><td>Full / Limited / None</td><td>Army strength, fleet morale</td></tr>
                                <tr><td>Living Standards</td><td>Utopian / Normal / Subsistence</td><td>Consumer goods cost, happiness</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="feature-block">
                        <h3>🧪 Gene Modification</h3>
                        <p>Add or remove genetic traits from species in your empire. Requires genetic research technology.</p>
                        <ul>
                            <li><strong>Point Budget</strong> — 5 base points + 2 per genetic tech level</li>
                            <li><strong>Cost</strong> — 500 Credits per modification</li>
                            <li><strong>Categories</strong> — Biological, Social, Intelligence, Physical, Special</li>
                        </ul>
                    </div>
                </div>
            </MudTabPanel>

            @* Tactical Combat *@
            <MudTabPanel Text="⚔️ Tactics" Icon="@Icons.Material.Filled.Shield">
                <div class="section">
                    <h2>Tactical Combat System</h2>

                    <div class="feature-block">
                        <h3>📋 Battle Doctrine</h3>
                        <p>Configure per-fleet doctrine from the Fleet Management screen. Each fleet can have its own tactical profile.</p>
                        <table class="data-table">
                            <thead><tr><th>Setting</th><th>Options</th></tr></thead>
                            <tbody>
                                <tr><td>Engagement Policy</td><td>Aggressive, Defensive, Hit-and-Run, Standoff, Balanced</td></tr>
                                <tr><td>Formation</td><td>Wedge, Sphere, Line, Dispersed, Echelon</td></tr>
                                <tr><td>Target Priority</td><td>Highest Threat, Weakest, Capitals, Flagships, Random</td></tr>
                                <tr><td>Retreat Threshold</td><td>0-100% fleet losses before retreat</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="feature-block">
                        <h3>🎯 Formation Bonuses</h3>
                        <p class="highlight-text">Formations follow a rock-paper-scissors system. Choosing the right formation against your enemy gives damage bonuses up to +20%.</p>
                        <ul>
                            <li><strong>Wedge</strong> — Strong vs Line, weak vs Sphere</li>
                            <li><strong>Sphere</strong> — Strong vs Wedge, weak vs Dispersed</li>
                            <li><strong>Line</strong> — Strong vs Echelon, weak vs Wedge</li>
                            <li><strong>Dispersed</strong> — Strong vs Sphere, weak vs Echelon</li>
                            <li><strong>Echelon</strong> — Strong vs Dispersed, weak vs Line</li>
                        </ul>
                    </div>

                    <div class="feature-block">
                        <h3>⚠️ Disorder System</h3>
                        <p>Changing orders mid-battle causes disorder — a cumulative accuracy and morale penalty.</p>
                        <ul>
                            <li><strong>Base Cost</strong> — +15% disorder per order change</li>
                            <li><strong>No Commander</strong> — +25% additional penalty</li>
                            <li><strong>Prior Orders</strong> — +5% per previous order in this battle</li>
                            <li><strong>Drill Level</strong> — Reduces disorder (−drillLevel × 0.2)</li>
                            <li><strong>Conditional Orders</strong> — Pre-programmed triggers execute FREE (no disorder)</li>
                        </ul>
                    </div>
                </div>
            </MudTabPanel>

            @* Leaders *@
            <MudTabPanel Text="👤 Leaders" Icon="@Icons.Material.Filled.Person">
                <div class="section">
                    <h2>Leader Management</h2>

                    <div class="feature-block">
                        <h3>🎖️ Leader Classes</h3>
                        <table class="data-table">
                            <thead><tr><th>Class</th><th>Role</th><th>Key Skills</th></tr></thead>
                            <tbody>
                                <tr><td>Admiral</td><td>Fleet Commander</td><td>Tactics, Logistics, Evasion</td></tr>
                                <tr><td>General</td><td>Ground Forces</td><td>Assault, Defense, Morale</td></tr>
                                <tr><td>Scientist</td><td>Research Lead</td><td>Physics, Biology, Engineering</td></tr>
                                <tr><td>Governor</td><td>Colony Manager</td><td>Administration, Infrastructure</td></tr>
                                <tr><td>Agent</td><td>Espionage</td><td>Infiltration, Sabotage, Counter-Intel</td></tr>
                                <tr><td>Diplomat</td><td>Foreign Relations</td><td>Negotiation, Deception, Influence</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="feature-block">
                        <h3>📈 Recruitment & Skills</h3>
                        <ul>
                            <li><strong>Recruit</strong> — Hire leaders from the leader pool (costs credits)</li>
                            <li><strong>Experience</strong> — Leaders gain XP through their assigned role</li>
                            <li><strong>Skills</strong> — Each level unlocks skill points for specialization</li>
                            <li><strong>Assignment</strong> — Assign leaders to fleets, armies, colonies, or research</li>
                        </ul>
                    </div>
                </div>
            </MudTabPanel>

            @* Crisis & Events *@
            <MudTabPanel Text="🔮 Crisis" Icon="@Icons.Material.Filled.Warning">
                <div class="section">
                    <h2>Crisis & Events</h2>

                    <div class="feature-block">
                        <h3>⚡ Late-Game Crises</h3>
                        <p class="highlight-text">When you least expect it, the galaxy faces existential threats. Crises escalate through 4 phases, each more dangerous than the last.</p>
                        <table class="data-table">
                            <thead><tr><th>Crisis</th><th>Threat</th></tr></thead>
                            <tbody>
                                <tr><td>Borg Incursion</td><td>Assimilating faction by faction</td></tr>
                                <tr><td>Dominion Invasion</td><td>Massive fleets from the Gamma Quadrant</td></tr>
                                <tr><td>Temporal Anomaly</td><td>Reality tears destabilizing systems</td></tr>
                                <tr><td>AI Rebellion</td><td>Your own technology turns against you</td></tr>
                                <tr><td>Subspace Collapse</td><td>Warp travel becomes impossible</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="feature-block">
                        <h3>🎲 Random Events</h3>
                        <p>Events fire based on triggers (turn number, technology level, diplomatic state). Some events chain into multi-turn storylines with choices that affect your empire.</p>
                        <ul>
                            <li><strong>Positive</strong> — Resource windfalls, technology breakthroughs, diplomatic openings</li>
                            <li><strong>Negative</strong> — Plagues, pirate raids, natural disasters</li>
                            <li><strong>Chain Events</strong> — Multi-step storylines with branching choices</li>
                        </ul>
                    </div>
                </div>
            </MudTabPanel>

            @* Economy & Policies *@
            <MudTabPanel Text="📊 Economy" Icon="@Icons.Material.Filled.AccountBalance">
                <div class="section">
                    <h2>Economy & Policies</h2>

                    <div class="feature-block">
                        <h3>💰 Resources</h3>
                        <table class="data-table">
                            <thead><tr><th>Resource</th><th>Source</th><th>Use</th></tr></thead>
                            <tbody>
                                <tr><td>Credits 💰</td><td>Trade, taxation</td><td>Leaders, maintenance, diplomacy</td></tr>
                                <tr><td>Dilithium 💎</td><td>Mining</td><td>Warp drives, advanced tech</td></tr>
                                <tr><td>Duranium ⚙️</td><td>Mining</td><td>Ship construction, buildings</td></tr>
                                <tr><td>Deuterium ⚡</td><td>Gas giants</td><td>Ship fuel, energy</td></tr>
                                <tr><td>Research 🔬</td><td>Labs, scientists</td><td>Technology progress</td></tr>
                                <tr><td>Influence 🏛️</td><td>Diplomacy</td><td>Claims, edicts, treaties</td></tr>
                                <tr><td>Food 🌾</td><td>Agriculture</td><td>Population growth</td></tr>
                                <tr><td>Alloys 🔧</td><td>Refineries</td><td>Advanced ship components</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="feature-block">
                        <h3>📜 Policies</h3>
                        <p>Policies apply empire-wide modifiers. Changing a policy reverts old modifiers and applies new ones (revert-then-apply pattern).</p>
                        <ul>
                            <li><strong>Military Policy</strong> — Affects fleet size, weapon damage, ship cost</li>
                            <li><strong>Economic Policy</strong> — Trade income, production bonuses, maintenance costs</li>
                            <li><strong>Diplomatic Policy</strong> — Relation modifiers, treaty options, influence gain</li>
                            <li><strong>Research Policy</strong> — Focus area bonuses, research speed</li>
                        </ul>
                    </div>

                    <div class="feature-block">
                        <h3>🚚 Trade Routes</h3>
                        <p>Establish trade routes between colonies for mutual economic benefit. Trade routes require Transport ships and are vulnerable to piracy.</p>
                    </div>
                </div>
            </MudTabPanel>

        </MudTabs>
    </div>
</div>

<style>
    .tutorial-wrapper { flex: 1; display: flex; flex-direction: column; overflow-y: auto; }

    .tutorial-page-header { padding: 12px 24px; background: linear-gradient(180deg, #1a1a2e 0%, #0a0a18 100%); border-bottom: 3px solid #ff9900; display: flex; align-items: center; gap: 24px; }
    .page-title { color: #ffcc00; font-size: 18px; font-weight: 700; letter-spacing: 4px; margin: 0; }

    .tutorial-content { max-width: 1000px; margin: 0 auto; padding: 24px; }
    
    .section { padding: 24px; color: #ccc; line-height: 1.7; }
    .section h2 { color: #ffcc00; font-size: 28px; margin-bottom: 16px; border-bottom: 2px solid #ff9900; padding-bottom: 8px; }
    .section h3 { color: #99ccff; font-size: 18px; margin: 24px 0 12px 0; }
    .section p { margin-bottom: 16px; }
    .section ul, .section ol { margin-left: 24px; margin-bottom: 16px; }
    .section li { margin-bottom: 8px; }
    
    .info-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin: 24px 0; }
    .info-card { background: rgba(30, 30, 60, 0.5); border: 2px solid #334; border-radius: 12px; padding: 20px; text-align: center; }
    .info-card:hover { border-color: #ff9900; }
    .card-icon { font-size: 40px; margin-bottom: 12px; }
    .info-card h3 { color: #ffcc00; margin-bottom: 8px; }
    .info-card p { color: #888; font-size: 13px; margin: 0; }
    
    .steps-list { background: rgba(20, 40, 60, 0.3); padding: 20px 20px 20px 40px; border-radius: 8px; border-left: 4px solid #ff9900; }
    .steps-list li { margin-bottom: 12px; }
    
    .feature-block { background: rgba(20, 20, 40, 0.5); border: 1px solid #334; border-radius: 12px; padding: 20px; margin-bottom: 20px; }
    .feature-block h3 { margin-top: 0; }
    
    .data-table { width: 100%; border-collapse: collapse; margin-top: 12px; }
    .data-table th { background: rgba(255, 153, 0, 0.2); color: #ffcc00; text-align: left; padding: 10px; border-bottom: 2px solid #ff9900; }
    .data-table td { padding: 10px; border-bottom: 1px solid #334; color: #99ccff; }
    .data-table tr:hover td { background: rgba(255, 153, 0, 0.1); }
    
    .star-legend { display: flex; flex-direction: column; gap: 8px; margin-top: 12px; }
    .legend-item { display: flex; align-items: center; gap: 12px; }
    .star { width: 20px; height: 20px; border-radius: 50%; }
    .star.yellow { background: radial-gradient(circle, #ffff88, #ffcc00); }
    .star.red { background: radial-gradient(circle, #ff8866, #cc4400); }
    .star.blue { background: radial-gradient(circle, #88ccff, #4488ff); }
    .star.white { background: radial-gradient(circle, #ffffff, #aabbcc); }
    
    .highlight-text { background: rgba(255, 153, 0, 0.15); border-left: 4px solid #ff9900; padding: 16px; margin: 16px 0; border-radius: 0 8px 8px 0; font-style: italic; }
    
