@page "/game/combat-doctrine/{FleetId:guid}"
@layout StellarisLayout
@using StarTrekGame.Web.Services
@using MudBlazor
@inject IGameApiClient Api
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Combat Doctrine - Galactic Strategy</PageTitle>

<div class="doctrine-page">
    @if (_loading)
    {
        <div class="doctrine-loading">
            <div class="loading-spinner"></div>
            <span>Loading battle doctrine...</span>
        </div>
    }
    else
    {
        @* ═══════════════════════════════════════════════════════════
           LEFT COLUMN — Doctrine Settings
           ═══════════════════════════════════════════════════════════ *@
        <div class="doctrine-left">

            @* ── Doctrine Name ── *@
            <section class="doctrine-section">
                <h2 class="section-title">DOCTRINE NAME</h2>
                <input type="text" class="doctrine-input" @bind="_name" placeholder="Enter doctrine name..." />
            </section>

            @* ── Engagement Policy ── *@
            <section class="doctrine-section">
                <h2 class="section-title">ENGAGEMENT POLICY</h2>
                <div class="engagement-grid">
                    @foreach (var ep in _engagementPolicies)
                    {
                        <div class="engagement-card @(ep.Value == _engagement ? "selected" : "")"
                             @onclick="() => _engagement = ep.Value">
                            <span class="engagement-emoji">@ep.Emoji</span>
                            <span class="engagement-name">@ep.Label</span>
                            <span class="engagement-desc">@ep.Description</span>
                        </div>
                    }
                </div>
            </section>

            @* ── Formation ── *@
            <section class="doctrine-section">
                <h2 class="section-title">FORMATION</h2>
                <div class="formation-grid">
                    @foreach (var fm in _formations)
                    {
                        <div class="formation-card @(fm.Value == _formation ? "selected" : "")"
                             @onclick="() => _formation = fm.Value">
                            <div class="formation-preview">@fm.AsciiArt</div>
                            <span class="formation-name">@fm.Label</span>
                        </div>
                    }
                </div>
            </section>

            @* ── Target Priority ── *@
            <section class="doctrine-section">
                <h2 class="section-title">TARGET PRIORITY</h2>
                <select class="doctrine-select" @bind="_targetPriority">
                    <option value="HighestThreat">Highest Threat</option>
                    <option value="Weakest">Weakest Target</option>
                    <option value="Capitals">Capital Ships</option>
                    <option value="Flagships">Flagships</option>
                    <option value="Random">Random</option>
                </select>
            </section>

            @* ── Retreat Threshold ── *@
            <section class="doctrine-section">
                <h2 class="section-title">RETREAT THRESHOLD</h2>
                <div class="retreat-slider-row">
                    <input type="range" class="doctrine-slider" min="0" max="100"
                           @bind="_retreatThreshold" @bind:event="oninput" />
                    <span class="retreat-value">@_retreatThreshold%</span>
                </div>
                <p class="retreat-hint">Fleet will retreat when losses exceed this percentage.</p>
            </section>

            @* ── Conditional Orders ── *@
            <section class="doctrine-section">
                <h2 class="section-title">CONDITIONAL ORDERS</h2>
                @if (_orders.Count == 0 && !_showOrderForm)
                {
                    <p class="no-orders-hint">No conditional orders defined. Add orders to automate mid-battle tactics.</p>
                }
                <div class="orders-list">
                    @for (int i = 0; i < _orders.Count; i++)
                    {
                        var idx = i;
                        var order = _orders[idx];
                        <div class="order-row">
                            <div class="order-info">
                                <span class="order-name">@order.Name</span>
                                <span class="order-summary">@FormatOrderSummary(order)</span>
                            </div>
                            <button class="order-delete-btn" @onclick="() => RemoveOrder(idx)" title="Remove order">X</button>
                        </div>
                    }
                </div>

                @if (_showOrderForm)
                {
                    <div class="order-form">
                        <div class="order-form-row">
                            <label>Name</label>
                            <input type="text" class="doctrine-input sm" @bind="_newOrderName" placeholder="Order name..." />
                        </div>
                        <div class="order-form-row">
                            <label>Trigger</label>
                            <select class="doctrine-select sm" @bind="_newTrigger">
                                <option value="ShipsLostPercent">Ships Lost %</option>
                                <option value="FlagshipDamaged">Flagship Damaged</option>
                                <option value="EnemyRetreat">Enemy Retreat</option>
                                <option value="RoundNumber">Round Number</option>
                                <option value="ShieldsBelow">Shields Below</option>
                            </select>
                        </div>
                        <div class="order-form-row">
                            <label>Comparison</label>
                            <select class="doctrine-select sm" @bind="_newComparison">
                                <option value="GreaterThan">Greater Than</option>
                                <option value="LessThan">Less Than</option>
                                <option value="Equals">Equals</option>
                            </select>
                        </div>
                        <div class="order-form-row">
                            <label>Threshold</label>
                            <input type="number" class="doctrine-input sm" @bind="_newThreshold" min="0" max="100" />
                        </div>
                        <div class="order-form-row">
                            <label>Action: Formation</label>
                            <select class="doctrine-select sm" @bind="_newFormation">
                                <option value="">-- none --</option>
                                <option value="Wedge">Wedge</option>
                                <option value="Sphere">Sphere</option>
                                <option value="Line">Line</option>
                                <option value="Dispersed">Dispersed</option>
                                <option value="Echelon">Echelon</option>
                            </select>
                        </div>
                        <div class="order-form-row">
                            <label>Action: Target Priority</label>
                            <select class="doctrine-select sm" @bind="_newTargetPriority">
                                <option value="">-- none --</option>
                                <option value="HighestThreat">Highest Threat</option>
                                <option value="Weakest">Weakest</option>
                                <option value="Capitals">Capitals</option>
                                <option value="Flagships">Flagships</option>
                                <option value="Random">Random</option>
                            </select>
                        </div>
                        <div class="order-form-row">
                            <label>Action: Engagement</label>
                            <select class="doctrine-select sm" @bind="_newEngagement">
                                <option value="">-- none --</option>
                                <option value="Aggressive">Aggressive</option>
                                <option value="Defensive">Defensive</option>
                                <option value="HitAndRun">Hit & Run</option>
                                <option value="Standoff">Standoff</option>
                                <option value="Balanced">Balanced</option>
                            </select>
                        </div>
                        <div class="order-form-row">
                            <label>Retreat</label>
                            <label class="retreat-checkbox-label">
                                <input type="checkbox" @bind="_newRetreat" />
                                <span>Order retreat when triggered</span>
                            </label>
                        </div>
                        <div class="order-form-actions">
                            <button class="btn-add-order" @onclick="AddOrder">ADD</button>
                            <button class="btn-cancel-order" @onclick="CancelOrderForm">CANCEL</button>
                        </div>
                    </div>
                }
                else
                {
                    <button class="btn-add-order-toggle" @onclick="() => _showOrderForm = true">+ Add Order</button>
                }
            </section>

            @* ── Save / Load Default ── *@
            <div class="doctrine-actions">
                <button class="btn-save-doctrine" @onclick="SaveDoctrine" disabled="@_saving">
                    @(_saving ? "SAVING..." : "SAVE DOCTRINE")
                </button>
                <button class="btn-load-default" @onclick="LoadDefault">LOAD DEFAULT</button>
            </div>

            @if (!string.IsNullOrEmpty(_statusMessage))
            {
                <div class="status-message">@_statusMessage</div>
            }
        </div>

        @* ═══════════════════════════════════════════════════════════
           RIGHT COLUMN — Drill Level + Summary
           ═══════════════════════════════════════════════════════════ *@
        <div class="doctrine-right">

            @* ── Drill Level Gauge ── *@
            <section class="doctrine-section drill-section">
                <h2 class="section-title">DRILL LEVEL</h2>
                <div class="drill-gauge-container">
                    <div class="drill-gauge" style="--drill-pct: @(_drillLevel * 3.6)deg;">
                        <div class="drill-gauge-inner">
                            <span class="drill-value">@_drillLevel</span>
                            <span class="drill-label">/ 100</span>
                        </div>
                    </div>
                    <div class="drill-rating">@GetDrillRating()</div>
                </div>
                <button class="btn-train" @onclick="DrillCrew" disabled="@(_drilling || _drillLevel >= 100)">
                    @(_drilling ? "TRAINING..." : "TRAIN CREW (+10)")
                </button>
            </section>

            @* ── Doctrine Summary ── *@
            <section class="doctrine-section summary-section">
                <h2 class="section-title">DOCTRINE SUMMARY</h2>
                <div class="summary-block">
                    <div class="summary-row"><span class="summary-key">Name:</span><span class="summary-val">@_name</span></div>
                    <div class="summary-row"><span class="summary-key">Engagement:</span><span class="summary-val">@FormatEngagement(_engagement)</span></div>
                    <div class="summary-row"><span class="summary-key">Formation:</span><span class="summary-val">@_formation</span></div>
                    <div class="summary-row"><span class="summary-key">Target Priority:</span><span class="summary-val">@FormatTargetPriority(_targetPriority)</span></div>
                    <div class="summary-row"><span class="summary-key">Retreat At:</span><span class="summary-val">@_retreatThreshold% losses</span></div>
                    <div class="summary-row"><span class="summary-key">Drill Level:</span><span class="summary-val">@_drillLevel (@GetDrillRating())</span></div>
                    <div class="summary-row"><span class="summary-key">Orders:</span><span class="summary-val">@_orders.Count conditional</span></div>
                </div>
                <p class="summary-text">@GenerateSummaryText()</p>
            </section>

            @* ── Back to Fleet ── *@
            <button class="btn-back-fleet" @onclick="BackToFleet">BACK TO FLEET</button>
        </div>
    }
</div>

<style>
/* ═══════════════════════════════════════════════════════════
   COMBAT DOCTRINE PAGE
   ═══════════════════════════════════════════════════════════ */
.doctrine-page{display:grid;grid-template-columns:2fr 1fr;gap:20px;padding:20px;height:100%;overflow-y:auto}

/* ── Loading ── */
.doctrine-loading{grid-column:1/-1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;color:var(--st-text-dim,#667788)}
.loading-spinner{width:40px;height:40px;border:3px solid rgba(100,140,200,0.2);border-top-color:var(--st-accent-blue,#4a9eff);border-radius:50%;animation:spin 1s linear infinite}

/* ── Columns ── */
.doctrine-left,.doctrine-right{display:flex;flex-direction:column;gap:16px}

/* ── Section ── */
.doctrine-section{background:rgba(15,20,35,0.8);border:1px solid rgba(100,140,200,0.2);border-radius:8px;padding:16px}
.section-title{font-family:var(--st-font-display,inherit);font-size:12px;color:var(--st-accent-gold,#ffcc44);letter-spacing:2px;margin:0 0 12px;padding-bottom:8px;border-bottom:1px solid rgba(100,140,200,0.1)}

/* ── Inputs ── */
.doctrine-input{width:100%;background:rgba(0,0,0,0.3);border:1px solid rgba(100,140,200,0.25);border-radius:4px;padding:8px 12px;color:var(--st-text-white,#e0e8f0);font-size:14px;outline:none;box-sizing:border-box}
.doctrine-input:focus{border-color:var(--st-accent-blue,#4a9eff);box-shadow:0 0 8px rgba(74,158,255,0.2)}
.doctrine-input.sm{width:100%}

.doctrine-select{width:100%;background:rgba(0,0,0,0.3);border:1px solid rgba(100,140,200,0.25);border-radius:4px;padding:8px 12px;color:var(--st-text-white,#e0e8f0);font-size:13px;outline:none;box-sizing:border-box}
.doctrine-select:focus{border-color:var(--st-accent-blue,#4a9eff)}
.doctrine-select.sm{width:100%}
.doctrine-select option{background:#0f1423;color:#e0e8f0}

/* ═══════ ENGAGEMENT POLICY ═══════ */
.engagement-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px}
.engagement-card{display:flex;flex-direction:column;align-items:center;text-align:center;padding:14px 10px;background:rgba(0,0,0,0.25);border:1px solid rgba(100,140,200,0.15);border-radius:6px;cursor:pointer;transition:all 0.2s}
.engagement-card:hover{border-color:rgba(100,140,200,0.4);background:rgba(0,0,0,0.35)}
.engagement-card.selected{border-color:var(--st-accent-blue,#4a9eff);background:rgba(74,158,255,0.1);box-shadow:0 0 12px rgba(74,158,255,0.2)}
.engagement-emoji{font-size:28px;margin-bottom:6px}
.engagement-name{font-size:12px;font-weight:600;color:var(--st-text-white,#e0e8f0);letter-spacing:1px;margin-bottom:4px}
.engagement-desc{font-size:10px;color:var(--st-text-dim,#667788);line-height:1.3}

/* ═══════ FORMATION ═══════ */
.formation-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px}
.formation-card{display:flex;flex-direction:column;align-items:center;text-align:center;padding:14px 8px;background:rgba(0,0,0,0.25);border:1px solid rgba(100,140,200,0.15);border-radius:6px;cursor:pointer;transition:all 0.2s}
.formation-card:hover{border-color:rgba(100,140,200,0.4);background:rgba(0,0,0,0.35)}
.formation-card.selected{border-color:var(--st-accent-blue,#4a9eff);background:rgba(74,158,255,0.1);box-shadow:0 0 12px rgba(74,158,255,0.2)}
.formation-preview{font-family:monospace;font-size:16px;color:var(--st-accent-blue,#4a9eff);margin-bottom:8px;height:36px;display:flex;align-items:center;justify-content:center;white-space:pre}
.formation-name{font-size:11px;font-weight:600;color:var(--st-text-white,#e0e8f0);letter-spacing:1px}

/* ═══════ RETREAT SLIDER ═══════ */
.retreat-slider-row{display:flex;align-items:center;gap:12px}
.doctrine-slider{flex:1;-webkit-appearance:none;appearance:none;height:6px;background:rgba(100,140,200,0.2);border-radius:3px;outline:none}
.doctrine-slider::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;background:var(--st-accent-blue,#4a9eff);border-radius:50%;cursor:pointer;box-shadow:0 0 6px rgba(74,158,255,0.4)}
.doctrine-slider::-moz-range-thumb{width:18px;height:18px;background:var(--st-accent-blue,#4a9eff);border-radius:50%;cursor:pointer;border:none}
.retreat-value{font-family:var(--st-font-display,inherit);font-size:18px;color:var(--st-accent-gold,#ffcc44);min-width:48px;text-align:right}
.retreat-hint{font-size:10px;color:var(--st-text-dim,#667788);margin:6px 0 0}

/* ═══════ CONDITIONAL ORDERS ═══════ */
.orders-list{display:flex;flex-direction:column;gap:6px;margin-bottom:10px}
.order-row{display:flex;align-items:center;gap:10px;padding:10px 12px;background:rgba(0,0,0,0.2);border:1px solid rgba(100,140,200,0.1);border-radius:4px}
.order-info{flex:1;min-width:0}
.order-name{display:block;font-size:12px;font-weight:600;color:var(--st-text-white,#e0e8f0)}
.order-summary{display:block;font-size:10px;color:var(--st-text-dim,#667788);margin-top:2px}
.order-delete-btn{background:rgba(255,68,68,0.15);border:1px solid rgba(255,68,68,0.3);color:var(--st-accent-red,#ff4444);width:28px;height:28px;border-radius:4px;cursor:pointer;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center;transition:all 0.2s}
.order-delete-btn:hover{background:rgba(255,68,68,0.3);border-color:rgba(255,68,68,0.6)}
.no-orders-hint{font-size:11px;color:var(--st-text-dim,#667788);margin:0 0 8px}

/* ── Order Form ── */
.order-form{background:rgba(0,0,0,0.25);border:1px solid rgba(100,140,200,0.2);border-radius:6px;padding:14px;margin-top:8px;display:flex;flex-direction:column;gap:10px}
.order-form-row{display:flex;align-items:center;gap:10px}
.order-form-row label{font-size:11px;color:var(--st-text-muted,#8899aa);min-width:110px;flex-shrink:0}
.retreat-checkbox-label{display:flex;align-items:center;gap:8px;cursor:pointer;min-width:auto}
.retreat-checkbox-label input[type="checkbox"]{accent-color:var(--st-accent-blue,#4a9eff)}
.retreat-checkbox-label span{font-size:12px;color:var(--st-text-white,#e0e8f0)}
.order-form-actions{display:flex;gap:8px;margin-top:4px}

.btn-add-order,.btn-cancel-order,.btn-add-order-toggle{padding:8px 16px;border-radius:4px;font-size:11px;font-weight:600;letter-spacing:1px;cursor:pointer;transition:all 0.2s;border:1px solid}
.btn-add-order{background:rgba(74,158,255,0.15);border-color:rgba(74,158,255,0.4);color:var(--st-accent-blue,#4a9eff)}
.btn-add-order:hover{background:rgba(74,158,255,0.25)}
.btn-cancel-order{background:rgba(255,255,255,0.05);border-color:rgba(100,140,200,0.2);color:var(--st-text-muted,#8899aa)}
.btn-cancel-order:hover{background:rgba(255,255,255,0.1)}
.btn-add-order-toggle{background:rgba(74,158,255,0.1);border-color:rgba(74,158,255,0.3);color:var(--st-accent-blue,#4a9eff);width:100%}
.btn-add-order-toggle:hover{background:rgba(74,158,255,0.2)}

/* ═══════ SAVE / LOAD ═══════ */
.doctrine-actions{display:flex;gap:12px;margin-top:4px}
.btn-save-doctrine,.btn-load-default{flex:1;padding:12px 20px;border-radius:6px;font-size:12px;font-weight:700;letter-spacing:1px;cursor:pointer;transition:all 0.2s;border:1px solid}
.btn-save-doctrine{background:linear-gradient(135deg,rgba(74,158,255,0.2),rgba(74,158,255,0.1));border-color:var(--st-accent-blue,#4a9eff);color:var(--st-accent-blue,#4a9eff)}
.btn-save-doctrine:hover:not(:disabled){background:linear-gradient(135deg,rgba(74,158,255,0.35),rgba(74,158,255,0.2));box-shadow:0 0 16px rgba(74,158,255,0.25)}
.btn-save-doctrine:disabled{opacity:0.5;cursor:not-allowed}
.btn-load-default{background:rgba(255,255,255,0.05);border-color:rgba(100,140,200,0.25);color:var(--st-text-muted,#8899aa)}
.btn-load-default:hover{background:rgba(255,255,255,0.1)}

.status-message{font-size:11px;color:var(--st-accent-green,#44dd66);text-align:center;margin-top:4px}

/* ═══════ DRILL GAUGE (conic-gradient circle) ═══════ */
.drill-section{align-items:center;text-align:center}
.drill-gauge-container{display:flex;flex-direction:column;align-items:center;gap:12px;margin-bottom:12px}
.drill-gauge{width:160px;height:160px;border-radius:50%;background:conic-gradient(var(--st-accent-blue,#4a9eff) var(--drill-pct),rgba(100,140,200,0.15) var(--drill-pct));display:flex;align-items:center;justify-content:center;position:relative;box-shadow:0 0 20px rgba(74,158,255,0.15)}
.drill-gauge-inner{width:120px;height:120px;border-radius:50%;background:rgba(10,14,26,0.95);display:flex;flex-direction:column;align-items:center;justify-content:center}
.drill-value{font-family:var(--st-font-display,inherit);font-size:36px;color:var(--st-text-white,#e0e8f0);line-height:1}
.drill-label{font-size:12px;color:var(--st-text-dim,#667788);margin-top:2px}
.drill-rating{font-size:12px;font-weight:600;letter-spacing:1px;color:var(--st-accent-gold,#ffcc44)}

.btn-train{padding:10px 24px;border-radius:6px;font-size:12px;font-weight:700;letter-spacing:1px;cursor:pointer;transition:all 0.2s;background:linear-gradient(135deg,rgba(68,221,102,0.2),rgba(68,221,102,0.1));border:1px solid var(--st-accent-green,#44dd66);color:var(--st-accent-green,#44dd66);width:100%}
.btn-train:hover:not(:disabled){background:linear-gradient(135deg,rgba(68,221,102,0.35),rgba(68,221,102,0.2));box-shadow:0 0 16px rgba(68,221,102,0.25)}
.btn-train:disabled{opacity:0.5;cursor:not-allowed}

/* ═══════ SUMMARY ═══════ */
.summary-block{display:flex;flex-direction:column;gap:6px;margin-bottom:12px}
.summary-row{display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:1px solid rgba(100,140,200,0.06)}
.summary-key{font-size:11px;color:var(--st-text-dim,#667788)}
.summary-val{font-size:12px;color:var(--st-text-white,#e0e8f0);font-weight:500}
.summary-text{font-size:11px;color:var(--st-text-muted,#8899aa);line-height:1.5;margin:0;padding:10px;background:rgba(0,0,0,0.2);border-radius:4px;border-left:2px solid var(--st-accent-gold,#ffcc44)}

/* ═══════ BACK BUTTON ═══════ */
.btn-back-fleet{padding:12px 20px;border-radius:6px;font-size:12px;font-weight:700;letter-spacing:1px;cursor:pointer;transition:all 0.2s;background:rgba(255,255,255,0.05);border:1px solid rgba(100,140,200,0.25);color:var(--st-text-muted,#8899aa);width:100%;margin-top:auto}
.btn-back-fleet:hover{background:rgba(255,255,255,0.1);border-color:rgba(100,140,200,0.4)}

@@keyframes spin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}

/* ═══════ RESPONSIVE ═══════ */
@@media(max-width:900px){
    .doctrine-page{grid-template-columns:1fr}
    .formation-grid{grid-template-columns:repeat(3,1fr)}
}
</style>

@code {
    [Parameter] public Guid FleetId { get; set; }
    [CascadingParameter(Name = "GameState")] public StellarisLayout.GameLayoutState? GameState { get; set; }

    private BattleDoctrineDto? _doctrine;
    private string _name = "Standard Doctrine";
    private string _engagement = "Balanced";
    private string _formation = "Line";
    private string _targetPriority = "HighestThreat";
    private int _retreatThreshold = 50;
    private int _drillLevel = 0;
    private List<ConditionalOrderDto> _orders = new();

    // Conditional order form state
    private bool _showOrderForm;
    private string _newOrderName = "";
    private string _newTrigger = "ShipsLostPercent";
    private string _newComparison = "GreaterThan";
    private int _newThreshold = 50;
    private string? _newFormation;
    private string? _newTargetPriority;
    private string? _newEngagement;
    private bool _newRetreat;

    private bool _loading = true;
    private bool _saving;
    private bool _drilling;
    private string _statusMessage = "";

    // ── Static Data ────────────────────────────────────────

    private record EngagementOption(string Value, string Label, string Emoji, string Description);
    private record FormationOption(string Value, string Label, string AsciiArt);

    private static readonly EngagementOption[] _engagementPolicies = new[]
    {
        new EngagementOption("Aggressive", "Aggressive", "\u2694\uFE0F", "Focus on damage output, accept higher losses"),
        new EngagementOption("Defensive", "Defensive", "\uD83D\uDEE1\uFE0F", "Prioritize survival, shields first"),
        new EngagementOption("HitAndRun", "Hit & Run", "\uD83D\uDCA8", "Strike fast, disengage when pressured"),
        new EngagementOption("Standoff", "Standoff", "\uD83C\uDFAF", "Maintain distance, use long-range weapons"),
        new EngagementOption("Balanced", "Balanced", "\u2696\uFE0F", "Adapt to the situation, moderate approach"),
    };

    private static readonly FormationOption[] _formations = new[]
    {
        new FormationOption("Wedge", "Wedge", "  \u25B3\n\u25C1 \u25B7"),
        new FormationOption("Sphere", "Sphere", " \u25CB\n\u25CB \u25CB"),
        new FormationOption("Line", "Line", "\u2500\u2500\u2500\u2500"),
        new FormationOption("Dispersed", "Dispersed", "\u00B7 \u00B7 \u00B7"),
        new FormationOption("Echelon", "Echelon", " / / /"),
    };

    // ── Lifecycle ──────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var doctrine = await Api.GetDoctrineAsync(FleetId);
            if (doctrine != null)
            {
                _doctrine = doctrine;
                _name = doctrine.Name;
                _engagement = doctrine.EngagementPolicy;
                _formation = doctrine.Formation;
                _targetPriority = doctrine.TargetPriority;
                _retreatThreshold = doctrine.RetreatThreshold;
                _drillLevel = doctrine.DrillLevel;
                _orders = doctrine.ConditionalOrders?.ToList() ?? new();
            }
        }
        catch
        {
            // API not available — keep defaults (graceful degradation)
        }
        _loading = false;
    }

    // ── Actions ────────────────────────────────────────────

    private async Task SaveDoctrine()
    {
        _saving = true;
        _statusMessage = "";
        try
        {
            var request = new SaveDoctrineRequest(_name, _engagement, _formation, _targetPriority, _retreatThreshold, _orders);
            await Api.SaveDoctrineAsync(FleetId, request);
            _statusMessage = "Doctrine saved successfully.";
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save doctrine: {ex.Message}", Severity.Error);
        }
        _saving = false;
    }

    private async Task LoadDefault()
    {
        var raceId = GameState?.RaceId ?? "federation";
        try
        {
            var def = await Api.GetDefaultDoctrineAsync(raceId);
            if (def != null)
            {
                _name = def.Name;
                _engagement = def.EngagementPolicy;
                _formation = def.Formation;
                _targetPriority = def.TargetPriority;
                _retreatThreshold = def.RetreatThreshold;
                _orders = def.ConditionalOrders?.ToList() ?? new();
                _statusMessage = $"Loaded default doctrine for {raceId}.";
            }
            else
            {
                Snackbar.Add("No default doctrine found.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load default: {ex.Message}", Severity.Error);
        }
    }

    private async Task DrillCrew()
    {
        if (_drillLevel >= 100) return;
        _drilling = true;
        try
        {
            var result = await Api.DrillCrewAsync(FleetId);
            if (result != null)
            {
                _drillLevel = result.DrillLevel;
            }
            else
            {
                _drillLevel = Math.Min(100, _drillLevel + 10);
            }
        }
        catch
        {
            _drillLevel = Math.Min(100, _drillLevel + 10);
        }
        _drilling = false;
    }

    private void AddOrder()
    {
        if (string.IsNullOrWhiteSpace(_newOrderName)) return;

        var action = new MidBattleActionDto(
            string.IsNullOrEmpty(_newFormation) ? null : _newFormation,
            string.IsNullOrEmpty(_newTargetPriority) ? null : _newTargetPriority,
            string.IsNullOrEmpty(_newEngagement) ? null : _newEngagement,
            _newRetreat
        );

        _orders.Add(new ConditionalOrderDto(_newOrderName, _newTrigger, _newComparison, _newThreshold, action, false, false));
        ResetOrderForm();
    }

    private void RemoveOrder(int index)
    {
        if (index >= 0 && index < _orders.Count)
            _orders.RemoveAt(index);
    }

    private void CancelOrderForm()
    {
        ResetOrderForm();
    }

    private void ResetOrderForm()
    {
        _showOrderForm = false;
        _newOrderName = "";
        _newTrigger = "ShipsLostPercent";
        _newComparison = "GreaterThan";
        _newThreshold = 50;
        _newFormation = null;
        _newTargetPriority = null;
        _newEngagement = null;
        _newRetreat = false;
    }

    private void BackToFleet()
    {
        Nav.NavigateTo("/game/fleets");
    }

    // ── Formatting Helpers ─────────────────────────────────

    private string FormatOrderSummary(ConditionalOrderDto order)
    {
        var trigger = $"{FormatTrigger(order.Trigger)} {FormatComparison(order.Comparison)} {order.Threshold}";
        var actions = new List<string>();
        if (!string.IsNullOrEmpty(order.Action.NewFormation)) actions.Add($"Formation: {order.Action.NewFormation}");
        if (!string.IsNullOrEmpty(order.Action.NewTargetPriority)) actions.Add($"Target: {order.Action.NewTargetPriority}");
        if (!string.IsNullOrEmpty(order.Action.NewEngagement)) actions.Add($"Engage: {order.Action.NewEngagement}");
        if (order.Action.Retreat) actions.Add("RETREAT");
        return $"{trigger} \u2192 {(actions.Count > 0 ? string.Join(", ", actions) : "No action")}";
    }

    private static string FormatTrigger(string trigger) => trigger switch
    {
        "ShipsLostPercent" => "Ships Lost %",
        "FlagshipDamaged" => "Flagship Damaged",
        "EnemyRetreat" => "Enemy Retreat",
        "RoundNumber" => "Round #",
        "ShieldsBelow" => "Shields Below",
        _ => trigger
    };

    private static string FormatComparison(string comp) => comp switch
    {
        "GreaterThan" => ">",
        "LessThan" => "<",
        "Equals" => "=",
        _ => comp
    };

    private static string FormatEngagement(string eng) => eng switch
    {
        "HitAndRun" => "Hit & Run",
        _ => eng
    };

    private static string FormatTargetPriority(string tp) => tp switch
    {
        "HighestThreat" => "Highest Threat",
        _ => tp
    };

    private string GetDrillRating() => _drillLevel switch
    {
        >= 90 => "ELITE",
        >= 70 => "VETERAN",
        >= 50 => "TRAINED",
        >= 25 => "GREEN",
        _ => "UNTRAINED"
    };

    private string GenerateSummaryText()
    {
        var eng = _engagement switch
        {
            "Aggressive" => "engaging aggressively with maximum firepower",
            "Defensive" => "holding a defensive posture with shields prioritized",
            "HitAndRun" => "using hit-and-run tactics to minimize exposure",
            "Standoff" => "maintaining distance for long-range engagement",
            _ => "adapting flexibly to battlefield conditions"
        };
        var form = _formation switch
        {
            "Wedge" => "wedge formation to concentrate forward firepower",
            "Sphere" => "sphere formation for all-around coverage",
            "Dispersed" => "dispersed formation to reduce area-of-effect damage",
            "Echelon" => "echelon formation for staggered broadside volleys",
            _ => "line formation for balanced broadside engagement"
        };
        return $"This fleet operates under \"{_name}\" doctrine, {eng} in {form}. "
             + $"Primary targets: {FormatTargetPriority(_targetPriority).ToLower()}. "
             + $"The fleet will retreat if losses exceed {_retreatThreshold}%. "
             + $"Crew readiness: {GetDrillRating().ToLower()} (drill level {_drillLevel}/100). "
             + (_orders.Count > 0 ? $"{_orders.Count} conditional order(s) will trigger during battle." : "No conditional orders configured.");
    }
}
