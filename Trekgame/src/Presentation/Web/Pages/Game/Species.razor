@page "/game/species"
@layout StellarisLayout
@using StarTrekGame.Web.Services
@using Blazored.LocalStorage
@using MudBlazor
@inject IGameApiClient Api
@inject ILocalStorageService LocalStorage
@inject ISnackbar Snackbar

<PageTitle>Species - Galactic Strategy</PageTitle>

<div class="species-page">
    <div class="species-header">
        <h1>SPECIES DATABASE</h1>
        <p>Encyclopedia, demographics, and genetic modification.</p>
        <div class="tab-bar">
            <button class="tab-btn @(_activeTab == "database" ? "active" : "")" @onclick='() => _activeTab = "database"'>Database</button>
            <button class="tab-btn @(_activeTab == "demographics" ? "active" : "")" @onclick='() => _activeTab = "demographics"'>Demographics</button>
            <button class="tab-btn @(_activeTab == "genemod" ? "active" : "")" @onclick='() => _activeTab = "genemod"'>Gene Modification</button>
        </div>
    </div>

    @if (_loading)
    {
        <div class="loading-indicator">Scanning xenobiological records...</div>
    }
    else
    {
        @* ═══════════════════════════════════════════════════════════════ *@
        @* TAB 1: DATABASE (Encyclopedia)                                  *@
        @* ═══════════════════════════════════════════════════════════════ *@
        @if (_activeTab == "database")
        {
            <div class="database-layout">
                <!-- Left: Species Card Grid -->
                <div class="species-list-panel">
                    <div class="search-bar">
                        <input type="text" class="search-input" placeholder="Search species..."
                               @bind="_searchText" @bind:event="oninput" />
                    </div>
                    <div class="quadrant-filters">
                        @foreach (var q in _quadrantLabels)
                        {
                            <button class="quadrant-btn @(_filterQuadrant == q ? "active" : "")"
                                    @onclick="() => _filterQuadrant = q">@q</button>
                        }
                    </div>
                    <div class="species-grid">
                        @if (FilteredSpecies.Count == 0)
                        {
                            <div class="empty-state">
                                <span class="empty-icon">🧬</span>
                                <p>No species match your search criteria.</p>
                            </div>
                        }
                        @foreach (var sp in FilteredSpecies)
                        {
                            <div class="species-card @(_selectedSpecies?.Id == sp.Id ? "selected" : "")"
                                 @onclick="() => SelectSpecies(sp)">
                                <span class="sp-icon">@sp.Icon</span>
                                <div class="sp-info">
                                    <div class="sp-name">@sp.Name</div>
                                    <div class="sp-homeworld">@sp.HomeWorld &mdash; @sp.IdealClimate</div>
                                    <div class="sp-traits-preview">
                                        @foreach (var t in sp.TraitNames.Take(3))
                                        {
                                            <span class="trait-tag">@t</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Right: Detail Panel -->
                <div class="species-detail-panel @(_selectedSpecies != null ? "visible" : "")">
                    @if (_selectedSpecies != null)
                    {
                        var s = _selectedSpecies;
                        <div class="detail-header">
                            <span class="detail-icon">@s.Icon</span>
                            <div>
                                <h2>@s.Name</h2>
                                <span class="detail-subtitle" style="color: @s.Color">@s.HomeWorld &bull; @s.IdealClimate</span>
                            </div>
                        </div>
                        <p class="detail-desc">@s.Description</p>

                        <!-- Modifier Bars -->
                        <div class="section-header">SPECIES MODIFIERS</div>
                        <div class="modifier-bars">
                            @foreach (var mod in GetModifiers(s))
                            {
                                var pct = Math.Clamp((mod.Value / 2.0) * 100, 0, 100);
                                var barColor = mod.Value > 1.0 ? "#2ecc71" : mod.Value < 1.0 ? "#e74c3c" : "#667788";
                                <div class="mod-row">
                                    <span class="mod-label">@mod.Label</span>
                                    <div class="mod-bar-track">
                                        <div class="mod-bar-fill" style="width: @(pct.ToString("F0", System.Globalization.CultureInfo.InvariantCulture))%; background: @barColor;"></div>
                                    </div>
                                    <span class="mod-value" style="color: @barColor;">@(mod.Value.ToString("F2"))x</span>
                                </div>
                            }
                        </div>

                        <!-- Upkeep -->
                        <div class="section-header">UPKEEP</div>
                        <div class="upkeep-row">
                            <span class="upkeep-item">🍖 Food: @s.FoodUpkeep.ToString("F1")</span>
                            <span class="upkeep-item">📦 Consumer Goods: @s.ConsumerGoodsUpkeep.ToString("F1")</span>
                        </div>

                        <!-- Habitability -->
                        <div class="section-header">HABITABILITY</div>
                        <div class="habitability-pills">
                            @foreach (var hab in s.HabitabilityModifiers)
                            {
                                <span class="hab-pill" style="background: @GetHabColor(hab.Value);">
                                    @hab.Key @((hab.Value * 100).ToString("F0"))%
                                </span>
                            }
                        </div>

                        <!-- Traits -->
                        <div class="section-header">TRAITS</div>
                        <div class="trait-cards">
                            @foreach (var tid in s.TraitIds)
                            {
                                var trait = _traits.FirstOrDefault(t => t.Id == tid);
                                if (trait != null)
                                {
                                    <div class="trait-card-detail">
                                        <div class="trait-card-head">
                                            <span class="trait-cat-badge @trait.Category.ToLower()">@trait.Category</span>
                                            <span class="trait-cost">@(trait.Cost > 0 ? $"+{trait.Cost}" : trait.Cost.ToString()) pts</span>
                                        </div>
                                        <div class="trait-card-name">@trait.Name</div>
                                        <div class="trait-card-desc">@trait.Description</div>
                                    </div>
                                }
                            }
                        </div>

                        <!-- Special Flags -->
                        <div class="section-header">SPECIAL</div>
                        <div class="special-flags">
                            <span class="flag-pill">Lifespan: @s.Lifespan yrs</span>
                            @if (s.CanBeAssimilated) { <span class="flag-pill assimilable">Can Be Assimilated</span> }
                            @if (!s.CanBeAssimilated) { <span class="flag-pill immune">Immune to Assimilation</span> }
                            @if (s.RequiresKetracelWhite) { <span class="flag-pill ketracel">Requires Ketracel-White</span> }
                            @if (s.RequiresOrgans) { <span class="flag-pill organs">Requires Organs</span> }
                        </div>
                    }
                    else
                    {
                        <div class="no-selection">
                            <span class="no-sel-icon">🔬</span>
                            <p>Select a species to view details.</p>
                        </div>
                    }
                </div>
            </div>
        }

        @* ═══════════════════════════════════════════════════════════════ *@
        @* TAB 2: DEMOGRAPHICS                                            *@
        @* ═══════════════════════════════════════════════════════════════ *@
        @if (_activeTab == "demographics")
        {
            @if (!_factionId.HasValue)
            {
                <div class="empty-state"><p>No faction selected. Start a game first.</p></div>
            }
            else if (_demographics == null)
            {
                <div class="empty-state"><p>No demographic data available.</p></div>
            }
            else
            {
                <div class="demographics-section">
                    <!-- Empire-wide stats -->
                    <div class="demo-header-card">
                        <span class="demo-stat-big">@_demographics.TotalPops.ToString("N0")</span>
                        <span class="demo-stat-label">million citizens across @_demographics.Colonies.Count colonies</span>
                    </div>

                    <!-- Species Breakdown -->
                    <div class="section-header">EMPIRE SPECIES BREAKDOWN</div>
                    <div class="breakdown-chart">
                        @foreach (var sp in _demographics.SpeciesBreakdown.OrderByDescending(x => x.Count))
                        {
                            <div class="breakdown-row">
                                <span class="br-icon">@sp.Icon</span>
                                <span class="br-name">@sp.Name</span>
                                <div class="br-bar-track">
                                    <div class="br-bar-fill" style="width: @(sp.Percentage.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                </div>
                                <span class="br-count">@sp.Count.ToString("N0")</span>
                                <span class="br-pct">@(sp.Percentage.ToString("F1"))%</span>
                            </div>
                        }
                    </div>

                    <!-- Per-Colony Expandable Sections -->
                    <div class="section-header">PER-COLONY DEMOGRAPHICS</div>
                    <div class="colony-demographics">
                        @foreach (var col in _demographics.Colonies)
                        {
                            var colKey = col.ColonyId.ToString();
                            var isExpanded = _expandedColonies.ContainsKey(colKey) && _expandedColonies[colKey];
                            <div class="colony-demo-block">
                                <div class="colony-demo-header" @onclick="() => ToggleColony(colKey)">
                                    <span class="expand-icon">@(isExpanded ? "▼" : "▶")</span>
                                    <span class="col-name">@col.ColonyName</span>
                                    <span class="col-pop-count">@col.Species.Sum(x => x.Count).ToString("N0") pops</span>
                                </div>
                                @if (isExpanded)
                                {
                                    <div class="colony-demo-body">
                                        @foreach (var sp in col.Species.OrderByDescending(x => x.Count))
                                        {
                                            <div class="breakdown-row compact">
                                                <span class="br-icon">@sp.Icon</span>
                                                <span class="br-name">@sp.Name</span>
                                                <div class="br-bar-track">
                                                    <div class="br-bar-fill" style="width: @(sp.Percentage.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                                </div>
                                                <span class="br-count">@sp.Count.ToString("N0")</span>
                                                <span class="br-pct">@(sp.Percentage.ToString("F1"))%</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Species Rights -->
                    <div class="section-header">SPECIES RIGHTS</div>
                    <div class="rights-panel">
                        @foreach (var sp in _demographics.SpeciesBreakdown)
                        {
                            var rights = GetRightsEdit(sp.SpeciesId, sp.Rights);
                            <div class="rights-row">
                                <div class="rights-species">
                                    <span class="br-icon">@sp.Icon</span>
                                    <span class="rights-sp-name">@sp.Name</span>
                                </div>
                                <div class="rights-selects">
                                    <div class="rights-field">
                                        <label>Citizenship</label>
                                        <select value="@rights.Cit"
                                                @onchange="e => UpdateRight(sp.SpeciesId, cit: e.Value?.ToString())">
                                            <option value="Full">Full</option>
                                            <option value="Resident">Resident</option>
                                            <option value="Slave">Slave</option>
                                            <option value="Undesirable">Undesirable</option>
                                        </select>
                                    </div>
                                    <div class="rights-field">
                                        <label>Military</label>
                                        <select value="@rights.Mil"
                                                @onchange="e => UpdateRight(sp.SpeciesId, mil: e.Value?.ToString())">
                                            <option value="Full">Full</option>
                                            <option value="Limited">Limited</option>
                                            <option value="None">None</option>
                                        </select>
                                    </div>
                                    <div class="rights-field">
                                        <label>Living Standard</label>
                                        <select value="@rights.Liv"
                                                @onchange="e => UpdateRight(sp.SpeciesId, liv: e.Value?.ToString())">
                                            <option value="Academic">Academic</option>
                                            <option value="Normal">Normal</option>
                                            <option value="Basic">Basic</option>
                                            <option value="Subsistence">Subsistence</option>
                                        </select>
                                    </div>
                                    <button class="btn-apply-rights" @onclick="() => ApplyRights(sp.SpeciesId)">Apply</button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }

        @* ═══════════════════════════════════════════════════════════════ *@
        @* TAB 3: GENE MODIFICATION                                        *@
        @* ═══════════════════════════════════════════════════════════════ *@
        @if (_activeTab == "genemod")
        {
            @if (!_hasGeneticTech)
            {
                <div class="lock-message">
                    <span class="lock-icon">🔒</span>
                    <p>Research <strong>Genetic Engineering</strong> to unlock gene modification.</p>
                </div>
            }
            else if (!_factionId.HasValue)
            {
                <div class="empty-state"><p>No faction selected. Start a game first.</p></div>
            }
            else
            {
                <div class="genemod-section">
                    <!-- Species Selector -->
                    <div class="genemod-selector">
                        <label>Target Species:</label>
                        <select class="genemod-select" value="@_geneModSpeciesId"
                                @onchange="OnGeneModSpeciesChanged">
                            <option value="">-- Select Species --</option>
                            @if (_demographics != null)
                            {
                                @foreach (var sp in _demographics.SpeciesBreakdown)
                                {
                                    <option value="@sp.SpeciesId">@sp.Icon @sp.Name (@sp.Count pops)</option>
                                }
                            }
                        </select>
                    </div>

                    @if (!string.IsNullOrEmpty(_geneModSpeciesId))
                    {
                        <div class="genemod-columns">
                            <!-- Left: Current Traits -->
                            <div class="genemod-col">
                                <div class="genemod-col-header">Current Traits</div>
                                <div class="genemod-trait-list">
                                    @foreach (var tid in _currentGeneTraits)
                                    {
                                        var trait = _traits.FirstOrDefault(t => t.Id == tid);
                                        var isPendingRemove = _pendingRemoveTraits.Contains(tid);
                                        if (trait != null)
                                        {
                                            <div class="genemod-trait-card @(isPendingRemove ? "removing" : "")">
                                                <div class="gm-trait-info">
                                                    <span class="trait-cat-badge @trait.Category.ToLower()">@trait.Category</span>
                                                    <span class="gm-trait-name">@trait.Name</span>
                                                    <span class="gm-trait-cost">@(trait.Cost > 0 ? $"+{trait.Cost}" : trait.Cost.ToString()) pts</span>
                                                </div>
                                                @if (!isPendingRemove)
                                                {
                                                    <button class="btn-remove-trait" @onclick="() => MarkRemoveTrait(tid)">✕</button>
                                                }
                                                else
                                                {
                                                    <button class="btn-undo-trait" @onclick="() => UnmarkRemoveTrait(tid)">↩</button>
                                                }
                                            </div>
                                        }
                                    }
                                    @if (_currentGeneTraits.Count == 0)
                                    {
                                        <p class="no-traits-msg">No current traits.</p>
                                    }
                                </div>
                            </div>

                            <!-- Right: Available Traits -->
                            <div class="genemod-col">
                                <div class="genemod-col-header">Available Traits</div>
                                <div class="trait-category-tabs">
                                    @foreach (var cat in _traitCategories)
                                    {
                                        <button class="trait-cat-tab @(_traitFilterCategory == cat ? "active" : "")"
                                                @onclick="() => _traitFilterCategory = cat">@cat</button>
                                    }
                                </div>
                                <div class="genemod-trait-list">
                                    @foreach (var trait in FilteredAvailableTraits)
                                    {
                                        var isAdded = _pendingAddTraits.Contains(trait.Id);
                                        <div class="genemod-trait-card available @(isAdded ? "added" : "")"
                                             @onclick="() => ToggleAddTrait(trait.Id)">
                                            <div class="gm-trait-info">
                                                <span class="trait-cat-badge @trait.Category.ToLower()">@trait.Category</span>
                                                <span class="gm-trait-name">@trait.Name</span>
                                                <span class="gm-trait-cost">@(trait.Cost > 0 ? $"+{trait.Cost}" : trait.Cost.ToString()) pts</span>
                                            </div>
                                            <div class="gm-trait-desc">@trait.Description</div>
                                            @if (isAdded)
                                            {
                                                <span class="added-badge">ADDED</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Summary Bar -->
                        <div class="genemod-summary">
                            <div class="gm-summary-stats">
                                <span>Points: <strong>@GeneModPointsUsed / @GeneModBudget</strong></span>
                                <span>Adding: <strong>@_pendingAddTraits.Count</strong> traits</span>
                                <span>Removing: <strong>@_pendingRemoveTraits.Count</strong> traits</span>
                            </div>
                            <button class="btn-apply-genemod @(CanApplyGeneMod ? "" : "disabled")"
                                    disabled="@(!CanApplyGeneMod)"
                                    @onclick="ApplyGeneMod">
                                Apply Modifications
                            </button>
                        </div>
                    }
                </div>
            }
        }
    }
</div>

@code {
    private Guid? _factionId;
    private bool _loading = true;
    private string _activeTab = "database";

    // Tab 1: Database
    private List<SpeciesDto> _species = [];
    private List<TraitDto> _traits = [];
    private SpeciesDto? _selectedSpecies;
    private string _searchText = "";
    private string _filterQuadrant = "All";

    // Tab 2: Demographics
    private DemographicsDto? _demographics;
    private Dictionary<string, bool> _expandedColonies = new();
    private Dictionary<string, (string Cit, string Mil, string Liv)> _rightsEdits = new();

    // Tab 3: Gene Modification
    private string? _geneModSpeciesId;
    private List<string> _currentGeneTraits = [];
    private List<string> _pendingAddTraits = [];
    private List<string> _pendingRemoveTraits = [];
    private string _traitFilterCategory = "All";
    private bool _hasGeneticTech = true; // TODO: wire to actual tech check

    // Modifier helpers
    private record ModInfo(string Label, double Value);
    private static ModInfo[] GetModifiers(SpeciesDto s) =>
    [
        new("Growth Rate", s.GrowthRate), new("Research", s.Research), new("Military", s.Military),
        new("Trade", s.Trade), new("Diplomacy", s.Diplomacy), new("Mining", s.Mining),
        new("Engineering", s.Engineering), new("Stability", s.Stability), new("Espionage", s.Spy)
    ];

    // Constants
    private static readonly string[] _quadrantLabels = ["All", "Alpha", "Beta", "Gamma", "Delta", "Borg", "Xindi"];
    private static readonly string[] _traitCategories = ["All", "Physical", "Biological", "Mental", "Psychic", "Social", "Special"];

    private static readonly Dictionary<string, string[]> _quadrantSpecies = new()
    {
        ["Alpha"] = ["human", "vulcan", "klingon", "romulan", "cardassian", "ferengi", "andorian", "tellarite", "betazoid", "bajoran", "trill"],
        ["Beta"] = ["orion", "nausicaan", "denobulan", "bolian", "benzite", "pakled", "reman", "el_aurian"],
        ["Gamma"] = ["jem_hadar", "vorta", "changeling"],
        ["Delta"] = ["hirogen", "kazon", "vidiian", "talaxian", "ocampa"],
        ["Borg"] = ["borg", "species_8472"],
        ["Xindi"] = ["xindi_reptilian", "xindi_insectoid", "xindi_aquatic", "xindi_primate", "xindi_arboreal"]
    };

    private List<SpeciesDto> FilteredSpecies
    {
        get
        {
            var list = _species.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(_searchText))
            {
                var q = _searchText.Trim().ToLowerInvariant();
                list = list.Where(s =>
                    s.Name.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                    s.HomeWorld.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                    s.IdealClimate.Contains(q, StringComparison.OrdinalIgnoreCase));
            }
            if (_filterQuadrant != "All" && _quadrantSpecies.TryGetValue(_filterQuadrant, out var ids))
            {
                list = list.Where(s => ids.Contains(s.Id.ToLowerInvariant()));
            }
            return list.ToList();
        }
    }

    private List<TraitDto> FilteredAvailableTraits
    {
        get
        {
            var list = _traits.AsEnumerable();
            if (_traitFilterCategory != "All")
                list = list.Where(t => t.Category.Equals(_traitFilterCategory, StringComparison.OrdinalIgnoreCase));
            // Exclude already current traits (unless pending remove) and already added
            list = list.Where(t =>
                !_currentGeneTraits.Contains(t.Id) || _pendingRemoveTraits.Contains(t.Id));
            list = list.Where(t => !_pendingAddTraits.Contains(t.Id));
            return list.ToList();
        }
    }

    private int GeneModBudget => 5;
    private int GeneModPointsUsed
    {
        get
        {
            int pts = 0;
            foreach (var tid in _pendingAddTraits)
            {
                var t = _traits.FirstOrDefault(x => x.Id == tid);
                if (t != null) pts += Math.Abs(t.Cost);
            }
            return pts;
        }
    }
    private bool CanApplyGeneMod => (_pendingAddTraits.Count > 0 || _pendingRemoveTraits.Count > 0)
                                     && GeneModPointsUsed <= GeneModBudget
                                     && !string.IsNullOrEmpty(_geneModSpeciesId);

    protected override async Task OnInitializedAsync()
    {
        _factionId = await LocalStorage.GetItemAsync<Guid?>("currentFactionId");
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _species = await Api.GetAllSpeciesAsync();
            _traits = await Api.GetAllTraitsAsync();
            if (_factionId.HasValue)
                _demographics = await Api.GetDemographicsAsync(_factionId.Value);
        }
        catch
        {
            _species = [];
            _traits = [];
        }
        _loading = false;
    }

    // ── Tab 1 ──
    private void SelectSpecies(SpeciesDto sp)
    {
        _selectedSpecies = _selectedSpecies?.Id == sp.Id ? null : sp;
    }

    private string GetHabColor(double val)
    {
        if (val >= 0.8) return "rgba(46, 204, 113, 0.25)";
        if (val >= 0.5) return "rgba(241, 196, 15, 0.25)";
        if (val >= 0.2) return "rgba(230, 126, 34, 0.25)";
        return "rgba(231, 76, 60, 0.25)";
    }

    // ── Tab 2 ──
    private void ToggleColony(string colKey)
    {
        if (_expandedColonies.ContainsKey(colKey))
            _expandedColonies[colKey] = !_expandedColonies[colKey];
        else
            _expandedColonies[colKey] = true;
    }

    private (string Cit, string Mil, string Liv) GetRightsEdit(string speciesId, SpeciesRightsData? existing)
    {
        if (_rightsEdits.TryGetValue(speciesId, out var edit))
            return edit;
        var cit = existing?.Citizenship ?? "Full";
        var mil = existing?.MilitaryService ?? "Full";
        var liv = existing?.LivingStandard ?? "Normal";
        var val = (cit, mil, liv);
        _rightsEdits[speciesId] = val;
        return val;
    }

    private void UpdateRight(string speciesId, string? cit = null, string? mil = null, string? liv = null)
    {
        var current = GetRightsEdit(speciesId, null);
        _rightsEdits[speciesId] = (
            cit ?? current.Cit,
            mil ?? current.Mil,
            liv ?? current.Liv
        );
    }

    private async Task ApplyRights(string speciesId)
    {
        if (!_factionId.HasValue) return;
        var r = GetRightsEdit(speciesId, null);
        try
        {
            await Api.SetSpeciesRightsAsync(_factionId.Value,
                new SetSpeciesRightsRequest(speciesId, r.Cit, r.Mil, r.Liv));
            Snackbar.Add($"Rights updated for {speciesId}", Severity.Success);
            _demographics = await Api.GetDemographicsAsync(_factionId.Value);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed: {ex.Message}", Severity.Error);
        }
    }

    // ── Tab 3 ──
    private void OnGeneModSpeciesChanged(ChangeEventArgs e)
    {
        _geneModSpeciesId = e.Value?.ToString();
        _pendingAddTraits.Clear();
        _pendingRemoveTraits.Clear();
        _currentGeneTraits.Clear();

        if (!string.IsNullOrEmpty(_geneModSpeciesId))
        {
            var sp = _species.FirstOrDefault(s => s.Id == _geneModSpeciesId);
            if (sp != null)
                _currentGeneTraits = sp.TraitIds.ToList();
        }
    }

    private void MarkRemoveTrait(string traitId)
    {
        if (!_pendingRemoveTraits.Contains(traitId))
            _pendingRemoveTraits.Add(traitId);
    }

    private void UnmarkRemoveTrait(string traitId)
    {
        _pendingRemoveTraits.Remove(traitId);
    }

    private void ToggleAddTrait(string traitId)
    {
        if (_pendingAddTraits.Contains(traitId))
            _pendingAddTraits.Remove(traitId);
        else
            _pendingAddTraits.Add(traitId);
    }

    private async Task ApplyGeneMod()
    {
        if (!_factionId.HasValue || string.IsNullOrEmpty(_geneModSpeciesId)) return;
        try
        {
            var req = new GeneModRequest(
                _geneModSpeciesId,
                _pendingAddTraits.Count > 0 ? _pendingAddTraits.ToArray() : null,
                _pendingRemoveTraits.Count > 0 ? _pendingRemoveTraits.ToArray() : null
            );
            var ok = await Api.ModifyGenesAsync(_factionId.Value, req);
            if (ok)
            {
                Snackbar.Add("Gene modification applied successfully!", Severity.Success);
                _pendingAddTraits.Clear();
                _pendingRemoveTraits.Clear();
                await LoadData();
                // Refresh current traits
                var sp = _species.FirstOrDefault(s => s.Id == _geneModSpeciesId);
                if (sp != null)
                    _currentGeneTraits = sp.TraitIds.ToList();
            }
            else
            {
                Snackbar.Add("Gene modification failed.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }
}

