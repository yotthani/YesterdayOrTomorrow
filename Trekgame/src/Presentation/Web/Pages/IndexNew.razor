@page "/"
@page "/menu"
@page "/main-menu"
@layout EmptyLayout
@using MudBlazor
@using StarTrekGame.Web.Services
@using StarTrekGame.Web.Components.MainMenuUI
@using Blazored.LocalStorage
@inject IGameApiClient Api
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@inject ISnackbar Snackbar
@inject ThemeService ThemeService
@inject MainMenuTemplateService TemplateService
@inject IJSRuntime JS

<PageTitle>TrekGame - The Final Strategy Frontier</PageTitle>

@* Full Menu Layout using templated components *@
<MenuLayout MenuStyle="@_menuStyle" Class="main-menu-page">
    <HeaderContent>
        <MenuHeader Title="TrekGame"
                    Subtitle="The Final Strategy Frontier"
                    CommunityTag="A <span class='yot-highlight'>YOT</span> Community Project" />
    </HeaderContent>

    <SidebarContent>
        <MenuSidebar HeaderTitle="MAIN MENU"
                     NavItems="@_navItems"
                     SecondaryNavItems="@_secondaryNavItems" />
    </SidebarContent>

    <MainContent>
        @if (_showNewGame)
        {
            <MenuPanel Title="NEW MISSION" ShowCloseButton="true" OnClose="@(() => _showNewGame = false)">
                <ChildContent>
                    <div class="faction-grid">
                        @foreach (var faction in _factions)
                        {
                            <div class="faction-card @(_selectedFaction == faction.Id ? "selected" : "")"
                                 @onclick="() => _selectedFaction = faction.Id">
                                <div class="faction-emblem" style="background: @faction.Color;">
                                    <img src="images/emblems/@(faction.Id).svg" alt="@faction.Name" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                                    <span style="display:none;">@faction.Icon</span>
                                </div>
                                <div class="faction-info">
                                    <h3>@faction.Name</h3>
                                    <p>@faction.Description</p>
                                </div>
                                <div class="faction-traits">
                                    @foreach (var trait in faction.Traits)
                                    {
                                        <span class="trait">@trait</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </ChildContent>
                <FooterContent>
                    <MenuButton Secondary="true" OnClick="@(() => _showNewGame = false)">CANCEL</MenuButton>
                    <MenuButton Primary="true" OnClick="StartNewGame" Disabled="@(_selectedFaction == null)">ENGAGE</MenuButton>
                </FooterContent>
            </MenuPanel>
        }
        else if (_showCredits)
        {
            <MenuPanel Title="CREDITS" ShowCloseButton="true" OnClose="@(() => _showCredits = false)">
                <ChildContent>
                    <div class="credits-content">
                        <div class="credit-section">
                            <h3 class="credit-heading">COMMUNITY</h3>
                            <p class="credit-line highlight"><span class="yot-badge">YOT</span> Yesterday or Tomorrow</p>
                            <p class="credit-line small">The community behind this project</p>
                        </div>
                        <div class="credit-divider"></div>
                        <div class="credit-section">
                            <h3 class="credit-heading">INSPIRED BY</h3>
                            <p class="credit-line">Star Trek™ Universe</p>
                            <p class="credit-line">Birth of the Federation (1999)</p>
                            <p class="credit-line">Stellaris by Paradox Interactive</p>
                            <p class="credit-line">Star Trek: New Horizons Mod</p>
                        </div>
                        <div class="credit-divider"></div>
                        <div class="credit-section">
                            <p class="credit-line small">Star Trek and related marks are trademarks of CBS Studios Inc.</p>
                            <p class="credit-line small">This is a fan project for educational and entertainment purposes.</p>
                        </div>
                    </div>
                </ChildContent>
            </MenuPanel>
        }
        else
        {
            <MenuPanel>
                <ChildContent>
                    <div class="welcome-content">
                        <div class="starfleet-emblem">🌟</div>
                        <h2>WELCOME, COMMANDER</h2>
                        <p>The galaxy awaits your leadership. Choose your path and shape the future of the Alpha Quadrant.</p>

                        @if (_hasExistingGame && _currentGame != null)
                        {
                            <div class="game-summary">
                                <div class="summary-header">CURRENT MISSION</div>
                                <div class="summary-stats">
                                    <div class="stat">
                                        <span class="stat-label">STARDATE</span>
                                        <span class="stat-value">@_currentGame.Turn.ToString("0.00")</span>
                                    </div>
                                    <div class="stat">
                                        <span class="stat-label">FACTIONS</span>
                                        <span class="stat-value">@_currentGame.Factions.Count</span>
                                    </div>
                                    <div class="stat">
                                        <span class="stat-label">SYSTEMS</span>
                                        <span class="stat-value">@_currentGame.SystemCount</span>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="quick-actions">
                            <MenuButton Icon="🎨" Secondary="true" OnClick="GoToAssets">Asset Gallery</MenuButton>
                            <MenuButton Icon="🖼" Secondary="true" OnClick="GoToShowcase">Showcase</MenuButton>
                        </div>
                    </div>
                </ChildContent>
            </MenuPanel>
        }
    </MainContent>

    <FooterContent>
        <MenuFooter Version="@GameVersion" VersionName="@VersionName" />
    </FooterContent>
</MenuLayout>

<style>
    /* Page-specific styles - using CSS variables from template */
    .main-menu-page {
        min-height: 100vh;
    }

    /* Welcome panel styles */
    .welcome-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        min-height: 400px;
    }

    .starfleet-emblem {
        font-size: 80px;
        margin-bottom: 20px;
        animation: emblem-glow 3s ease-in-out infinite;
    }

    @@keyframes emblem-glow {
        0%, 100% { filter: drop-shadow(0 0 20px rgba(255, 153, 0, 0.5)); }
        50% { filter: drop-shadow(0 0 40px rgba(255, 153, 0, 0.8)); }
    }

    .welcome-content h2 {
        font-family: var(--st-font-display, 'Orbitron', sans-serif);
        font-size: 28px;
        color: var(--menu-primary, #ff9900);
        letter-spacing: 4px;
        margin: 0 0 16px;
    }

    .welcome-content p {
        font-size: 14px;
        color: var(--menu-tertiary, #ffcc99);
        max-width: 500px;
        line-height: 1.6;
    }

    .game-summary {
        margin-top: 30px;
        background: rgba(255, 153, 0, 0.1);
        border: 1px solid var(--menu-primary, #ff9900);
        border-radius: 10px;
        padding: 20px;
        width: 100%;
        max-width: 400px;
    }

    .summary-header {
        font-family: var(--st-font-display, 'Orbitron', sans-serif);
        font-size: 12px;
        color: var(--menu-accent, #cc99ff);
        letter-spacing: 2px;
        margin-bottom: 16px;
    }

    .summary-stats {
        display: flex;
        justify-content: space-around;
    }

    .stat { text-align: center; }
    .stat-label { display: block; font-size: 10px; color: var(--menu-secondary, #cc9966); letter-spacing: 1px; margin-bottom: 4px; }
    .stat-value { font-family: var(--st-font-display, 'Orbitron', sans-serif); font-size: 24px; color: var(--menu-primary, #ff9900); }

    .quick-actions {
        display: flex;
        gap: 12px;
        margin-top: 30px;
    }

    /* Faction grid */
    .faction-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        max-height: 400px;
        overflow-y: auto;
    }

    .faction-card {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 16px;
        background: rgba(0, 0, 0, 0.5);
        border: 1px solid var(--menu-secondary, #cc9966);
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.15s;
    }

    .faction-card:hover {
        border-color: var(--menu-primary, #ff9900);
        background: rgba(255, 153, 0, 0.1);
    }

    .faction-card.selected {
        border-color: var(--menu-primary, #ff9900);
        border-width: 2px;
        box-shadow: 0 0 20px rgba(255, 153, 0, 0.3);
    }

    .faction-emblem {
        width: 60px;
        height: 60px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        padding: 8px;
        box-sizing: border-box;
    }

    .faction-emblem img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        filter: brightness(1.2);
    }

    .faction-info h3 {
        font-family: var(--st-font-display, 'Orbitron', sans-serif);
        font-size: 14px;
        color: var(--menu-primary, #ff9900);
        margin: 0;
    }

    .faction-info p {
        font-size: 11px;
        color: var(--menu-tertiary, #ffcc99);
        margin: 4px 0 0;
        line-height: 1.4;
    }

    .faction-traits {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
    }

    .trait {
        font-size: 9px;
        padding: 2px 8px;
        background: rgba(153, 153, 204, 0.2);
        border-radius: 10px;
        color: var(--menu-accent, #cc99ff);
    }

    /* Credits */
    .credits-content { text-align: center; padding: 40px; }
    .credit-section { margin-bottom: 20px; }
    .credit-heading { font-family: var(--st-font-display, 'Orbitron', sans-serif); font-size: 12px; color: var(--menu-accent, #cc99ff); letter-spacing: 3px; margin-bottom: 12px; }
    .credit-line { font-family: var(--st-font-display, 'Orbitron', sans-serif); font-size: 16px; color: var(--menu-primary, #ff9900); margin: 12px 0; }
    .credit-line.highlight { font-size: 20px; color: #ffcc00; }
    .credit-line.small { font-size: 11px; color: var(--menu-secondary, #cc9966); }
    .yot-badge { display: inline-block; background: linear-gradient(135deg, #ffcc00, #ff9900); color: #000; padding: 4px 12px; border-radius: 4px; font-weight: 700; font-size: 14px; margin-right: 8px; letter-spacing: 2px; }
    .credit-divider { height: 2px; background: var(--menu-secondary, #cc9966); margin: 30px auto; width: 200px; }
    .yot-highlight { color: #ffcc00; font-weight: 700; text-shadow: 0 0 10px rgba(255, 204, 0, 0.5); }
</style>

@code {
    private const string GameVersion = "1.43.64";
    private const string VersionName = "Building Blocks";

    private string _menuStyle = "lcars";  // Default menu style
    private bool _showNewGame = false;
    private bool _showCredits = false;
    private bool _hasExistingGame = false;
    private string? _selectedFaction = null;
    private GameDetailDto? _currentGame;

    private List<MenuSidebar.NavItemData> _navItems = new();
    private List<MenuSidebar.NavItemData> _secondaryNavItems = new();

    private List<FactionOption> _factions = new()
    {
        new("federation", "United Federation", "#4488ff", "🖖", "Exploration and diplomacy focused", new[] { "+Research", "+Diplomacy" }),
        new("klingon", "Klingon Empire", "#cc2222", "⚔️", "Honor through combat", new[] { "+Combat", "+Honor" }),
        new("romulan", "Romulan Star Empire", "#22aa66", "🦅", "Shadows and intrigue", new[] { "+Espionage", "+Cloaking" }),
        new("cardassian", "Cardassian Union", "#cc8822", "🔱", "Order through strength", new[] { "+Production", "+Control" }),
        new("ferengi", "Ferengi Alliance", "#ddaa22", "💎", "Profit above all", new[] { "+Trade", "+Economy" }),
        new("borg", "Borg Collective", "#22cc44", "⬛", "Resistance is futile", new[] { "+Assimilation", "+Tech" }),
        new("dominion", "Dominion", "#8844cc", "👁", "Order through control", new[] { "+Control", "+Military" }),
        new("bajoran", "Bajoran Republic", "#00bbcc", "🔮", "Faith and resistance", new[] { "+Faith", "+Resistance" }),
    };

    protected override void OnInitialized()
    {
        InitializeNavItems();
    }

    protected override async Task OnInitializedAsync()
    {
        await ThemeService.SetThemeAsync("default");
        try
        {
            var games = await Api.GetGamesAsync();
            if (games.Any())
            {
                _currentGame = await Api.GetGameAsync(games.First().Id);
                _hasExistingGame = true;
            }
        }
        catch { }
    }

    private void InitializeNavItems()
    {
        _navItems = new List<MenuSidebar.NavItemData>
        {
            new() { Label = "CONTINUE", Icon = "▶", IsPrimary = _hasExistingGame, OnClick = EventCallback.Factory.Create(this, ContinueGame) },
            new() { Label = "NEW GAME", Icon = "✦", OnClick = EventCallback.Factory.Create(this, () => _showNewGame = true) },
            new() { Label = "LOAD GAME", Icon = "◉", OnClick = EventCallback.Factory.Create(this, GoToSaveLoad) },
        };

        _secondaryNavItems = new List<MenuSidebar.NavItemData>
        {
            new() { Label = "SETTINGS", Icon = "⚙", OnClick = EventCallback.Factory.Create(this, GoToSettings) },
            new() { Label = "TUTORIAL", Icon = "?", OnClick = EventCallback.Factory.Create(this, GoToTutorial) },
            new() { Label = "CREDITS", Icon = "★", OnClick = EventCallback.Factory.Create(this, () => _showCredits = true) },
        };
    }

    private void GoToSaveLoad() => Navigation.NavigateTo("/game/save-load");
    private void GoToSettings() => Navigation.NavigateTo("/game/settings");
    private void GoToTutorial() => Navigation.NavigateTo("/game/tutorial");
    private void GoToAssets() => Navigation.NavigateTo("/game/assets");
    private void GoToShowcase() => Navigation.NavigateTo("/game/showcase");

    private async Task ContinueGame()
    {
        var gameId = await LocalStorage.GetItemAsync<Guid?>("currentGameId");
        var factionId = await LocalStorage.GetItemAsync<Guid?>("currentFactionId");

        if (gameId.HasValue && factionId.HasValue)
        {
            Navigation.NavigateTo("/game/galaxy");
        }
        else
        {
            try
            {
                var games = await Api.GetGamesAsync();
                if (games.Any())
                {
                    var gameList = games.First();
                    var game = await Api.GetGameAsync(gameList.Id);
                    if (game != null)
                    {
                        var firstFaction = game.Factions.FirstOrDefault();
                        if (firstFaction != null)
                        {
                            await LocalStorage.SetItemAsync("currentGameId", game.Id);
                            await LocalStorage.SetItemAsync("currentFactionId", firstFaction.Id);
                            Navigation.NavigateTo("/game/galaxy");
                            return;
                        }
                    }
                }
            }
            catch { }

            _showNewGame = true;
            StateHasChanged();
        }
    }

    private async Task StartNewGame()
    {
        if (_selectedFaction == null) return;

        try
        {
            var game = await Api.CreateGameAsync("New Galaxy", 30);
            var faction = await Api.JoinGameAsync(game.Id, "Commander", _factions.First(f => f.Id == _selectedFaction).Name, _selectedFaction);

            await LocalStorage.SetItemAsync("currentGameId", game.Id);
            await LocalStorage.SetItemAsync("currentFactionId", faction.Id);
            await LocalStorage.SetItemAsync("currentRaceId", _selectedFaction);

            // Set the theme for the newly selected faction
            await ThemeService.SetThemeForRaceAsync(_selectedFaction);

            Navigation.NavigateTo("/game/galaxy");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to create game: {ex.Message}", Severity.Error);
        }
    }

    record FactionOption(string Id, string Name, string Color, string Icon, string Description, string[] Traits);
}
