@using StarTrekGame.Web.Services
@inject MainMenuTemplateService TemplateService

@* Data-driven menu footer that renders based on template definition *@

@{
    var template = TemplateService.GetTemplate(_currentStyle);
    var footer = template.Footer;
}

<footer class="menu-footer @footer.Style @Class">
    @* Render structure parts *@
    @foreach (var part in footer.Structure)
    {
        @RenderStructurePart(part, template)
    }
</footer>

@code {
    [Parameter] public string? Version { get; set; }
    [Parameter] public string? VersionName { get; set; }
    [Parameter] public string? Disclaimer { get; set; }
    [Parameter] public RenderFragment? ExtraContent { get; set; }
    [Parameter] public string Class { get; set; } = "";

    /// <summary>
    /// Override the default menu style
    /// </summary>
    [Parameter] public string? Style { get; set; }

    [CascadingParameter(Name = "MenuStyle")]
    public string? CascadedStyle { get; set; }

    private string _currentStyle => Style ?? CascadedStyle ?? "lcars";

    private RenderFragment RenderStructurePart(string part, MenuTemplate template) => builder =>
    {
        var footer = template.Footer;

        switch (part)
        {
            case "segment-left":
            case "segment-right":
                builder.OpenElement(0, "span");
                builder.AddAttribute(1, "class", $"footer-segment {part.Replace("segment-", "")}");
                builder.CloseElement();
                break;

            case "text-center":
                builder.OpenElement(0, "span");
                builder.AddAttribute(1, "class", "footer-text center");
                builder.AddContent(2, "UNITED FEDERATION OF PLANETS • STARFLEET COMMAND");
                builder.CloseElement();
                break;

            case "disclaimer":
                if (!string.IsNullOrEmpty(Disclaimer))
                {
                    builder.OpenElement(0, "p");
                    builder.AddAttribute(1, "class", "footer-disclaimer");
                    builder.AddContent(2, Disclaimer);
                    builder.CloseElement();
                }
                break;

            case "version":
            case "version-small":
            case "version-center":
                if (footer.ShowVersion && !string.IsNullOrEmpty(Version))
                {
                    builder.OpenElement(0, "div");
                    builder.AddAttribute(1, "class", $"footer-version {part}");

                    builder.OpenElement(2, "span");
                    builder.AddAttribute(3, "class", "version-number");
                    builder.AddContent(4, $"v{Version}");
                    builder.CloseElement();

                    if (!string.IsNullOrEmpty(VersionName))
                    {
                        builder.OpenElement(5, "span");
                        builder.AddAttribute(6, "class", "version-name");
                        builder.AddContent(7, $"\"{VersionName}\"");
                        builder.CloseElement();
                    }

                    builder.CloseElement();
                }
                break;

            case "academy-motto":
                builder.OpenElement(0, "p");
                builder.AddAttribute(1, "class", "footer-motto");
                builder.AddContent(2, "Ex Astris, Scientia");
                builder.CloseElement();
                break;

            default:
                builder.OpenElement(0, "div");
                builder.AddAttribute(1, "class", $"footer-part {part}");
                if (ExtraContent != null)
                {
                    builder.AddContent(2, ExtraContent);
                }
                builder.CloseElement();
                break;
        }
    };
}
