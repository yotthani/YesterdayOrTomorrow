@using StarTrekGame.Web.Services
@inject FactionTemplateService TemplateService
@inject ThemeService ThemeService

@* Data-driven header that renders based on template definition *@

@{
    var template = TemplateService.GetTemplate(ThemeService.CurrentTheme);
    var header = template.Header;
}

<header class="templated-header @header.CssClass @Class">
    @* Render decorations first (positioned absolute) *@
    @foreach (var decoration in header.Decorations)
    {
        @RenderDecoration(decoration, template)
    }

    @* Render structure parts *@
    @foreach (var part in header.Structure)
    {
        @RenderStructurePart(part, template)
    }
</header>

@code {
    [Parameter] public string Title { get; set; } = "GALACTIC STRATEGY";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public RenderFragment? ResourceContent { get; set; }
    [Parameter] public RenderFragment? ActionContent { get; set; }
    [Parameter] public string Class { get; set; } = "";

    private RenderFragment RenderDecoration(DecorationElement decoration, FactionTemplate template) => builder =>
    {
        var positionClass = decoration.Position;

        switch (decoration.Type)
        {
            case "elbow":
            case "blade":
            case "wing":
            case "diamond":
            case "node":
            case "trefoil-emblem":
                builder.OpenElement(0, "div");
                builder.AddAttribute(1, "class", $"header-decoration {decoration.Type} {positionClass}");
                builder.CloseElement();
                break;

            case "multi-color-bar":
                builder.OpenElement(0, "div");
                builder.AddAttribute(1, "class", $"header-decoration color-bars {positionClass}");
                if (decoration.Colors != null)
                {
                    foreach (var color in decoration.Colors)
                    {
                        builder.OpenElement(2, "div");
                        builder.AddAttribute(3, "class", $"color-bar-segment {color}");
                        builder.CloseElement();
                    }
                }
                builder.CloseElement();
                break;

            case "spike":
            case "v-motif":
            case "bronze-divider":
            case "glow-line":
            case "grid-pattern":
            case "surveillance-line":
            case "golden-line":
            case "shimmer":
            case "hierarchy-indicator":
            case "status-light":
                builder.OpenElement(0, "div");
                builder.AddAttribute(1, "class", $"header-decoration {decoration.Type} {positionClass}");
                builder.CloseElement();
                break;

            default:
                builder.OpenElement(0, "div");
                builder.AddAttribute(1, "class", $"header-decoration {decoration.Type} {positionClass}");
                builder.CloseElement();
                break;
        }
    };

    private RenderFragment RenderStructurePart(string part, FactionTemplate template) => builder =>
    {
        switch (part)
        {
            case "title":
            case "designation":
            case "title-block":
                builder.OpenElement(0, "div");
                builder.AddAttribute(1, "class", $"header-title-block {part}");

                builder.OpenElement(2, "span");
                builder.AddAttribute(3, "class", "header-title");
                builder.AddContent(4, Title);
                builder.CloseElement();

                if (!string.IsNullOrEmpty(Subtitle))
                {
                    builder.OpenElement(5, "span");
                    builder.AddAttribute(6, "class", "header-subtitle");
                    builder.AddContent(7, Subtitle);
                    builder.CloseElement();
                }

                builder.CloseElement();
                break;

            case "subroutine-text":
                if (!string.IsNullOrEmpty(Subtitle))
                {
                    builder.OpenElement(0, "span");
                    builder.AddAttribute(1, "class", "header-subroutine");
                    builder.AddContent(2, Subtitle);
                    builder.CloseElement();
                }
                break;

            case "resources":
            case "data-readout":
                builder.OpenElement(0, "div");
                builder.AddAttribute(1, "class", $"header-resources {part}");
                builder.AddContent(2, ResourceContent);
                builder.CloseElement();
                break;

            case "actions":
            case "action-node":
                builder.OpenElement(0, "div");
                builder.AddAttribute(1, "class", $"header-actions {part}");
                builder.AddContent(2, ActionContent);
                builder.CloseElement();
                break;

            case "elbow":
            case "blade-left":
            case "blade-right":
            case "wing-left":
            case "wing-right":
            case "diamond-left":
            case "diamond-right":
            case "trefoil":
            case "bird-icon":
            case "founder-icon":
            case "emblem":
            case "cap":
            case "spike":
            case "v-accent":
            case "grid-overlay":
            case "status-nodes":
            case "hierarchy-indicator":
            case "surveillance-line":
            case "golden-line":
            case "color-bars":
            case "divider":
                builder.OpenElement(0, "div");
                builder.AddAttribute(1, "class", $"header-part {part}");
                builder.CloseElement();
                break;

            default:
                builder.OpenElement(0, "div");
                builder.AddAttribute(1, "class", $"header-part {part}");
                builder.CloseElement();
                break;
        }
    };
}
