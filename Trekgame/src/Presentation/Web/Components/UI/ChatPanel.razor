@using StarTrekGame.Web.Services
@inject IJSRuntime JS

<div class="chat-panel @(IsOpen ? "open" : "")">
    <div class="chat-header">
        <span class="chat-title">Chat</span>
        <button class="chat-close-btn" @onclick="ToggleChat">&times;</button>
    </div>

    <div class="chat-tabs">
        <button class="chat-tab @(_channel == "Global" ? "active" : "")"
                @onclick='() => _channel = "Global"'>Global</button>
        <button class="chat-tab @(_channel == "Alliance" ? "active" : "")"
                @onclick='() => _channel = "Alliance"'>Alliance</button>
    </div>

    <div class="chat-messages" @ref="_messagesContainer">
        @if (MpState is not null)
        {
            @foreach (var msg in MpState.ChatMessages.Where(m => m.Channel == _channel))
            {
                <div class="chat-message">
                    <div class="chat-message-header">
                        <span class="chat-sender">@msg.SenderName</span>
                        <span class="chat-timestamp">@msg.Timestamp.ToString("HH:mm")</span>
                    </div>
                    <div class="chat-text">@msg.Message</div>
                </div>
            }
        }
    </div>

    <div class="chat-input-area">
        <input class="chat-input"
               type="text"
               placeholder="Type a message..."
               @bind="_inputText"
               @bind:event="oninput"
               @onkeydown="OnKeyDown" />
        <button class="chat-send-btn" @onclick="SendMessage">Send</button>
    </div>
</div>

@code {
    [CascadingParameter(Name = "MultiplayerState")]
    public MultiplayerState? MpState { get; set; }

    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public EventCallback<(string message, string channel)> OnSendMessage { get; set; }

    private string _channel = "Global";
    private string _inputText = "";
    private ElementReference _messagesContainer;

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_inputText))
            return;

        await OnSendMessage.InvokeAsync((_inputText.Trim(), _channel));
        _inputText = "";
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    private async Task ToggleChat()
    {
        await IsOpenChanged.InvokeAsync(!IsOpen);
    }

    private int _lastMessageCount;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!IsOpen) return;

        var currentCount = MpState?.ChatMessages.Count(m => m.Channel == _channel) ?? 0;
        if (currentCount != _lastMessageCount || firstRender)
        {
            _lastMessageCount = currentCount;
            try
            {
                await JS.InvokeVoidAsync("eval",
                    "document.querySelector('.chat-messages')?.scrollTo(0, document.querySelector('.chat-messages')?.scrollHeight ?? 0)");
            }
            catch
            {
                // Ignore during prerendering or if element not yet in DOM
            }
        }
    }
}

<style>
    .chat-panel {
        position: fixed;
        top: 0;
        right: 0;
        width: 300px;
        height: 100%;
        z-index: 9000;
        display: flex;
        flex-direction: column;
        background: rgba(10, 15, 25, 0.95);
        border-left: 1px solid rgba(255, 153, 0, 0.3);
        transform: translateX(100%);
        transition: transform 0.3s ease;
        font-family: 'Segoe UI', sans-serif;
    }

    .chat-panel.open {
        transform: translateX(0);
    }

    .chat-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 14px;
        background: linear-gradient(180deg, rgba(20, 30, 50, 0.98) 0%, rgba(12, 18, 32, 0.98) 100%);
        border-bottom: 1px solid rgba(255, 153, 0, 0.25);
    }

    .chat-title {
        font-size: 14px;
        font-weight: 600;
        color: #ff9900;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .chat-close-btn {
        background: none;
        border: 1px solid rgba(100, 120, 160, 0.3);
        border-radius: 4px;
        color: #7890a8;
        font-size: 16px;
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.15s;
    }

    .chat-close-btn:hover {
        border-color: #ff9900;
        color: #ff9900;
        background: rgba(255, 153, 0, 0.1);
    }

    .chat-tabs {
        display: flex;
        border-bottom: 1px solid rgba(100, 120, 160, 0.2);
    }

    .chat-tab {
        flex: 1;
        padding: 8px 0;
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        color: #7890a8;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.15s;
    }

    .chat-tab:hover {
        color: #c8d4e8;
        background: rgba(255, 153, 0, 0.05);
    }

    .chat-tab.active {
        color: #ff9900;
        border-bottom-color: #ff9900;
    }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 10px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .chat-messages::-webkit-scrollbar {
        width: 4px;
    }

    .chat-messages::-webkit-scrollbar-track {
        background: rgba(10, 15, 25, 0.5);
    }

    .chat-messages::-webkit-scrollbar-thumb {
        background: rgba(255, 153, 0, 0.3);
        border-radius: 2px;
    }

    .chat-message {
        padding: 6px 8px;
        border-radius: 4px;
        background: rgba(30, 40, 60, 0.5);
        border: 1px solid rgba(100, 120, 160, 0.1);
    }

    .chat-message-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 3px;
    }

    .chat-sender {
        font-size: 11px;
        font-weight: 600;
        color: #ff9900;
    }

    .chat-timestamp {
        font-size: 10px;
        color: #7890a8;
    }

    .chat-text {
        font-size: 12px;
        color: #c8d4e8;
        line-height: 1.4;
        word-break: break-word;
    }

    .chat-input-area {
        display: flex;
        gap: 6px;
        padding: 10px;
        border-top: 1px solid rgba(255, 153, 0, 0.2);
        background: rgba(15, 20, 35, 0.95);
    }

    .chat-input {
        flex: 1;
        padding: 8px 10px;
        border-radius: 4px;
        border: 1px solid rgba(100, 120, 160, 0.3);
        background: rgba(20, 28, 45, 0.9);
        color: #c8d4e8;
        font-size: 12px;
        outline: none;
        transition: border-color 0.15s;
    }

    .chat-input::placeholder {
        color: rgba(120, 144, 168, 0.5);
    }

    .chat-input:focus {
        border-color: rgba(255, 153, 0, 0.5);
    }

    .chat-send-btn {
        padding: 8px 14px;
        border-radius: 4px;
        border: 1px solid #cc6600;
        background: linear-gradient(180deg, #cc6600 0%, #993300 100%);
        color: #fff;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.15s;
        white-space: nowrap;
    }

    .chat-send-btn:hover {
        background: linear-gradient(180deg, #dd7700 0%, #aa4400 100%);
        border-color: #ff8800;
        box-shadow: 0 0 8px rgba(255, 136, 0, 0.3);
    }

    .chat-send-btn:active {
        background: linear-gradient(180deg, #aa5500 0%, #882200 100%);
    }
</style>
